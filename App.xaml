<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HandWStat"
             x:Class="HandWStat.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="StudioInk">#071412</Color>
            <Color x:Key="StudioPaper">#F2F0E8</Color>
            <Color x:Key="StudioSignal">#FF5B2E</Color>
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource StudioPaper}, Dark={StaticResource StudioInk}}" />
                <Setter Property="Shell.NavBarIsVisible" Value="False" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
