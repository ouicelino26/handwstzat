@implements IDisposable
@inject IAppUpdateService UpdateService

@if (UpdateService.State.IsMandatory)
{
    <UpdateRequired />
}
else
{
<Router AppAssembly="@typeof(MauiProgram).Assembly"
        OnNavigateAsync="HandleNavigateAsync">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="[data-page-title], h1, h2" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(Layout.PublicLayout)">
            <DynamicComponent Type="typeof(HandWStat.Components.Pages.NotFound)" />
        </LayoutView>
    </NotFound>
</Router>

<UpdateAvailableDialog />
}

@if (_showTransition)
{
    <div class="studio-route-transition" role="status" aria-live="polite">
        <div class="studio-route-transition__mark" aria-hidden="true">
            <span></span><span></span><span></span>
        </div>
        <div>
            <strong>Changement de scene</strong>
            <small>Le contexte analytique reste synchronise.</small>
        </div>
    </div>
}

@code {
    private bool _showTransition;
    private bool _hideAfterRender;
    private bool _initialNavigationCompleted;
    private DateTimeOffset _startedAt;
    private static readonly TimeSpan MinimumDuration = TimeSpan.FromMilliseconds(170);

    protected override void OnInitialized()
    {
        UpdateService.StateChanged += HandleUpdateStateChanged;
        _ = UpdateService.CheckAsync();
    }

    private Task HandleNavigateAsync(NavigationContext args)
    {
        if (!_initialNavigationCompleted)
        {
            _initialNavigationCompleted = true;
            return Task.CompletedTask;
        }

        _startedAt = DateTimeOffset.UtcNow;
        _showTransition = true;
        _hideAfterRender = true;
        return InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_hideAfterRender)
        {
            return;
        }

        _hideAfterRender = false;
        var elapsed = DateTimeOffset.UtcNow - _startedAt;
        if (elapsed < MinimumDuration)
        {
            await Task.Delay(MinimumDuration - elapsed);
        }

        _showTransition = false;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleUpdateStateChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        UpdateService.StateChanged -= HandleUpdateStateChanged;
    }
}
