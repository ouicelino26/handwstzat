@page "/not-found"
@layout MainLayout
@inject NavigationManager Navigation

<PageTitle>Scene introuvable</PageTitle>

<section class="lost-scene">
    <div class="lost-scene__code" aria-hidden="true">404</div>
    <div class="lost-scene__copy">
        <span>Route hors terrain</span>
        <h2 data-page-title>Cette scene n'existe plus dans le studio.</h2>
        <p>Le lien a peut-etre change, mais votre contexte d'analyse reste intact.</p>
        <div>
            <button type="button" class="primary-button" @onclick="GoHome">Revenir a Today</button>
            <button type="button" class="ghost-button" @onclick="GoToDemo">Ouvrir la visite guidee</button>
        </div>
    </div>
</section>

@code {
    private void GoHome() => Navigation.NavigateTo("/dashboard");
    private void GoToDemo() => Navigation.NavigateTo("/demo");
}
