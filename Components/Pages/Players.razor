    private static string GetScatterInsightLabel(MatchTrendPoint point)
    {
        var impact = point.DirectContributions + point.DefensiveImpact;

        if (point.Turnovers >= 4 && impact < 4)
        {
            return "Risque eleve";
        }

        if (point.Turnovers <= 1 && impact >= 6)
        {
            return "Impact fort";
        }

        if (point.Turnovers <= 2 && impact >= 4)
        {
            return "Lecture propre";
        }

        if (impact >= 5)
        {
            return "Profil actif";
        }

        return "Profil equilibre";
    }

