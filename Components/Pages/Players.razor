    private async Task HandleZoneSelectionAsync(string zoneKey)
    {
        if (!SelectedPlayerId.HasValue || Spatial is null || string.IsNullOrWhiteSpace(zoneKey))
        {
            return;
        }

        var normalizedZoneKey = zoneKey.Trim();
        var nextFocusKey = string.Equals(SpatialFocusKey, normalizedZoneKey, StringComparison.OrdinalIgnoreCase)
            ? null
            : normalizedZoneKey;

        ActiveZoneKey = normalizedZoneKey;
        await LoadSpatialForFocusAsync(nextFocusKey);
    }

    private async Task ResetSpatialFocusAsync()
    {
        if (!HasSpatialFocus)
        {
            return;
        }

        await LoadSpatialForFocusAsync(null);
    }

    private async Task LoadSpatialForFocusAsync(string? focusZoneKey)
    {
        if (!SelectedPlayerId.HasValue)
        {
            return;
        }

        var playerId = SelectedPlayerId.Value;
        var loadToken = System.Threading.Interlocked.Increment(ref SpatialLoadToken);
        var options = BuildSpatialQueryOptions(focusZoneKey);

        IsSpatialLoading = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            var spatialTask = StatsApiClient.GetPlayerSpatialAsync(playerId, options);
            var spatial = await spatialTask;

            if (loadToken != SpatialLoadToken || !SelectedPlayerId.HasValue || SelectedPlayerId.Value != playerId)
            {
                return;
            }

            Spatial = spatial;
            SpatialFocusKey = focusZoneKey;
            ActiveZoneKey = ResolveActiveZoneKey(focusZoneKey);
            ErrorMessage = null;
        }
        catch (Exception ex)
        {
            if (loadToken != SpatialLoadToken || !SelectedPlayerId.HasValue || SelectedPlayerId.Value != playerId)
            {
                return;
            }

            ErrorMessage = ex.Message;
        }
        finally
        {
            if (loadToken == SpatialLoadToken && SelectedPlayerId.HasValue && SelectedPlayerId.Value == playerId)
            {
                IsSpatialLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private StatsQueryOptionsDto BuildSpatialQueryOptions(string? focusZoneKey)
    {
        var options = BuildOptions();

        if (string.IsNullOrWhiteSpace(focusZoneKey))
        {
            return options;
        }

        if (SpatialZoneVisuals.IsTriggerZoneKey(focusZoneKey))
        {
            options.Trigger = SpatialZoneVisuals.ToBackendTriggerKey(focusZoneKey);
        }
        else
        {
            options.ShootShade = focusZoneKey.Trim();
        }

        return options;
    }

    private string? ResolveActiveZoneKey(string? preferredKey = null)
    {
        var allZoneKeys = GoalZones
            .Concat(TriggerZones)
            .Select(zone => zone.Key)
            .Where(key => !string.IsNullOrWhiteSpace(key))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!string.IsNullOrWhiteSpace(preferredKey) && allZoneKeys.Contains(preferredKey))
        {
            return preferredKey;
        }

        if (!string.IsNullOrWhiteSpace(ActiveZoneKey) && allZoneKeys.Contains(ActiveZoneKey))
        {
            return ActiveZoneKey;
        }

        return GoalZones.FirstOrDefault(zone => zone.Attempts > 0)?.Key
            ?? TriggerZones.FirstOrDefault(zone => zone.Attempts > 0)?.Key
            ?? GoalZones.FirstOrDefault()?.Key
            ?? TriggerZones.FirstOrDefault()?.Key;
    }

