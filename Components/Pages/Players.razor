    private async Task LoadAsync(bool refreshReferenceData)
    {
        if (!AuthService.Session.IsAuthenticated)
        {
            ReferenceData = AnalyticsReferenceData.Empty;
            PlayerDirectory = [];
            await LoadPlayerDetailsAsync(manageBusyState: false);
            return;
        }

        var loadStartedAt = DateTimeOffset.UtcNow;

        try
        {
            await BusyUiHelper.EnterAsync(() => IsBusy = true, () => InvokeAsync(StateHasChanged));
            ErrorMessage = null;

            if (refreshReferenceData || ReferenceData == AnalyticsReferenceData.Empty)
            {
                ReferenceData = await ReferenceDataService.GetReferenceDataAsync(refreshReferenceData);
            }

            if (!HasDirectoryCriteria)
            {
                ScopedMatches = [];
                PlayerDirectory = [];
                await LoadPlayerDetailsAsync(manageBusyState: false);
                return;
            }

            await LoadFilterScopesAsync();

            var filtersAdjusted = false;

            if (CompetitionId.HasValue && AvailableCompetitions.All(item => item.CompetitionId != CompetitionId.Value))
            {
                CompetitionId = null;
                filtersAdjusted = true;
            }

            if (TeamId.HasValue && AvailableTeams.All(item => item.TeamId != TeamId.Value))
            {
                TeamId = null;
                filtersAdjusted = true;
            }

            if (filtersAdjusted)
            {
                await LoadFilterScopesAsync();
            }

            if (!string.IsNullOrWhiteSpace(Season) && !SeasonOptions.Contains(Season, StringComparer.OrdinalIgnoreCase))
            {
                Season = null;
            }

            if (!string.IsNullOrWhiteSpace(Day) && !DayOptions.Contains(Day, StringComparer.OrdinalIgnoreCase))
            {
                Day = null;
            }

            PlayerDirectory = await PlayersApiClient.GetPlayersAsync(
                teamId: TeamId,
                positionId: PositionId,
                competitionId: CompetitionId,
                year: Year,
                season: Season,
                day: Day,
                search: Search,
                pageSize: IsCompetitionOnlyDirectoryFilter ? 1000 : 250);

            SelectedPlayerId ??= PlayerDirectory.FirstOrDefault()?.PlayerId;

            if (SelectedPlayerId.HasValue && PlayerDirectory.All(player => player.PlayerId != SelectedPlayerId.Value))
            {
                SelectedPlayerId = PlayerDirectory.FirstOrDefault()?.PlayerId;
            }

            await LoadPlayerDetailsAsync(manageBusyState: false);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            await BusyUiHelper.ExitAsync(() => IsBusy = false, () => InvokeAsync(StateHasChanged), loadStartedAt);
        }
    }

    public void Dispose()
    {
        var cts = Interlocked.Exchange(ref _searchDebounceCts, null);
        cts?.Cancel();
        cts?.Dispose();
    }

    private async Task LoadPlayerDetailsAsync(bool manageBusyState = true)
    {
        System.Threading.Interlocked.Increment(ref SpatialLoadToken);
        IsSpatialLoading = false;

        if (!SelectedPlayerId.HasValue)
        {
            Profile = null;
            Global = null;
            Offense = null;
            Defense = null;
            Passing = null;
            Sanctions = null;
            Goalkeeper = null;
            Technical = null;
            Spatial = null;
            ActiveZoneKey = null;
            SpatialFocusKey = null;
            IsSpatialLoading = false;
            PlayerMatches = [];
            return;
        }

        var loadStartedAt = DateTimeOffset.UtcNow;

        try
        {
            if (manageBusyState)
            {
                await BusyUiHelper.EnterAsync(() => IsBusy = true, () => InvokeAsync(StateHasChanged));
            }
            ErrorMessage = null;

            var options = BuildOptions();

            var profileTask = PlayersApiClient.GetPlayerProfileAsync(SelectedPlayerId.Value, options);
            var globalTask = StatsApiClient.GetPlayerGlobalAsync(SelectedPlayerId.Value, options);
            var offenseTask = StatsApiClient.GetPlayerOffenseAsync(SelectedPlayerId.Value, options);
            var defenseTask = StatsApiClient.GetPlayerDefenseAsync(SelectedPlayerId.Value, options);
            var passingTask = StatsApiClient.GetPlayerPassingAsync(SelectedPlayerId.Value, options);
            var sanctionsTask = StatsApiClient.GetPlayerSanctionsAsync(SelectedPlayerId.Value, options);
            var goalkeeperTask = StatsApiClient.GetPlayerGoalkeeperAsync(SelectedPlayerId.Value, options);
            var technicalTask = StatsApiClient.GetPlayerTechnicalAsync(SelectedPlayerId.Value, options);
            var spatialTask = StatsApiClient.GetPlayerSpatialAsync(SelectedPlayerId.Value, options);
            var matchesTask = PlayersApiClient.GetPlayerMatchesAsync(SelectedPlayerId.Value, options);

            await Task.WhenAll(profileTask, globalTask, offenseTask, defenseTask, passingTask, sanctionsTask, goalkeeperTask, technicalTask, spatialTask, matchesTask);

            Profile = profileTask.Result;
            Global = globalTask.Result;
            Offense = offenseTask.Result;
            Defense = defenseTask.Result;
            Passing = passingTask.Result;
            Sanctions = sanctionsTask.Result;
            Goalkeeper = goalkeeperTask.Result;
            Technical = technicalTask.Result;
            Spatial = spatialTask.Result;
            PlayerMatches = matchesTask.Result;
            SpatialFocusKey = null;
            ActiveZoneKey = ResolveActiveZoneKey();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            if (manageBusyState)
            {
                await BusyUiHelper.ExitAsync(() => IsBusy = false, () => InvokeAsync(StateHasChanged), loadStartedAt);
            }
        }
    }

    private StatsQueryOptionsDto BuildOptions()
    {
        return new StatsQueryOptionsDto
        {
            CompetitionId = CompetitionId,
            TeamId = TeamId,
            PositionId = PositionId,
            Year = Year,
            Season = Season,
            Day = Day
        };
    }

    private StatsQueryOptionsDto BuildPlayerSheetPositionProfileOptions()
    {
        return new StatsQueryOptionsDto
        {
            PositionId = PositionId,
            Year = Year,
            Season = Season,
            Day = Day
        };
