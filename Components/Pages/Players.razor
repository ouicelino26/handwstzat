    private static string GetScatterInsightLabel(MatchTrendPoint point)
    {
        var impact = point.DirectContributions + point.DefensiveImpact;

        if (point.Turnovers >= 4 && impact < 4)
        {
            return "Risque eleve";
        }

        if (point.Turnovers <= 1 && impact >= 6)
        {
            return "Impact fort";
        }

        if (point.Turnovers <= 2 && impact >= 4)
        {
            return "Lecture propre";
        }

        if (impact >= 5)
        {
            return "Profil actif";
        }

        return "Profil equilibre";
    }

    private RenderFragment TableHeader(string column, string label, Action<string> onSort) => builder =>
    {
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "type", "button");
        builder.AddAttribute(2, "class", $"table-sort-button {(PlayerMatchSort.IsActive(column) ? "is-active" : string.Empty)}");
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => onSort(column)));
        builder.AddContent(4, label);

        var glyph = PlayerMatchSort.Glyph(column);
        if (!string.IsNullOrWhiteSpace(glyph))
        {
            builder.OpenElement(5, "span");
            builder.AddAttribute(6, "class", "sort-indicator");
            builder.AddContent(7, glyph);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static string FormatRate(double value) => value.ToString("0.#");
