            [
                new PlayerSheetRow("Matchs", Profile.MatchesPlayed.ToString(), "Volume total de rencontres analysees.", "info"),
                new PlayerSheetRow("Arrets", (Goalkeeper.Arrets + Goalkeeper.ArretsPenalty).ToString(), "Arrets classiques et penalties.", "positive"),
                new PlayerSheetRow("Arrets 7m", Goalkeeper.ArretsPenalty.ToString(), "Impact direct sur les phases decisives.", "good"),
                new PlayerSheetRow("Tirs subis", Goalkeeper.TirsSubis.ToString(), "Charge defensive absorbee.", "warning"),
                new PlayerSheetRow("Taux d'arret", $"{FormatRate(Goalkeeper.TauxArret)}%", "Lecture gardienne sur la ligne.", Goalkeeper.TauxArret >= 45 ? "positive" : "warning"),
                new PlayerSheetRow("Stop 7m", $"{FormatRate(Technical.GoalkeeperPenaltyStopRate)}%", "Efficacite sur penalties.", Technical.GoalkeeperPenaltyStopRate >= 40 ? "good" : "warning"),
                new PlayerSheetRow("Pertes techniques", Technical.TechnicalLosses.ToString(), "Mauvaises passes, pertes et fautes.", "danger"),
                new PlayerSheetRow("Sanctions", Technical.Sanctions.ToString(), "Charge disciplinaire individuelle.", "danger")
            ];
        }

        return
        [
            new PlayerSheetRow("Matchs", Profile.MatchesPlayed.ToString(), "Volume total de rencontres analysees.", "info"),
            new PlayerSheetRow("Buts", Global.TotalGoals.ToString(), "Production offensive directe.", "positive"),
            new PlayerSheetRow("Passes decisives", Global.AssistCount.ToString(), "Creation et finalisation du collectif.", "good"),
            new PlayerSheetRow("Interceptions", Defense.Interceptions.ToString(), "Impact defensif au contact.", "good"),
            new PlayerSheetRow("Tirs engages", Technical.ShotAttempts.ToString(), "Tirs rates, contres et penalties engages.", "warning"),
            new PlayerSheetRow("Taux de tir ouvert", $"{FormatRate(Technical.OpenShotSuccessRate)}%", "Conversion hors 7m.", Technical.OpenShotSuccessRate >= 50 ? "positive" : "warning"),
            new PlayerSheetRow("Pertes techniques", Technical.TechnicalLosses.ToString(), "Ballons rendus et fautes techniques.", "danger"),
            new PlayerSheetRow("Sanctions", Technical.Sanctions.ToString(), "Charge disciplinaire individuelle.", "danger")
        ];
    }

    private string BuildPlayerSheetRadarMarkup(PositionProfileResponseDto? positionProfile, int panelX, int panelY, int panelWidth, int panelHeight)
    {
        var axes = BuildRadarAxes(positionProfile);
        if (axes.Count == 0)
        {
            return $"""
  <rect x="{panelX + 24}" y="{panelY + 74}" width="{panelWidth - 48}" height="{panelHeight - 120}" rx="22" fill="#f8fafc" stroke="#d8e2ef" />
  <text x="{panelX + (panelWidth / 2)}" y="{panelY + 360}" text-anchor="middle" font-family="Segoe UI, Arial, sans-serif" font-size="18" font-weight="700" fill="#0f172a">Radar poste indisponible</text>
  <text x="{panelX + (panelWidth / 2)}" y="{panelY + 388}" text-anchor="middle" font-family="Segoe UI, Arial, sans-serif" font-size="13" fill="#64748b">La fiche reste exportee, mais la cohorte du poste n'a pas pu etre chargee.</text>
""";
        }

        var centerX = panelX + 264d;
        var centerY = panelY + 370d;
        var radius = 220d;
        var legendX = panelX + 430d;
        var legendY = panelY + 180d;
        var polygonLevels = new[] { 0.25d, 0.5d, 0.75d, 1d };
        var grid = string.Join("\n", polygonLevels.Select(level => BuildRadarPolygon(axes, centerX, centerY, radius * level, axis => 100d, "none", "#d7e0ea", 1)));
        var spokes = string.Join("\n", axes.Select((axis, index) =>
        {
            var point = GetRadarPoint(index, axes.Count, centerX, centerY, radius, 100d);
            return $"""<line x1="{FormatSvgNumber(centerX)}" y1="{FormatSvgNumber(centerY)}" x2="{FormatSvgNumber(point.X)}" y2="{FormatSvgNumber(point.Y)}" stroke="#d7e0ea" stroke-width="1" />""";
        }));
        var labels = string.Join("\n", axes.Select((axis, index) =>
        {
            var point = GetRadarPoint(index, axes.Count, centerX, centerY, radius + 42d, 100d);
            return $"""<text x="{FormatSvgNumber(point.X)}" y="{FormatSvgNumber(point.Y)}" text-anchor="{GetRadarTextAnchor(point.X, centerX)}" font-family="Segoe UI, Arial, sans-serif" font-size="14" font-weight="700" fill="#334155">{EscapeXml(axis.Label)}</text>""";
        }));
        var medianPolygon = BuildRadarPolygon(axes, centerX, centerY, radius, axis => axis.MedianValue, ChartColorUtilities.WithAlpha(ChartPalette.Reference, 0.12), ChartPalette.Reference, 2.5, "7 6");
        var playerPolygon = BuildRadarPolygon(axes, centerX, centerY, radius, axis => axis.PlayerValue, ChartColorUtilities.WithAlpha(ChartPalette.Player, 0.18), ChartPalette.Player, 3);

        return $"""
  <g>
    <rect x="{panelX + 24}" y="{panelY + 74}" width="{panelWidth - 48}" height="{panelHeight - 120}" rx="22" fill="#ffffff" stroke="#d8e2ef" />
    <g>
      {grid}
      {spokes}
      {medianPolygon}
      {playerPolygon}
      {labels}
      <circle cx="{FormatSvgNumber(centerX)}" cy="{FormatSvgNumber(centerY)}" r="4" fill="#0f172a" />
    </g>
    <g transform="translate({FormatSvgNumber(legendX)}, {FormatSvgNumber(legendY)})">
      <rect width="220" height="128" rx="18" fill="#f8fafc" stroke="#d8e2ef" />
      <text x="24" y="32" font-family="Segoe UI, Arial, sans-serif" font-size="14" font-weight="700" fill="#0f172a">Legende</text>
      <line x1="26" y1="62" x2="70" y2="62" stroke="{ChartPalette.Player}" stroke-width="4" />
      <text x="78" y="67" font-family="Segoe UI, Arial, sans-serif" font-size="14" fill="#334155">{EscapeXml(Profile?.FullName ?? "Joueuse")}</text>
      <line x1="26" y1="94" x2="70" y2="94" stroke="{ChartPalette.Reference}" stroke-width="4" stroke-dasharray="7 6" />
      <text x="78" y="99" font-family="Segoe UI, Arial, sans-serif" font-size="14" fill="#334155">Mediane du poste</text>
      <text x="24" y="120" font-family="Segoe UI, Arial, sans-serif" font-size="13" fill="#64748b">Echelle radar 0-100 sur la cohorte du poste.</text>
    </g>
  </g>
""";
    }

    private static IReadOnlyList<PlayerSheetRadarAxis> BuildRadarAxes(PositionProfileResponseDto? positionProfile)
    {
        var axes = positionProfile?.SelectedPlayer?.Axes ?? [];
        if (axes.Count == 0)
        {
            return [];
        }

        return axes
            .Where(axis => axis is not null && !string.IsNullOrWhiteSpace(axis.Label))
            .OrderBy(GetRadarAxisSortRank)
            .ThenBy(axis => axis.Key, StringComparer.OrdinalIgnoreCase)
            .Select(axis =>
            {
                return new PlayerSheetRadarAxis(
                    axis.Label,
                    NormalizeRadarValue(axis, axis.Value),
                    NormalizeRadarValue(axis, axis.MedianValue));
            })
            .ToList();
    }

    private static string BuildRadarPolygon(
        IReadOnlyList<PlayerSheetRadarAxis> axes,
        double centerX,
        double centerY,
        double radius,
        Func<PlayerSheetRadarAxis, double> valueSelector,
        string fill,
        string stroke,
        double strokeWidth,
        string? strokeDasharray = null)
    {
        var points = axes
            .Select((axis, index) => GetRadarPoint(index, axes.Count, centerX, centerY, radius, valueSelector(axis)))
            .Select(point => $"{FormatSvgNumber(point.X)},{FormatSvgNumber(point.Y)}");

        var dashAttribute = string.IsNullOrWhiteSpace(strokeDasharray) ? string.Empty : $" stroke-dasharray=\"{EscapeXml(strokeDasharray)}\"";
        return $"""<polygon points="{string.Join(" ", points)}" fill="{fill}" stroke="{stroke}" stroke-width="{strokeWidth.ToString("0.##", CultureInfo.InvariantCulture)}"{dashAttribute} />""";
    }

    private static (double X, double Y) GetRadarPoint(int index, int count, double centerX, double centerY, double radius, double value)
    {
        var angle = (-Math.PI / 2d) + (2d * Math.PI * index / count);
        var normalized = Math.Clamp(value / 100d, 0d, 1d);
        var currentRadius = radius * normalized;
        return (centerX + (Math.Cos(angle) * currentRadius), centerY + (Math.Sin(angle) * currentRadius));
    }

    private static string GetRadarTextAnchor(double pointX, double centerX)
    {
        if (Math.Abs(pointX - centerX) < 12d)
        {
            return "middle";
        }

        return pointX > centerX ? "start" : "end";
    }

    private static int GetRadarAxisSortRank(PositionProfileAxisDto axis)
    {
        var text = $"{axis.Category} {axis.Key} {axis.Label}".ToLowerInvariant();

        if (text.Contains("goalkeeper") || text.Contains("keeper") || text.Contains("save") || text.Contains("arret"))
        {
            return 4;
        }

        if (text.Contains("discip") || text.Contains("sanction") || text.Contains("penalty"))
        {
            return 3;
        }

        if (text.Contains("def") || text.Contains("interception") || text.Contains("block") || text.Contains("neutral"))
        {
            return 2;
        }

        if (text.Contains("pass") || text.Contains("assist") || text.Contains("create") || text.Contains("ball"))
        {
            return 1;
        }

        return 0;
    }

    private static double NormalizeRadarValue(PositionProfileAxisDto axis, double value)
    {
        if (!double.IsFinite(axis.MinValue) || !double.IsFinite(axis.MaxValue) || axis.MaxValue <= axis.MinValue)
        {
            return Math.Clamp(axis.HigherIsBetter ? axis.Percentile : 100d - axis.Percentile, 0d, 100d);
        }

        var normalized = (value - axis.MinValue) * 100d / (axis.MaxValue - axis.MinValue);

        if (!axis.HigherIsBetter)
        {
            normalized = 100d - normalized;
        }

        return Math.Clamp(Math.Round(normalized, 1, MidpointRounding.AwayFromZero), 0d, 100d);
    }

    private static string GetSheetToneColor(string? tone)
    {
        return tone?.ToLowerInvariant() switch
        {
            "positive" => ChartPalette.Positive,
            "good" => ChartPalette.Primary,
            "warning" => ChartPalette.Warning,
            "danger" => ChartPalette.Danger,
            "info" => ChartPalette.Info,
            _ => ChartPalette.Slate
        };
    }

    private static string EscapeXml(string value) => value.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;").Replace("\"", "&quot;").Replace("'", "&apos;");

    private static string Slugify(string value) => string.Join("-", value.Trim().ToLowerInvariant().Split(new[] { ' ', '/', '\\', '.', ',', ';', ':', '_' }, StringSplitOptions.RemoveEmptyEntries));

    private static string FormatSvgNumber(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);

    private sealed record PlayerSheetRow(string Label, string Value, string Note, string Tone);

    private sealed record PlayerSheetRadarAxis(string Label, double PlayerValue, double MedianValue);

    private RenderFragment TableHeader(string column, string label, Action<string> onSort) => builder =>
    {
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "type", "button");
        builder.AddAttribute(2, "class", $"table-sort-button {(PlayerMatchSort.IsActive(column) ? "is-active" : string.Empty)}");
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => onSort(column)));
        builder.AddContent(4, label);

        var glyph = PlayerMatchSort.Glyph(column);
        if (!string.IsNullOrWhiteSpace(glyph))
        {
            builder.OpenElement(5, "span");
            builder.AddAttribute(6, "class", "sort-indicator");
            builder.AddContent(7, glyph);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static string FormatRate(double value) => value.ToString("0.#");
}
