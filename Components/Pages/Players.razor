                BuildPlayerSheetFileName("svg"),
                "image/svg+xml;charset=utf-8",
                BuildPlayerSheetSvg(positionProfile));
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            await BusyUiHelper.ExitAsync(() => IsPlayerSheetExportBusy = false, () => InvokeAsync(StateHasChanged), loadStartedAt);
        }
