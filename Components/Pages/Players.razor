@page "/players"
@inject ReferenceDataService ReferenceDataService
@inject PlayersApiClient PlayersApiClient
@inject MatchesApiClient MatchesApiClient
@inject StatsApiClient StatsApiClient
@inject IApiAuthService AuthService

<PageTitle>Joueuses</PageTitle>

<div class="page-shell">
    @if (!AuthService.Session.IsAuthenticated)
    {
        <AccessRequiredCard Message="Connectez-vous pour ouvrir les fiches joueuses, les zones et les feuilles de match." />
    }
    else
    {
        <section class="page-panel players-directory-panel">
            <div class="panel-head panel-head-wrap">
                <div>
                    <p class="section-kicker">Répertoire</p>
                    <h3>Choisissez une joueuse puis ouvrez sa fiche</h3>
                </div>

                <div class="toolbar">
                    <button type="button" class="primary-button" @onclick="ApplyFiltersAsync" disabled="@IsBusy">Charger</button>
                    <button type="button" class="ghost-button filter-ghost" @onclick="ResetFiltersAsync" disabled="@IsBusy">Réinitialiser</button>
                </div>
            </div>

            <details class="filter-drawer">
                <summary>
                    <div>
                        <strong>Afficher les filtres du répertoire</strong>
                        <span>Recherche, compétition, équipe, poste, saison et journée.</span>
                    </div>
                </summary>

                <div class="filter-drawer-body">
                    <div class="page-filters">
                        <label class="filter-field player-search">
                            <span>Recherche</span>
                            <input @bind="Search" placeholder="Nom ou prenom" />
                        </label>

                        <label class="filter-field">
                            <span>Competition</span>
                            <select @bind="CompetitionId" @bind:after="OnDirectoryScopeChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var competition in AvailableCompetitions)
                                {
                                    <option value="@competition.CompetitionId">@competition.CompetitionName</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Equipe</span>
                            <select @bind="TeamId" @bind:after="OnDirectoryScopeChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var team in AvailableTeams)
                                {
                                    <option value="@team.TeamId">@team.TeamName</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Poste</span>
                            <select @bind="PositionId" @bind:after="OnDirectoryScopeChangedAsync">
                                <option value="">Tous</option>
                                @foreach (var position in AvailablePositions)
                                {
                                    <option value="@position.Id">@position.Name</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Saison</span>
                            <select @bind="Season" @bind:after="OnDirectoryScopeChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var season in SeasonOptions)
                                {
                                    <option value="@season">@season</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Journee</span>
                            <select @bind="Day" @bind:after="OnDirectoryScopeChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var day in DayOptions)
                                {
                                    <option value="@day">@day</option>
                                }
                            </select>
                        </label>
                    </div>
                </div>
            </details>
        </section>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <StateCard Kicker="Erreur"
                       Title="Impossible de charger le répertoire"
                       Message="@ErrorMessage"
                       Tone="error" />
        }
        else if (IsBusy && PlayerDirectory.Count == 0)
        {
            <StateCard Kicker="Chargement"
                       Title="Chargement du répertoire joueuses"
                       Message="Préparation des filtres, de la liste et de la fiche détaillée."
                       Tone="loading" />
        }
        else if (!HasDirectoryCriteria)
        {
            <StateCard Kicker="Filtre requis"
                       Title="Sélectionnez un contexte pour charger les joueuses"
                       Message="Choisissez au moins une compétition, une équipe, un poste ou saisissez une recherche."
                       Tone="empty" />
        }
        else
        {
            <section class="workspace-grid players-workspace-grid">
                <article class="page-panel selection-column players-selection-column">
                    <div class="panel-head">
                        <div>
                            <p class="section-kicker">Liste</p>
                            <h3>@PlayerDirectory.Count joueuses</h3>
                        </div>
                    </div>

                    @if (PlayerDirectory.Count == 0)
                    {
                        <StateCard Kicker="Aucune joueuse"
                                   Title="Le filtre courant ne retourne aucune fiche"
                                   Message="Essayez un contexte plus large ou retirez un filtre trop restrictif."
                                   Tone="empty"
                                   CssClass="empty-card-inline" />
                    }
                    else
                    {
                        <div class="player-mosaic @(UseScrollableDirectory ? "player-mosaic-scrollable" : string.Empty)">
                            @foreach (var player in PlayerDirectory)
                            {
                                <div class="list-item @(SelectedPlayerId == player.PlayerId ? "is-selected" : string.Empty)">
                                    <button type="button" @onclick="() => SelectPlayerAsync(player.PlayerId)">
                                        <div class="key-metric">
                                            <strong>@player.FullName</strong>
                                            <span>@(player.PositionCode ?? player.PositionName ?? "-")</span>
                                        </div>
                                        <p class="tiny-note">@player.TeamName - @(player.Nationality ?? "Nationalite inconnue")</p>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </article>

                <article class="page-panel detail-column players-detail-column">
                    @if (Profile is null || Global is null || Offense is null || Defense is null || Passing is null || Sanctions is null || Goalkeeper is null)
                    {
                        <StateCard Kicker="Aucune fiche"
                                   Title="Choisissez une joueuse pour afficher la synthèse"
                                   Message="La vue détaillée, les zones et les matchs s’ouvrent après sélection."
                                   Tone="empty"
                                   CssClass="empty-card-inline" />
                    }
                    else
                    {
                        var profile = Profile!;
                        var global = Global!;
                        var offense = Offense!;
                        var defense = Defense!;
                        var passing = Passing!;
                        var sanctions = Sanctions!;
                        var goalkeeper = Goalkeeper!;
                        var technical = Technical!;

                        <div class="panel-head panel-head-wrap">
                            <div>
                                <p class="section-kicker">Fiche joueuse</p>
                                <h3>@profile.FullName</h3>
                                <p class="page-subtitle">
                                    @(profile.TeamName ?? "Equipe non renseignee") - @(profile.PositionName ?? "Poste non renseigne")
                                    @if (profile.Number.HasValue)
                                    {
                                        <span>- #@profile.Number.Value</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(profile.Nationality))
                                    {
                                        <span>- @profile.Nationality</span>
                                    }
                                </p>
                            </div>

                            <span class="hero-badge">@(profile.IsGoalkeeper ? "Gardienne" : "Joueuse de champ")</span>
                        </div>

                        <ScopeSummaryBar Kicker="Lecture fiche"
                                         Title="Toutes les vues utilisent le meme cadre d'analyse"
                                         Subtitle="Synthese, graphes, zones et matchs restent cales sur la meme selection."
                                         Items="@SelectedPlayerScopeItems"
                                         Message="Le detail conserve le filtre courant pour eviter les comparaisons faussees." />

                        <AudienceLensSelector Value="@ActiveLens"
                                              ValueChanged="SetActiveLens"
                                              Title="Choisissez la bonne lecture de fiche"
                                              Subtitle="Joueuse pour l'essentiel, Club pour le role dans le collectif, Analyste pour ouvrir toute la profondeur." />

                        <div class="tab-strip">
                            <button type="button" class="tab-button @(ActiveSection == "overview" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("overview")'>Synthese</button>
                            <button type="button" class="tab-button @(ActiveSection == "graphs" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("graphs")'>Graphes</button>
                            <button type="button" class="tab-button @(ActiveSection == "zones" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("zones")'>Zones</button>
                            <button type="button" class="tab-button @(ActiveSection == "matches" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("matches")'>Matchs</button>
                        </div>

                        @if (ActiveSection == "overview")
                        {
                            <div class="stats-grid">
                                <div class="mini-card"><span>Matchs</span><strong>@Profile.MatchesPlayed</strong></div>
                                <div class="mini-card"><span>Buts</span><strong>@Global.TotalGoals</strong></div>
                                <div class="mini-card"><span>Passes</span><strong>@Global.AssistCount</strong></div>
                                <div class="mini-card"><span>Interceptions</span><strong>@Global.InterceptionCount</strong></div>
                                <div class="mini-card"><span>Arrets</span><strong>@Global.SaveCount</strong></div>
                                <div class="mini-card"><span>Pertes</span><strong>@Global.TurnoverCount</strong></div>
                                <div class="mini-card"><span>Tir</span><strong>@FormatRate(Global.ShotSuccessRate)%</strong></div>
                                <div class="mini-card"><span>Penalty</span><strong>@FormatRate(Global.PenaltySuccessRate)%</strong></div>
                            </div>

                            <BarGaugeKpiGrid Items="@PlayerGaugeKpis" />

                            <KpiTileGrid Items="@PlayerKpis" />

                            @if (ShowPlayerRoleCards)
                            {
                                <div class="triple-grid">
                                    <section class="page-panel">
                                        <p class="section-kicker">Attaque</p>
                                        <h4>@Offense.TotalButs buts</h4>
                                        <p>@Offense.TirsRates tirs rates - @Offense.TirContre tirs contres - @Offense.PenaltyRate penalties rates</p>
                                        <p class="tiny-note">@FormatRate(HandballKpiHelper.OverallShotSuccessRate(Offense))% de conversion globale</p>
                                    </section>

                                    <section class="page-panel">
                                        <p class="section-kicker">Defense</p>
                                        <h4>@Defense.Interceptions interceptions</h4>
                                        <p>@Defense.Contres contres - @Defense.Neutralisations neutralisations</p>
                                        <p class="tiny-note">@Defense.PassageForce passages en force provoques</p>
                                    </section>

                                    <section class="page-panel">
                                        <p class="section-kicker">Passe / perte</p>
                                        <h4>@Passing.PasseDecisive passes decisives</h4>
                                        <p>@Passing.TotalPertes pertes - @Passing.MauvaisePasse mauvaises passes</p>
                                        <p class="tiny-note">@Passing.FauteTechnique fautes techniques - @Passing.PassageEnForce passages en force</p>
                                    </section>
                                </div>
                            }

                            @if (ShowPlayerAdvancedCards)
                            {
                                <div class="triple-grid">
                                    <section class="page-panel">
                                        <p class="section-kicker">Sanctions</p>
                                        <h4>@(Sanctions.Exclusions + Sanctions.Avertissements + Sanctions.DeuxMinutes + Sanctions.PenaltyConcede) incidents</h4>
                                        <div class="badge-row">
                                            <div class="mini-card"><span>Exclusions</span><strong>@Sanctions.Exclusions</strong></div>
                                            <div class="mini-card"><span>Avertissements</span><strong>@Sanctions.Avertissements</strong></div>
                                            <div class="mini-card"><span>Deux minutes</span><strong>@Sanctions.DeuxMinutes</strong></div>
                                            <div class="mini-card"><span>Penaltys</span><strong>@Sanctions.PenaltyConcede</strong></div>
                                        </div>
                                    </section>
                                    <section class="page-panel">
                                        <p class="section-kicker">Bloc gardienne</p>
                                        <h4>@(Goalkeeper.Arrets + Goalkeeper.ArretsPenalty) arrets</h4>
                                        <div class="badge-row">
                                            <div class="mini-card"><span>Buts pris</span><strong>@Goalkeeper.ButsPris</strong></div>
                                            <div class="mini-card"><span>Tirs subis</span><strong>@Goalkeeper.TirsSubis</strong></div>
                                            <div class="mini-card"><span>Taux d'arret</span><strong>@FormatRate(Goalkeeper.TauxArret)%</strong></div>
                                            <div class="mini-card"><span>Passes</span><strong>@Goalkeeper.PasseDecisives</strong></div>
                                        </div>
                                    </section>
                                    <section class="page-panel">
                                        <p class="section-kicker">Technique</p>
                                        <h4>@(profile.IsGoalkeeper ? $"{technical.TirsSubis} tirs subis" : $"{technical.ShotAttempts} tirs engages")</h4>
                                        <div class="badge-row">
                                            <div class="mini-card">
                                                <span>@(profile.IsGoalkeeper ? "Stop 7m" : "Conversion globale")</span>
                                                <strong>@FormatRate(profile.IsGoalkeeper ? technical.GoalkeeperPenaltyStopRate : technical.OverallShotSuccessRate)%</strong>
                                            </div>
                                            <div class="mini-card">
                                                <span>@(profile.IsGoalkeeper ? "Buts encaisses" : "Tirs contres")</span>
                                                <strong>@(profile.IsGoalkeeper ? technical.GoalkeeperConcededGoals : offense.TirContre)</strong>
                                            </div>
                                            <div class="mini-card">
                                                <span>@(profile.IsGoalkeeper ? "Pertes techniques" : "Dechet tir")</span>
                                                <strong>@(profile.IsGoalkeeper ? technical.TechnicalLosses : technical.ShotWaste)</strong>
                                            </div>
                                            <div class="mini-card">
                                                <span>Sanctions</span>
                                                <strong>@technical.Sanctions</strong>
                                            </div>
                                        </div>
                                    </section>
                                </div>
                            }
                        }
                        else if (ActiveSection == "graphs")
                        {
                            @if (ShowPlayerProfileCharts)
                            {
                                <div class="dual-grid">
                                    <section class="page-panel">
                                        <p class="section-kicker">Profil technique</p>
                                        <h4>Volumes qui structurent le role</h4>
                                        <ApexChart TItem="MetricPlotPoint" Title="Profil d'impact" Height="310">
                                            <ApexPointSeries TItem="MetricPlotPoint"
                                                             Items="@PlayerActionProfile"
                                                             Name="@Profile.FullName"
                                                             SeriesType="SeriesType.Bar"
                                                             XValue="point => point.Label"
                                                             YValue="point => (decimal?)point.Value" />
                                        </ApexChart>
                                    </section>

                                    <section class="page-panel">
                                        <p class="section-kicker">Rendement</p>
                                        <h4>Pourcentages et ratios clefs</h4>
                                        <ApexChart TItem="MetricPlotPoint" Title="Rendement" Height="310">
                                            <ApexPointSeries TItem="MetricPlotPoint"
                                                             Items="@PlayerRateProfile"
                                                             Name="Niveau"
                                                             SeriesType="SeriesType.Bar"
                                                             XValue="point => point.Label"
                                                             YValue="point => (decimal?)point.Value" />
                                        </ApexChart>
                                    </section>
                                </div>
                            }

                            <div class="dual-grid">
                                <section class="page-panel">
                                    <p class="section-kicker">Tendance recente</p>
                                    <h4>Lecture match apres match</h4>

                                    @if (PlayerTrendSeries.Count == 0)
                                    {
                                        <p class="empty-hint">Aucun historique detaille disponible pour tracer la tendance recente.</p>
                                    }
                                    else
                                    {
                                        <ApexChart @key="SelectedPlayerId" TItem="MatchTrendPoint" Title="Evolution recente" Height="320">
                                            <ApexPointSeries TItem="MatchTrendPoint"
                                                             Items="@PlayerTrendSeries"
                                                             Name="Actions directes"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="point => point.Label"
                                                             YValue="point => (decimal?)point.DirectContributions" />
                                            <ApexPointSeries TItem="MatchTrendPoint"
                                                             Items="@PlayerTrendSeries"
                                                             Name="Impact def."
                                                             SeriesType="SeriesType.Line"
                                                             XValue="point => point.Label"
                                                             YValue="point => (decimal?)point.DefensiveImpact" />
                                            <ApexPointSeries TItem="MatchTrendPoint"
                                                             Items="@PlayerTrendSeries"
                                                             Name="Pertes"
                                                             SeriesType="SeriesType.Line"
                                                             XValue="point => point.Label"
                                                             YValue="point => (decimal?)point.Turnovers" />
                                            @if (Profile.IsGoalkeeper)
                                            {
                                                <ApexPointSeries TItem="MatchTrendPoint"
                                                                 Items="@PlayerTrendSeries"
                                                                 Name="Arrets"
                                                                 SeriesType="SeriesType.Line"
                                                                 XValue="point => point.Label"
                                                                 YValue="point => (decimal?)point.Saves" />
                                            }
                                        </ApexChart>
                                    }
                                </section>

                                <section class="page-panel">
                                    <p class="section-kicker">Nuage de points</p>
                                    <h4>Pertes vs impact global</h4>
                                    <p class="page-subtitle">Chaque point represente un match. Plus il monte, plus l'impact global est fort. Plus il part a droite, plus les pertes augmentent.</p>

                                    @if (!ShowPlayerScatterChart)
                                    {
                                        <p class="empty-hint">Aucune serie assez complete pour tracer le nuage de points.</p>
                                    }
                                    else
                                    {
                                        <ApexChart @key="SelectedPlayerId" TItem="MatchTrendPoint" Title="Pertes vs impact" Height="320" Options="@GetPlayerScatterChartOptions()">
                                            <ApexPointTooltip>
                                                @{
                                                    var datapoint = context.DataPoint as IDataPoint<MatchTrendPoint>;
                                                    var point = datapoint?.Items?.FirstOrDefault();
                                                }

                                                @if (point is not null)
                                                {
                                                    var impact = point.DirectContributions + point.DefensiveImpact;
                                                    var insight = GetScatterInsightLabel(point);

                                                    <div class="chart-tooltip-card player-scatter-tooltip">
                                                        <div class="chart-tooltip-head">
                                                            <div>
                                                                <p class="chart-tooltip-kicker">Lecture analytique</p>
                                                                <h5>@(point.MatchLabel ?? point.Label)</h5>
                                                            </div>

                                                            <span class="chart-tooltip-badge">@insight</span>
                                                        </div>

                                                        <p class="chart-tooltip-meta">
                                                            @if (!string.IsNullOrWhiteSpace(point.SeasonDayLabel))
                                                            {
                                                                <span>@point.SeasonDayLabel</span>
                                                            }

                                                            @if (!string.IsNullOrWhiteSpace(point.TeamLabel))
                                                            {
                                                                <span>@point.TeamLabel</span>
                                                            }

                                                            @if (!string.IsNullOrWhiteSpace(point.OpponentLabel))
                                                            {
                                                                <span>vs @point.OpponentLabel</span>
                                                            }
                                                        </p>

                                                        @if (!string.IsNullOrWhiteSpace(point.CompetitionLabel))
                                                        {
                                                            <p class="chart-tooltip-competition">@point.CompetitionLabel</p>
                                                        }

                                                        <div class="chart-tooltip-grid">
                                                            <div>
                                                                <span>Pertes</span>
                                                                <strong>@FormatRate(point.Turnovers)</strong>
                                                            </div>
                                                            <div>
                                                                <span>Impact</span>
                                                                <strong>@FormatRate(impact)</strong>
                                                            </div>
                                                            <div>
                                                                <span>Directes</span>
                                                                <strong>@FormatRate(point.DirectContributions)</strong>
                                                            </div>
                                                            <div>
                                                                <span>Defense</span>
                                                                <strong>@FormatRate(point.DefensiveImpact)</strong>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </ApexPointTooltip>
                                            <ChildContent>
                                                <ApexPointSeries TItem="MatchTrendPoint"
                                                                 Items="@PlayerScatterSeries"
                                                                 Name="Matchs"
                                                                 SeriesType="SeriesType.Scatter"
                                                                 XValue="point => (decimal?)point.Turnovers"
                                                                 YValue="point => (decimal?)(point.DirectContributions + point.DefensiveImpact)" />
                                            </ChildContent>
                                        </ApexChart>
                                    }
                                </section>
                            </div>
                        }
                        else if (ActiveSection == "zones")
                        {
                            <div class="dual-grid">
                                <section class="page-panel">
                                    <p class="section-kicker">Spatial</p>
                                    <h4>But et declenchements</h4>
                                    <GoalKpi GoalZones="@GoalZones"
                                             TriggerZones="@TriggerZones"
                                             IsGoalkeeper="@Profile.IsGoalkeeper"
                                             ActiveZoneKey="@ActiveZoneKey"
                                             OnZoneSelected="HandleZoneSelectionAsync" />
                                </section>

                                <section class="page-panel">
                                    <div class="panel-head">
                                        <div>
                                            <p class="section-kicker">Zone active</p>
                                            <h4>@(CurrentZone?.Label ?? "Selectionnez une zone")</h4>
                                        </div>
                                        @if (CurrentZone is not null)
                                        {
                                            <span class="hero-badge">@FormatRate(CurrentZone.Rate)%</span>
                                        }
                                    </div>

                                    @if (CurrentZone is not null)
                                    {
                                        <div class="badge-row">
                                            <div class="mini-card"><span>Volume</span><strong>@CurrentZone.Attempts</strong></div>
                                            <div class="mini-card"><span>Succes</span><strong>@CurrentZone.Successes</strong></div>
                                            <div class="mini-card"><span>Echecs</span><strong>@CurrentZone.Failures</strong></div>
                                        </div>

                                        <div class="list-stack">
                                            @foreach (var outcome in CurrentZone.Outcomes)
                                            {
                                                <div class="list-item">
                                                    <div class="key-metric">
                                                        <strong>@outcome.Label</strong>
                                                        <span>@outcome.Count</span>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </section>
                            </div>
                        }
                        else
                        {
                            <section class="page-panel">
                                <div class="panel-head">
                                    <div>
                                        <p class="section-kicker">Feuilles de match</p>
                                        <h4>@PlayerMatches.Count matchs pour la joueuse</h4>
                                    </div>
                                </div>

                                <div class="table-toolbar">
                                    <label class="filter-field table-search">
                                        <span>Filtrer le tableau</span>
                                        <input value="@PlayerMatchSearch" @oninput="OnPlayerMatchSearchChanged" placeholder="Equipe, competition ou saison" />
                                    </label>
                                </div>

                                <div class="table-toolbar">
                                    @TableHeader("match", "Match", SetPlayerMatchSort)
                                    @TableHeader("date", "Saison/J", SetPlayerMatchSort)
                                    @TableHeader("score", "Score", SetPlayerMatchSort)
                                    @TableHeader("goals", "Buts", SetPlayerMatchSort)
                                    @TableHeader("assists", "Passes", SetPlayerMatchSort)
                                    @TableHeader("interceptions", "Interceptions", SetPlayerMatchSort)
                                    @TableHeader("saves", "Arrets", SetPlayerMatchSort)
                                    @TableHeader("turnovers", "Pertes", SetPlayerMatchSort)
                                    @TableHeader("sanctions", "Sanctions", SetPlayerMatchSort)
                                </div>

                                @{
                                    var playerMatchRows = FilteredPlayerMatches.ToArray();
                                }

                                @if (playerMatchRows.Length == 0)
                                {
                                    <StateCard Kicker="Aucune feuille"
                                               Title="Le filtre courant ne retourne aucune rencontre pour cette joueuse"
                                               Message="Essayez un autre contexte ou retirez un filtre trop restrictif."
                                               Tone="empty"
                                               CssClass="empty-card-inline" />
                                }
                                else
                                {
                                    <div class="match-mosaic">
                                        @foreach (var match in playerMatchRows)
                                        {
                                        <MatchCard @key="match.MatchId"
                                                   Title="@($"{match.Team1Name ?? "Equipe A"} vs {match.Team2Name ?? "Equipe B"}")"
                                                   Score="@($"{match.Team1Score ?? 0} - {match.Team2Score ?? 0}")"
                                                   Meta="@(match.CompetitionName ?? "Competition")"
                                                   SecondaryMeta="@MatchFilterCatalog.FormatSeasonDay(match)"
                                                   DetailsHref="@($"/matches?matchId={match.MatchId}")"
                                                   DetailsLabel="Voir plus">
                                                <span class="match-card-chip is-positive">Buts @match.Goals</span>
                                                <span class="match-card-chip is-good">Passes @match.Assists</span>
                                                <span class="match-card-chip">Interceptions @match.Interceptions</span>
                                                <span class="match-card-chip">Arrets @match.Saves</span>
                                                <span class="match-card-chip is-warning">Pertes @match.Turnovers</span>
                                                <span class="match-card-chip is-danger">Sanctions @match.Sanctions</span>
                                            </MatchCard>
                                        }
                                    </div>
                                }
                            </section>
                        }
                    }
                </article>
            </section>
        }
    }
</div>

@code {
    private AnalyticsReferenceData ReferenceData { get; set; } = AnalyticsReferenceData.Empty;
    private IReadOnlyList<MatchListItemDto> CompetitionOptionMatches { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> TeamOptionMatches { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> ScopedMatches { get; set; } = [];
    private IReadOnlyList<PlayerListItemDto> PlayerDirectory { get; set; } = [];
