    private IReadOnlyList<MatchTrendPoint> BuildPlayerTrendSeries()
    {
        if (PlayerMatches.Count == 0)
        {
            return [];
        }

        var ordered = PlayerMatches
            .OrderBy(match => match.Date ?? DateTime.MinValue)
            .ThenBy(match => match.MatchId)
            .ToList();

        if (ordered.Count > 8)
        {
            ordered = ordered.Skip(ordered.Count - 8).ToList();
        }

        return ordered
            .Select(BuildMatchTrendPoint)
            .ToList();
    }

    private IReadOnlyList<MatchTrendPoint> BuildPlayerScatterSeries()
    {
        if (PlayerMatches.Count == 0)
        {
            return [];
        }

        var ordered = PlayerMatches
            .OrderBy(match => match.Date ?? DateTime.MinValue)
            .ThenBy(match => match.MatchId)
            .ToList();

        if (ordered.Count > 12)
        {
            ordered = ordered.Skip(ordered.Count - 12).ToList();
        }

        return ordered
            .Select(BuildMatchTrendPoint)
            .ToList();
    }

    private MatchTrendPoint BuildMatchTrendPoint(PlayerMatchItemDto match)
    {
        var teamLabel = Profile?.TeamName;
        var opponentLabel = GetOpponentTeamLabel(match, teamLabel);

        return new MatchTrendPoint(
            match.Date?.ToString("dd/MM") ?? $"M{match.MatchId}",
            HandballKpiHelper.DirectContributions(match),
            HandballKpiHelper.DefensiveImpact(match),
            match.Turnovers,
            match.Saves,
            BuildMatchLabel(match),
            MatchFilterCatalog.FormatSeasonDay(match),
            teamLabel,
            match.CompetitionName,
            opponentLabel);
    }

    private static string BuildMatchLabel(PlayerMatchItemDto match)
    {
        return $"{match.Team1Name ?? "Equipe A"} vs {match.Team2Name ?? "Equipe B"}";
    }

    private static string? GetOpponentTeamLabel(PlayerMatchItemDto match, string? teamLabel)
    {
        if (string.IsNullOrWhiteSpace(teamLabel))
        {
            return match.Team2Name ?? match.Team1Name;
        }

        if (string.Equals(match.Team1Name?.Trim(), teamLabel.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return match.Team2Name;
        }

        if (string.Equals(match.Team2Name?.Trim(), teamLabel.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return match.Team1Name;
        }

        return match.Team2Name ?? match.Team1Name;
    }

    private IReadOnlyList<PlayerMatchItemDto> GetFilteredPlayerMatches()
    {
        IEnumerable<PlayerMatchItemDto> filtered = PlayerMatches;

        if (!string.IsNullOrWhiteSpace(PlayerMatchSearch))
        {
            var query = PlayerMatchSearch.Trim();
            filtered = filtered.Where(match =>
                TextSearchHelper.Contains(match.Team1Name, query)
                || TextSearchHelper.Contains(match.Team2Name, query)
                || TextSearchHelper.Contains(match.CompetitionName, query)
                || TextSearchHelper.Contains(MatchFilterCatalog.FormatSeasonDay(match), query)
                || TextSearchHelper.Contains(match.Day, query));
        }

        filtered = PlayerMatchSort.Column switch
        {
            "match" => PlayerMatchSort.IsDescending
                ? filtered.OrderByDescending(item => $"{item.Team1Name} vs {item.Team2Name}")
                : filtered.OrderBy(item => $"{item.Team1Name} vs {item.Team2Name}"),
            "score" => PlayerMatchSort.IsDescending
                ? filtered.OrderByDescending(item => (item.Team1Score ?? 0) + (item.Team2Score ?? 0))
                : filtered.OrderBy(item => (item.Team1Score ?? 0) + (item.Team2Score ?? 0)),
            "goals" => PlayerMatchSort.IsDescending
                ? filtered.OrderByDescending(item => item.Goals + item.PenaltyGoals)
                : filtered.OrderBy(item => item.Goals + item.PenaltyGoals),
            "assists" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Assists) : filtered.OrderBy(item => item.Assists),
            "interceptions" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Interceptions) : filtered.OrderBy(item => item.Interceptions),
            "saves" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Saves) : filtered.OrderBy(item => item.Saves),
            "turnovers" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Turnovers) : filtered.OrderBy(item => item.Turnovers),
            "sanctions" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Sanctions) : filtered.OrderBy(item => item.Sanctions),
            _ => PlayerMatchSort.IsDescending
                ? filtered.OrderByDescending(item => item.Date)
                : filtered.OrderBy(item => item.Date)
        };

        return filtered.ToList();
    }

    private void SetPlayerMatchSort(string column)
    {
        PlayerMatchSort = PlayerMatchSort.Toggle(column, column is "match" ? SortDirection.Asc : SortDirection.Desc);
    }

