        new("Repertoire", HasDirectoryCriteria ? $"{PlayerDirectory.Count} joueuses" : "En attente")
    ];
    private IReadOnlyList<ScopeSummaryItem> SelectedPlayerScopeItems => Profile is null || Global is null
        ? []
        :
        [
            new("Equipe", Profile.TeamName ?? "Non renseignee"),
            new("Poste", Profile.PositionName ?? "Non renseigne"),
            new("Matchs", Profile.MatchesPlayed.ToString()),
            new(Profile.IsGoalkeeper ? "Arrets" : "Buts", Profile.IsGoalkeeper
                ? (Goalkeeper is null ? "0" : (Goalkeeper.Arrets + Goalkeeper.ArretsPenalty).ToString())
                : Global.TotalGoals.ToString()),
            new(Profile.IsGoalkeeper ? "Taux d'arret" : "Taux de tir", Profile.IsGoalkeeper
                ? $"{FormatRate(Goalkeeper?.TauxArret ?? 0)}%"
                : $"{FormatRate(Global.ShotSuccessRate)}%"),
            new("Zones actives", GoalZones.Count(zone => zone.Attempts > 0).ToString())
        ];
    private bool ShowPlayerRoleCards => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowPlayerAdvancedCards => ActiveLens == AudienceLens.Analyst;
    private bool ShowPlayerProfileCharts => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private IReadOnlyList<BarGaugeKpiItem> PlayerGaugeKpis => BuildPlayerGaugeKpis();
    private IReadOnlyList<KpiTile> PlayerKpis => BuildPlayerKpis();
    private IReadOnlyList<MetricPlotPoint> PlayerActionProfile => BuildPlayerActionProfile();
    private IReadOnlyList<MetricPlotPoint> PlayerRateProfile => BuildPlayerRateProfile();
    private IReadOnlyList<MatchTrendPoint> PlayerTrendSeries => BuildPlayerTrendSeries();
    private IReadOnlyList<MatchTrendPoint> PlayerScatterSeries => BuildPlayerScatterSeries();
    private IReadOnlyList<PlayerMatchItemDto> FilteredPlayerMatches => GetFilteredPlayerMatches();
    private ZoneStat? CurrentZone => GoalZones.Concat(TriggerZones).FirstOrDefault(zone => zone.Key == ActiveZoneKey)
        ?? GoalZones.FirstOrDefault(zone => zone.Attempts > 0)
        ?? TriggerZones.FirstOrDefault(zone => zone.Attempts > 0)
        ?? GoalZones.FirstOrDefault()
        ?? TriggerZones.FirstOrDefault();
    private bool HasDirectoryCriteria => CompetitionId.HasValue
        || TeamId.HasValue
        || PositionId.HasValue
        || !string.IsNullOrWhiteSpace(Season)
        || !string.IsNullOrWhiteSpace(Day)
        || !string.IsNullOrWhiteSpace(Search);
    private bool IsCompetitionOnlyDirectoryFilter => CompetitionId.HasValue
        && !TeamId.HasValue
        && !PositionId.HasValue
        && string.IsNullOrWhiteSpace(Season)
        && string.IsNullOrWhiteSpace(Day)
        && string.IsNullOrWhiteSpace(Search);
    private bool UseScrollableDirectory => IsCompetitionOnlyDirectoryFilter && PlayerDirectory.Count > 10;
    private bool ShowPlayerScatterChart => PlayerScatterSeries.Count > 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(refreshReferenceData: true);
    }

    private Task OnDirectoryScopeChangedAsync()
    {
        return ApplyFiltersAsync();
    }

    private Task SetActiveLens(string lens)
    {
        ActiveLens = lens;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ApplyFiltersAsync()
    {
        SelectedPlayerId = null;
        await LoadAsync(refreshReferenceData: false);
    }

    private async Task ResetFiltersAsync()
    {
        CompetitionId = null;
        TeamId = null;
        PositionId = null;
        Season = null;
        Day = null;
        Search = string.Empty;
        PlayerMatchSearch = string.Empty;
        PlayerMatchSort = new TableSortState("date", SortDirection.Desc);
        SelectedPlayerId = null;
        ActiveSection = "overview";
        await LoadAsync(refreshReferenceData: true);
    }

    private async Task SelectPlayerAsync(int playerId)
    {
        SelectedPlayerId = playerId;
        await LoadPlayerDetailsAsync();
    }

    private Task SetActiveSection(string section)
    {
        ActiveSection = section;
        return InvokeAsync(StateHasChanged);
    }

    private async Task HandleZoneSelectionAsync(string zoneKey)
    {
        ActiveZoneKey = zoneKey;
        await InvokeAsync(StateHasChanged);
    }

    private Task OnPlayerMatchSearchChanged(ChangeEventArgs args)
    {
        PlayerMatchSearch = args.Value?.ToString() ?? string.Empty;
        return InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync(bool refreshReferenceData)
    {
        if (!AuthService.Session.IsAuthenticated)
        {
            ReferenceData = AnalyticsReferenceData.Empty;
            PlayerDirectory = [];
            await LoadPlayerDetailsAsync();
            return;
        }

        try
        {
            IsBusy = true;
            ErrorMessage = null;

            if (refreshReferenceData || ReferenceData == AnalyticsReferenceData.Empty)
            {
                ReferenceData = await ReferenceDataService.GetReferenceDataAsync(refreshReferenceData);
            }

            if (!HasDirectoryCriteria)
            {
                ScopedMatches = [];
                PlayerDirectory = [];
                await LoadPlayerDetailsAsync();
                return;
            }

            await LoadFilterScopesAsync();

            var filtersAdjusted = false;

            if (CompetitionId.HasValue && AvailableCompetitions.All(item => item.CompetitionId != CompetitionId.Value))
            {
                CompetitionId = null;
                filtersAdjusted = true;
            }

            if (TeamId.HasValue && AvailableTeams.All(item => item.TeamId != TeamId.Value))
            {
                TeamId = null;
                filtersAdjusted = true;
            }

            if (filtersAdjusted)
            {
                await LoadFilterScopesAsync();
            }

            if (!string.IsNullOrWhiteSpace(Season) && !SeasonOptions.Contains(Season, StringComparer.OrdinalIgnoreCase))
            {
                Season = null;
            }

            if (!string.IsNullOrWhiteSpace(Day) && !DayOptions.Contains(Day, StringComparer.OrdinalIgnoreCase))
            {
                Day = null;
            }

            PlayerDirectory = await PlayersApiClient.GetPlayersAsync(
                teamId: TeamId,
                positionId: PositionId,
                competitionId: CompetitionId,
                year: Year,
                season: Season,
                day: Day,
                search: Search,
                pageSize: IsCompetitionOnlyDirectoryFilter ? 1000 : 250);

            SelectedPlayerId ??= PlayerDirectory.FirstOrDefault()?.PlayerId;

            if (SelectedPlayerId.HasValue && PlayerDirectory.All(player => player.PlayerId != SelectedPlayerId.Value))
            {
                SelectedPlayerId = PlayerDirectory.FirstOrDefault()?.PlayerId;
            }

            await LoadPlayerDetailsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task LoadPlayerDetailsAsync()
    {
        if (!SelectedPlayerId.HasValue)
        {
            Profile = null;
            Global = null;
            Offense = null;
            Defense = null;
            Passing = null;
            Sanctions = null;
            Goalkeeper = null;
            Technical = null;
            Spatial = null;
            PlayerMatches = [];
            return;
        }

        try
        {
            IsBusy = true;
            ErrorMessage = null;

            var options = BuildOptions();

            var profileTask = PlayersApiClient.GetPlayerProfileAsync(SelectedPlayerId.Value, options);
            var globalTask = StatsApiClient.GetPlayerGlobalAsync(SelectedPlayerId.Value, options);
            var offenseTask = StatsApiClient.GetPlayerOffenseAsync(SelectedPlayerId.Value, options);
            var defenseTask = StatsApiClient.GetPlayerDefenseAsync(SelectedPlayerId.Value, options);
            var passingTask = StatsApiClient.GetPlayerPassingAsync(SelectedPlayerId.Value, options);
            var sanctionsTask = StatsApiClient.GetPlayerSanctionsAsync(SelectedPlayerId.Value, options);
            var goalkeeperTask = StatsApiClient.GetPlayerGoalkeeperAsync(SelectedPlayerId.Value, options);
            var technicalTask = StatsApiClient.GetPlayerTechnicalAsync(SelectedPlayerId.Value, options);
            var spatialTask = StatsApiClient.GetPlayerSpatialAsync(SelectedPlayerId.Value, options);
            var matchesTask = PlayersApiClient.GetPlayerMatchesAsync(SelectedPlayerId.Value, options);

            await Task.WhenAll(profileTask, globalTask, offenseTask, defenseTask, passingTask, sanctionsTask, goalkeeperTask, technicalTask, spatialTask, matchesTask);

            Profile = profileTask.Result;
            Global = globalTask.Result;
            Offense = offenseTask.Result;
            Defense = defenseTask.Result;
            Passing = passingTask.Result;
            Sanctions = sanctionsTask.Result;
            Goalkeeper = goalkeeperTask.Result;
            Technical = technicalTask.Result;
            Spatial = spatialTask.Result;
            PlayerMatches = matchesTask.Result;
            ActiveZoneKey = GoalZones.FirstOrDefault(zone => zone.Attempts > 0)?.Key
                ?? TriggerZones.FirstOrDefault(zone => zone.Attempts > 0)?.Key
                ?? GoalZones.FirstOrDefault()?.Key
                ?? TriggerZones.FirstOrDefault()?.Key;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private StatsQueryOptionsDto BuildOptions()
    {
        return new StatsQueryOptionsDto
        {
            CompetitionId = CompetitionId,
            TeamId = TeamId,
            PositionId = PositionId,
            Year = Year,
            Season = Season,
            Day = Day
        };
    }

    private async Task LoadFilterScopesAsync()
    {
        var competitionScopeTask = MatchesApiClient.GetMatchesAsync(
            teamId: TeamId,
            year: Year,
            page: 1,
            pageSize: 500);
        var teamScopeTask = MatchesApiClient.GetMatchesAsync(
            competitionId: CompetitionId,
            year: Year,
            page: 1,
            pageSize: 500);
        var contextScopeTask = MatchesApiClient.GetMatchesAsync(
            competitionId: CompetitionId,
            teamId: TeamId,
            year: Year,
            page: 1,
            pageSize: 500);

        await Task.WhenAll(competitionScopeTask, teamScopeTask, contextScopeTask);

        CompetitionOptionMatches = competitionScopeTask.Result;
        TeamOptionMatches = teamScopeTask.Result;
        ScopedMatches = contextScopeTask.Result;
    }

    private static ZoneStat MapZone(ZoneStatDto zone)
    {
        return new ZoneStat(
            zone.ZoneCode,
            zone.ZoneCode,
            zone.SuccessRate,
            zone.Attempts,
            zone.SuccessCount,
            zone.Outcomes.Select(outcome => new OutcomeCount(outcome.EventName, outcome.Count)).ToList());
    }

    private static ZoneStat MapTrigger(TriggerZoneStatDto zone)
    {
        return new ZoneStat(
            SpatialZoneVisuals.ToVisualTriggerKey(zone.TriggerCode),
            SpatialZoneVisuals.ToVisualTriggerKey(zone.TriggerCode),
            zone.SuccessRate,
            zone.Attempts,
            zone.SuccessCount,
            zone.Outcomes.Select(outcome => new OutcomeCount(outcome.EventName, outcome.Count)).ToList());
    }

    private IReadOnlyList<KpiTile> BuildPlayerKpis()
    {
        if (Profile is null || Global is null || Offense is null || Defense is null || Passing is null || Sanctions is null || Goalkeeper is null || Technical is null)
        {
            return [];
        }

        var matches = Math.Max(Global.MatchesPlayed, 0);
        var directContributions = Global.TotalGoals + Global.AssistCount;
        var shotAttempts = Technical.ShotAttempts;
        var shotWaste = Technical.ShotWaste;
        var defensiveImpact = Profile.IsGoalkeeper
            ? Technical.GoalkeeperStops
            : Technical.DefensiveImpact;
        var sanctions = Technical.Sanctions;
        var technicalLosses = Technical.TechnicalLosses;
        var goalkeeperConcededGoals = Technical.GoalkeeperConcededGoals;
        var penaltyStopRate = Technical.GoalkeeperPenaltyStopRate;
        var overallShotRate = Technical.OverallShotSuccessRate;

        return
        [
            new KpiTile(
                "Actions directes / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(directContributions, matches)),
                "Buts et passes decisives rapportes aux matchs.",
                HandballKpiHelper.DirectActionsTone(HandballKpiHelper.PerMatch(directContributions, matches), Profile.IsGoalkeeper),
                HandballKpiHelper.FormatPerMatchContext(directContributions, matches, "actions")),
            new KpiTile(
                "Ballons valorises",
                HandballKpiHelper.FormatPercent(HandballKpiHelper.SuccessVsWasteShare(Passing.PasseDecisive, Passing.TotalPertes)),
                "Part des actions de balle qui se terminent positivement.",
                HandballKpiHelper.BallRetentionTone(HandballKpiHelper.SuccessVsWasteShare(Passing.PasseDecisive, Passing.TotalPertes), Profile.IsGoalkeeper),
                $"{Passing.PasseDecisive} passes pour {Passing.TotalPertes} pertes"),
            new KpiTile(
                Profile.IsGoalkeeper ? "Arrets / match" : "Impact def. / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(defensiveImpact, matches)),
                Profile.IsGoalkeeper
                    ? "Arrets classiques et penalties arretes."
                    : "Interceptions, contres, neutralisations et passages forces.",
                HandballKpiHelper.DefensiveImpactTone(HandballKpiHelper.PerMatch(defensiveImpact, matches), Profile.IsGoalkeeper),
                HandballKpiHelper.FormatPerMatchContext(defensiveImpact, matches, Profile.IsGoalkeeper ? "arrets" : "actions def.")),
            new KpiTile(
                Profile.IsGoalkeeper ? "Taux d'arret" : "Taux de tir ouvert",
                HandballKpiHelper.FormatPercent(Profile.IsGoalkeeper ? Goalkeeper.TauxArret : Offense.TauxReussiteTir),
                Profile.IsGoalkeeper ? "Lecture gardienne sur les tirs subis." : "Capacite de finition sur les tirs ouverts, hors 7m.",
                Profile.IsGoalkeeper
                    ? HandballKpiHelper.GoalkeeperSaveRateTone(Goalkeeper.TauxArret)
                    : HandballKpiHelper.FieldSuccessRateTone(Offense.TauxReussiteTir),
                Profile.IsGoalkeeper
                    ? HandballKpiHelper.FormatBase(
                        HandballKpiHelper.GoalkeeperStops(Goalkeeper),
                        Math.Max(Goalkeeper.TirsSubis, 1),
                        "tirs arretes")
                    : HandballKpiHelper.FormatBase(
                        Offense.Buts,
                        Math.Max(Offense.Buts + Offense.TirsRates, 1),
                        "tirs ouverts")),
            new KpiTile(
                Profile.IsGoalkeeper ? "Stop 7m %" : "Conversion globale",
                HandballKpiHelper.FormatPercent(Profile.IsGoalkeeper ? penaltyStopRate : overallShotRate),
                Profile.IsGoalkeeper ? "Arrets sur penalties." : "Buts rapportes a tous les tirs engages.",
                Profile.IsGoalkeeper
                    ? HandballKpiHelper.GoalkeeperPenaltyStopRateTone(penaltyStopRate)
                    : HandballKpiHelper.FieldSuccessRateTone(overallShotRate),
                Profile.IsGoalkeeper
                    ? HandballKpiHelper.FormatBase(
                        Goalkeeper.ArretsPenalty,
                        Math.Max(Goalkeeper.ArretsPenalty + Goalkeeper.ButsPenalty, 1),
                        "penalties arretes")
                    : HandballKpiHelper.FormatBase(
                        Global.TotalGoals,
                        Math.Max(shotAttempts, 1),
                        "tirs engages")),
            new KpiTile(
                Profile.IsGoalkeeper ? "Tirs subis / match" : "Tirs engages / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(
                    Profile.IsGoalkeeper ? Goalkeeper.TirsSubis : shotAttempts,
                    matches)),
                Profile.IsGoalkeeper ? "Volume de tirs affrontes rapporte au temps de jeu." : "Buts, tirs rates, tirs contres et penalties engages.",
                "warning",
                HandballKpiHelper.FormatPerMatchContext(
                    Profile.IsGoalkeeper ? Goalkeeper.TirsSubis : shotAttempts,
                    matches,
                    Profile.IsGoalkeeper ? "tirs subis" : "tirs engages")),
            new KpiTile(
                Profile.IsGoalkeeper ? "Buts pris / match" : "Dechet tir / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(
                    Profile.IsGoalkeeper ? goalkeeperConcededGoals : shotWaste,
                    matches)),
                Profile.IsGoalkeeper ? "Volume de buts encaisses rapporte au temps de jeu." : "Tirs rates, tirs contres et penalties manques.",
                Profile.IsGoalkeeper
                    ? HandballKpiHelper.GoalkeeperConcededGoalsTone(HandballKpiHelper.PerMatch(goalkeeperConcededGoals, matches))
                    : HandballKpiHelper.FieldWasteTone(HandballKpiHelper.PerMatch(shotWaste, matches)),
                HandballKpiHelper.FormatPerMatchContext(
                    Profile.IsGoalkeeper ? goalkeeperConcededGoals : shotWaste,
                    matches,
                    Profile.IsGoalkeeper ? "buts encaisses" : "dechets tir")),
            new KpiTile(
                "Pertes techniques / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(technicalLosses, matches)),
                "Mauvaises passes, pertes de balle, fautes techniques et passages en force.",
                Profile.IsGoalkeeper
                    ? HandballKpiHelper.KeeperWasteTone(HandballKpiHelper.PerMatch(technicalLosses, matches))
                    : HandballKpiHelper.FieldWasteTone(HandballKpiHelper.PerMatch(technicalLosses, matches)),
                HandballKpiHelper.FormatPerMatchContext(technicalLosses, matches, "pertes techniques")),
            new KpiTile(
                "Sanctions / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(sanctions, matches)),
                "Charge disciplinaire individuelle.",
                HandballKpiHelper.SanctionsTone(HandballKpiHelper.PerMatch(sanctions, matches), Profile.IsGoalkeeper),
                HandballKpiHelper.FormatPerMatchContext(sanctions, matches, "sanctions"))
        ];
    }

    private IReadOnlyList<BarGaugeKpiItem> BuildPlayerGaugeKpis()
    {
        if (Profile is null || Global is null || Offense is null || Defense is null || Passing is null || Sanctions is null || Goalkeeper is null || Technical is null)
        {
            return [];
        }

        var isGoalkeeper = Profile.IsGoalkeeper;
        var primaryRate = isGoalkeeper
            ? Technical.GoalkeeperSaveRate
            : Technical.OverallShotSuccessRate;
        var secondaryRate = isGoalkeeper
            ? Technical.GoalkeeperPenaltyStopRate
            : Technical.OpenShotSuccessRate;
        var technicalScore = HandballKpiHelper.TechnicalBalanceScore(Global, Offense, Defense, Passing, Sanctions, Goalkeeper);
        var ballonsValorises = HandballKpiHelper.SuccessVsWasteShare(Passing.PasseDecisive, Passing.TotalPertes);

        return
        [
            new BarGaugeKpiItem(
                isGoalkeeper ? "Taux d'arret" : "Conversion globale",
                FormatRate(primaryRate) + "%",
                primaryRate,
                isGoalkeeper
                    ? "Lecture gardienne sur tous les tirs subis."
                    : "Buts rapportes a tous les tirs engages.",
                isGoalkeeper
                    ? HandballKpiHelper.GoalkeeperSaveRateTone(primaryRate)
                    : HandballKpiHelper.FieldSuccessRateTone(primaryRate),
                isGoalkeeper
                    ? HandballKpiHelper.FormatBase(Goalkeeper.Arrets + Goalkeeper.ArretsPenalty, Math.Max(Goalkeeper.TirsSubis, 1), "arrets")
                    : HandballKpiHelper.FormatBase(Offense.TotalButs, Math.Max(Technical.ShotAttempts, 1), "tirs engages")),
            new BarGaugeKpiItem(
                "Indice technique",
                FormatRate(technicalScore) + "%",
                technicalScore,
                "Balance entre productions utiles et déchets techniques.",
                HandballKpiHelper.TechnicalBalanceTone(technicalScore, isGoalkeeper),
                HandballKpiHelper.FormatBase(
                    DirectActionsCount(),
                    Math.Max(DirectActionsCount() + TechnicalWasteCount(), 1),
                    "actions")),
            new BarGaugeKpiItem(
                "Ballons valorises",
                FormatRate(ballonsValorises) + "%",
                ballonsValorises,
                "Part des actions de balle qui se terminent positivement.",
                HandballKpiHelper.BallRetentionTone(ballonsValorises, isGoalkeeper),
                $"{Passing.PasseDecisive} passes pour {Passing.TotalPertes} pertes"),
            new BarGaugeKpiItem(
                isGoalkeeper ? "Stop 7m" : "Taux de tir ouvert",
                FormatRate(secondaryRate) + "%",
                secondaryRate,
                isGoalkeeper
                    ? "Efficacite gardienne sur les penalties."
                    : "Finition sur les tirs ouverts hors penalties.",
                isGoalkeeper
                    ? HandballKpiHelper.GoalkeeperPenaltyStopRateTone(secondaryRate)
                    : HandballKpiHelper.FieldSuccessRateTone(secondaryRate),
                isGoalkeeper
                    ? HandballKpiHelper.FormatBase(Goalkeeper.ArretsPenalty, Math.Max(Goalkeeper.ArretsPenalty + Goalkeeper.ButsPenalty, 1), "penalties arretes")
                    : HandballKpiHelper.FormatBase(Offense.Buts, Math.Max(Offense.Buts + Offense.TirsRates, 1), "tirs ouverts"))
        ];
    }

    private int DirectActionsCount()
    {
        return (Global?.TotalGoals ?? 0) + (Global?.AssistCount ?? 0) + (Defense?.Interceptions ?? 0) + (Defense?.Contres ?? 0) + (Defense?.Neutralisations ?? 0) + (Defense?.PassageForce ?? 0) + (Goalkeeper?.Arrets ?? 0) + (Goalkeeper?.ArretsPenalty ?? 0);
    }

    private int TechnicalWasteCount()
    {
        return (Offense?.TirsRates ?? 0) + (Offense?.PenaltyRate ?? 0) + (Offense?.TirContre ?? 0) + (Passing?.MauvaisePasse ?? 0) + (Passing?.PerteDeBalle ?? 0) + (Passing?.FauteTechnique ?? 0) + (Passing?.PassageEnForce ?? 0) + (Sanctions?.Exclusions ?? 0) + (Sanctions?.Avertissements ?? 0) + (Sanctions?.DeuxMinutes ?? 0) + (Sanctions?.PenaltyConcede ?? 0) + (Goalkeeper?.ButsPris ?? 0) + (Goalkeeper?.ButsPenalty ?? 0);
    }

    private IReadOnlyList<MetricPlotPoint> BuildPlayerActionProfile()
    {
        if (Global is null || Offense is null || Defense is null || Passing is null || Goalkeeper is null || Technical is null)
        {
            return [];
        }

        if (Profile is not null && Profile.IsGoalkeeper)
        {
            return
            [
                new MetricPlotPoint("Arrets", Technical.GoalkeeperStops),
                new MetricPlotPoint("Tirs subis", Technical.TirsSubis),
                new MetricPlotPoint("Buts encaisses", Technical.GoalkeeperConcededGoals),
                new MetricPlotPoint("Passes", Passing.PasseDecisive),
                new MetricPlotPoint("Pertes", Technical.TechnicalLosses),
                new MetricPlotPoint("Sanctions", Technical.Sanctions)
            ];
        }

        return
        [
            new MetricPlotPoint("Buts", Global.TotalGoals),
            new MetricPlotPoint("Passes", Global.AssistCount),
            new MetricPlotPoint("Impact def.", Technical.DefensiveImpact),
            new MetricPlotPoint("Tirs engages", Technical.ShotAttempts),
            new MetricPlotPoint("7m engages", Technical.PenaltyAttempts),
            new MetricPlotPoint("Dechet tir", Technical.ShotWaste),
            new MetricPlotPoint("Pertes", Technical.TechnicalLosses),
            new MetricPlotPoint("Sanctions", Technical.Sanctions)
        ];
    }

    private IReadOnlyList<MetricPlotPoint> BuildPlayerRateProfile()
    {
        if (Profile is null || Global is null || Offense is null || Passing is null || Sanctions is null || Goalkeeper is null || Technical is null)
        {
            return [];
        }

        if (Profile.IsGoalkeeper)
        {
            return
            [
                new MetricPlotPoint("Taux d'arret", Technical.GoalkeeperSaveRate),
                new MetricPlotPoint("Stop 7m", Technical.GoalkeeperPenaltyStopRate),
                new MetricPlotPoint("Ballons +", HandballKpiHelper.SuccessVsWasteShare(Passing.PasseDecisive, Passing.TotalPertes)),
                new MetricPlotPoint("Directes/m", HandballKpiHelper.PerMatch(HandballKpiHelper.DirectContributions(Global), Math.Max(Profile.MatchesPlayed, 1))),
                new MetricPlotPoint("Sanctions/m", HandballKpiHelper.PerMatch(Technical.Sanctions, Math.Max(Profile.MatchesPlayed, 1)))
            ];
        }

        return
        [
            new MetricPlotPoint("Tir ouvert", Technical.OpenShotSuccessRate),
            new MetricPlotPoint("Conversion globale", Technical.OverallShotSuccessRate),
            new MetricPlotPoint("Penalty", Technical.PenaltySuccessRate),
            new MetricPlotPoint("Ballons +", HandballKpiHelper.SuccessVsWasteShare(Passing.PasseDecisive, Passing.TotalPertes)),
            new MetricPlotPoint("Directes/m", HandballKpiHelper.PerMatch(HandballKpiHelper.DirectContributions(Global), Math.Max(Profile.MatchesPlayed, 1))),
            new MetricPlotPoint("Sanctions/m", HandballKpiHelper.PerMatch(Technical.Sanctions, Math.Max(Profile.MatchesPlayed, 1)))
        ];
    }

    private IReadOnlyList<MatchTrendPoint> BuildPlayerTrendSeries()
    {
        if (PlayerMatches.Count == 0)
        {
            return [];
        }

        var ordered = PlayerMatches
            .OrderBy(match => match.Date ?? DateTime.MinValue)
            .ThenBy(match => match.MatchId)
            .ToList();

        if (ordered.Count > 8)
        {
            ordered = ordered.Skip(ordered.Count - 8).ToList();
        }

        return ordered
            .Select(BuildMatchTrendPoint)
            .ToList();
    }

    private IReadOnlyList<MatchTrendPoint> BuildPlayerScatterSeries()
    {
        if (PlayerMatches.Count == 0)
        {
            return [];
        }

        var ordered = PlayerMatches
            .OrderBy(match => match.Date ?? DateTime.MinValue)
            .ThenBy(match => match.MatchId)
            .ToList();

        if (ordered.Count > 12)
        {
            ordered = ordered.Skip(ordered.Count - 12).ToList();
        }

        return ordered
            .Select(BuildMatchTrendPoint)
            .ToList();
    }

    private MatchTrendPoint BuildMatchTrendPoint(PlayerMatchItemDto match)
    {
        var teamLabel = Profile?.TeamName;
        var opponentLabel = GetOpponentTeamLabel(match, teamLabel);

        return new MatchTrendPoint(
            match.Date?.ToString("dd/MM") ?? $"M{match.MatchId}",
            HandballKpiHelper.DirectContributions(match),
            HandballKpiHelper.DefensiveImpact(match),
            match.Turnovers,
            match.Saves,
            BuildMatchLabel(match),
            MatchFilterCatalog.FormatSeasonDay(match),
            teamLabel,
            match.CompetitionName,
            opponentLabel);
    }

    private static string BuildMatchLabel(PlayerMatchItemDto match)
    {
        return $"{match.Team1Name ?? "Equipe A"} vs {match.Team2Name ?? "Equipe B"}";
    }

    private static string? GetOpponentTeamLabel(PlayerMatchItemDto match, string? teamLabel)
    {
        if (string.IsNullOrWhiteSpace(teamLabel))
        {
            return match.Team2Name ?? match.Team1Name;
        }

        if (string.Equals(match.Team1Name?.Trim(), teamLabel.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return match.Team2Name;
        }

        if (string.Equals(match.Team2Name?.Trim(), teamLabel.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return match.Team1Name;
        }

        return match.Team2Name ?? match.Team1Name;
    }

    private IReadOnlyList<PlayerMatchItemDto> GetFilteredPlayerMatches()
    {
        IEnumerable<PlayerMatchItemDto> filtered = PlayerMatches;

        if (!string.IsNullOrWhiteSpace(PlayerMatchSearch))
        {
            var query = PlayerMatchSearch.Trim();
            filtered = filtered.Where(match =>
                TextSearchHelper.Contains(match.Team1Name, query)
                || TextSearchHelper.Contains(match.Team2Name, query)
                || TextSearchHelper.Contains(match.CompetitionName, query)
                || TextSearchHelper.Contains(MatchFilterCatalog.FormatSeasonDay(match), query)
                || TextSearchHelper.Contains(match.Day, query));
        }

        filtered = PlayerMatchSort.Column switch
        {
            "match" => PlayerMatchSort.IsDescending
                ? filtered.OrderByDescending(item => $"{item.Team1Name} vs {item.Team2Name}")
                : filtered.OrderBy(item => $"{item.Team1Name} vs {item.Team2Name}"),
            "score" => PlayerMatchSort.IsDescending
                ? filtered.OrderByDescending(item => (item.Team1Score ?? 0) + (item.Team2Score ?? 0))
                : filtered.OrderBy(item => (item.Team1Score ?? 0) + (item.Team2Score ?? 0)),
            "goals" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Goals + item.PenaltyGoals) : filtered.OrderBy(item => item.Goals + item.PenaltyGoals),
            "assists" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Assists) : filtered.OrderBy(item => item.Assists),
            "interceptions" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Interceptions) : filtered.OrderBy(item => item.Interceptions),
            "saves" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Saves) : filtered.OrderBy(item => item.Saves),
            "turnovers" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Turnovers) : filtered.OrderBy(item => item.Turnovers),
            "sanctions" => PlayerMatchSort.IsDescending ? filtered.OrderByDescending(item => item.Sanctions) : filtered.OrderBy(item => item.Sanctions),
            _ => PlayerMatchSort.IsDescending
                ? filtered.OrderByDescending(item => item.Date)
                : filtered.OrderBy(item => item.Date)
        };

        return filtered.ToList();
    }

    private void SetPlayerMatchSort(string column)
    {
        PlayerMatchSort = PlayerMatchSort.Toggle(column, column is "match" ? SortDirection.Asc : SortDirection.Desc);
    }

