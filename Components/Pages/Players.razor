    private string BuildPlayerSheetTableMarkup(IReadOnlyList<PlayerSheetRow> rows, double x, double y, double width, double height)
    {
        var headerHeight = 36d;
        var rowHeight = 58d;
        var tableX = x + 24d;
        var tableY = y + 74d;
        var tableWidth = width - 48d;
        var labelWidth = 168d;
        var valueWidth = 120d;
        var noteX = tableX + labelWidth + valueWidth + 18d;
        var noteWidth = tableWidth - labelWidth - valueWidth - 34d;

        var bodyRows = string.Join("\n", rows.Select((row, index) =>
        {
            var rowY = tableY + headerHeight + (index * rowHeight);
            var background = index % 2 == 0 ? "#f8fafc" : "#ffffff";
            var accent = GetSheetToneColor(row.Tone);

            return $"""
      <rect x="{FormatSvgNumber(tableX)}" y="{FormatSvgNumber(rowY)}" width="{FormatSvgNumber(tableWidth)}" height="{FormatSvgNumber(rowHeight - 4d)}" rx="14" fill="{background}" stroke="#d8e2ef" />
