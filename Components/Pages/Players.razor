      {SvgExportHelpers.BuildWrappedText(noteX, rowY + 21d, noteWidth, row.Note, "#475569", 12, 400, "start", 1.16, 2)}
""";
        }));

        return $"""
  <rect x="{FormatSvgNumber(x)}" y="{FormatSvgNumber(y)}" width="{FormatSvgNumber(width)}" height="{FormatSvgNumber(height)}" rx="24" fill="#ffffff" stroke="#d8e2ef" />
  <text x="{FormatSvgNumber(x + 24d)}" y="{FormatSvgNumber(y + 36d)}" font-family="Segoe UI, Arial, sans-serif" font-size="15" font-weight="700" fill="{ChartPalette.Player}">TABLEAU DE SYNTHESE</text>
