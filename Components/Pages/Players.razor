  <text x="{FormatSvgNumber(tableX + labelWidth + 18d)}" y="{FormatSvgNumber(tableY + 23d)}" font-family="Segoe UI, Arial, sans-serif" font-size="12" font-weight="700" fill="#64748b">VALEUR</text>
