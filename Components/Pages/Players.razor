    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(refreshReferenceData: true);
    }

    private Task OnDirectoryScopeChangedAsync()
    {
        return ApplyFiltersAsync();
    }

    private async Task OnSearchChangedAsync(ChangeEventArgs args)
    {
        Search = args.Value?.ToString() ?? string.Empty;
        await DebounceSearchAsync();
    }

    private async Task DebounceSearchAsync()
    {
        var cts = new CancellationTokenSource();
        var previous = Interlocked.Exchange(ref _searchDebounceCts, cts);
        previous?.Cancel();
        previous?.Dispose();

        try
        {
            await Task.Delay(SearchDebounceDelay, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (cts.IsCancellationRequested)
        {
            return;
        }

        await ApplyFiltersAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        SelectedPlayerId = null;
        await LoadAsync(refreshReferenceData: false);
    }

    private void ToggleDirectoryDrawer()
    {
        IsDirectoryDrawerOpen = !IsDirectoryDrawerOpen;
    }

    private async Task ResetFiltersAsync()
    {
        CompetitionId = null;
        TeamId = null;
        PositionId = null;
        Season = null;
        Day = null;
        Search = string.Empty;
        PlayerMatchSearch = string.Empty;
        PlayerMatchSort = new TableSortState("date", SortDirection.Desc);
        SelectedPlayerId = null;
        ActiveSection = "overview";
        IsDirectoryDrawerOpen = true;
        IsPlayerListOpen = true;
        await LoadAsync(refreshReferenceData: true);
