@page "/dashboard"
@inherits HomeBase

<PageTitle>Today</PageTitle>

@if (IsBusy && Snapshot is null)
{
    <StateCard Kicker="Chargement"
               Title="Mise à jour du tableau de bord"
               Message="Préparation des classements, de la joueuse suivie et des cartes de tir."
               Tone="loading" />
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <StateCard Kicker="Erreur"
               Title="Impossible de charger le tableau de bord"
               Message="@ErrorMessage"
               Tone="error"
               Actions="@RetryActions" />
}
else if (Snapshot is not null)
{
    <div class="today-workspace" data-workspace="today">
        @if (IsBusy)
        {
            <PageLoader Kicker="Chargement"
                        Title="Actualisation du tableau de bord"
                        Message="Les filtres, classements et KPI se recalculent." />
        }

        <section class="today-brief">
            <div class="today-brief__copy">
                <span>Morning brief / @Snapshot.DataOrigin</span>
                <h2 data-page-title>Le scope en un regard.</h2>
                <p>Les signaux collectifs, le classement actif et les dernieres activites sont synchronises sur le meme contexte.</p>

                <div class="today-brief__meta">
                    <span>@Snapshot.RequestedRankingLabel</span>
                    <span>@Snapshot.Overview.MatchCount matchs observes</span>
                </div>
            </div>

            <div class="today-pulse">
                    <article>
                        <span>Equipes actives</span>
                        <strong>@Snapshot.Overview.TeamCount</strong>
                        <small>clubs dans le perimetre filtre</small>
                    </article>

                    <article>
                        <span>Cadence offensive</span>
                        <strong>@((Snapshot.Overview.MatchCount == 0 ? 0 : Snapshot.Overview.GoalCount / (double)Snapshot.Overview.MatchCount).ToString("0.0"))</strong>
                        <small>buts par match sur la selection</small>
                    </article>

                    <article class="today-pulse__signal">
                        <span>Jeu prepare</span>
                        <strong>@((Snapshot.Overview.GoalCount == 0 ? 0 : Snapshot.Overview.AssistCount * 100d / Snapshot.Overview.GoalCount).ToString("0"))%</strong>
                        <small>buts amenes par une passe decisive</small>
                    </article>
            </div>
        </section>

        <AudienceLensSelector Kicker="Espace de lecture"
                              Title="Adaptez le tableau de bord à votre mission"
                              Subtitle="Le contenu se réorganise pour le pilotage du club, l'analyse détaillée ou le débrief joueuse."
                              Value="@ActiveLens"
                              ValueChanged="SetActiveLens" />

        <section class="scope-sheet">

            <div class="panel-head panel-head-wrap">
                <div>
                    <p class="section-kicker">Scope local</p>
                    <h3>Ajuster le brief</h3>
                </div>

                <div class="toolbar">
                    <button type="button" class="ghost-button filter-ghost" @onclick="ResetFiltersAsync" disabled="@IsBusy">Reinitialiser</button>
                </div>
            </div>

            <details class="filter-drawer" open>
                <summary>
                    <div>
                        <strong>Afficher les filtres dashboard</strong>
                        <span>Compétition, équipe, saison, journée et lecture de classement.</span>
                    </div>
                </summary>

                <div class="filter-drawer-body">
                    <div class="page-filters">
                        <label class="filter-field">
                            <span>Competition</span>
                            <select @bind="Filters.CompetitionId" @bind:after="OnScopeSelectionChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var competition in AvailableCompetitions)
                                {
                                    <option value="@competition.CompetitionId">@competition.CompetitionName</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Equipe</span>
                            <select @bind="Filters.TeamId" @bind:after="OnScopeSelectionChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var team in AvailableTeams)
                                {
                                    <option value="@team.TeamId">@team.TeamName</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Saison</span>
                            <select @bind="Filters.Season" @bind:after="OnScopeSelectionChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var season in SeasonOptions)
                                {
                                    <option value="@season">@season</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Journee</span>
                            <select @bind="Filters.Day" @bind:after="OnScopeSelectionChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var day in DayOptions)
                                {
                                    <option value="@day">@day</option>
                                }
                            </select>
                        </label>

                    </div>
                </div>
            </details>

        </section>

        @if (!string.IsNullOrWhiteSpace(Snapshot.WarningMessage))
        {
            <section class="warning-banner">
                <strong>Information</strong>
                <span>@Snapshot.WarningMessage</span>
            </section>
        }

        @if (Snapshot.Players.Count == 0 || Snapshot.Spotlight.PlayerId <= 0)
        {
            <StateCard Kicker="Aucune joueuse"
                       Title="Aucune joueuse dans cette sélection"
                       Message="Essayez une autre compétition, une autre équipe ou réinitialisez les filtres."
                       Tone="empty" />
        }
        else
        {
            <div class="scene-switcher" role="tablist" aria-label="Scenes Today">
                <button type="button" class="section-chip @(ActiveDashboardSection == "league" ? "is-active" : string.Empty)" @onclick='() => SetDashboardSection("league")' disabled="@IsBusy">
                    Pulse
                    <small>Signaux collectifs</small>
                </button>
                <button type="button" class="section-chip @(ActiveDashboardSection == "team-of-day" ? "is-active" : string.Empty)" @onclick='() => SetDashboardSection("team-of-day")' disabled="@IsBusy">
                    Team day
                    <small>Equipe type</small>
                </button>
                <button type="button" class="section-chip @(ActiveDashboardSection == "spotlight" ? "is-active" : string.Empty)" @onclick='() => SetDashboardSection("spotlight")' disabled="@IsBusy">
                    Athlete signal
                    <small>Profil et court</small>
                </button>
                <button type="button" class="section-chip @(ActiveDashboardSection == "recent" ? "is-active" : string.Empty)" @onclick='() => SetDashboardSection("recent")' disabled="@IsBusy">
                    Recent games
                    <small>Dernieres rencontres</small>
                </button>
                <button type="button" class="section-chip @(ActiveDashboardSection == "global-rankings" ? "is-active" : string.Empty)" @onclick='() => SetDashboardSection("global-rankings")' disabled="@IsBusy">
                    Data index
                    <small>Tables completes</small>
                </button>
            </div>

            @if (ActiveDashboardSection == "league")
            {
                <section class="signal-matrix">
                    <div class="mini-card"><span>Joueuses</span><strong>@Snapshot.Overview.PlayerCount</strong></div>
                    <div class="mini-card"><span>Matchs</span><strong>@Snapshot.Overview.MatchCount</strong></div>
                    <div class="mini-card"><span>Buts</span><strong>@Snapshot.Overview.GoalCount</strong></div>
                    <div class="mini-card"><span>Passes</span><strong>@Snapshot.Overview.AssistCount</strong></div>
                    <div class="mini-card"><span>Interceptions</span><strong>@Snapshot.Overview.InterceptionCount</strong></div>
                    <div class="mini-card"><span>Arrets</span><strong>@Snapshot.Overview.SaveCount</strong></div>
                </section>

                @if (ShowLeagueKpis)
                {
                    <section class="page-panel">
                        <div class="panel-head">
                            <div>
                                <p class="section-kicker">Lecture staff</p>
                                <h3>Les KPI qui structurent le contexte de la selection</h3>
                            </div>
                        </div>

                        <KpiTileGrid Items="@LeagueKpis" />
                    </section>
                }

                @if (ShowRankingPanel)
                {
                    <section class="page-panel">
                        <div class="panel-head">
                            <div>
                                <p class="section-kicker">Classement</p>
                                <h3>@Snapshot.RequestedRankingLabel</h3>
                            </div>
                            <span class="panel-pill">Top @Filters.Top</span>
                        </div>

                        <div class="ranking-toolbar">
                            <div class="ranking-toolbar-group">
                                <span class="section-kicker">Indicateur</span>
                                <div class="page-section-switch ranking-chip-row">
                                    @foreach (var metric in RankingMetrics)
                                    {
                                        <button type="button"
                                                class="section-chip ranking-chip @(IsRankingMetricActive(metric.Value) ? "is-active" : string.Empty)"
                                                disabled="@IsBusy"
                                                @onclick="() => SelectRankingMetricAsync(metric.Value)">
                                            @metric.Label
                                        </button>
                                    }
                                </div>
                            </div>

                            <div class="ranking-toolbar-group">
                                <span class="section-kicker">Top</span>
                                <div class="page-section-switch ranking-chip-row">
                                    @foreach (var top in RankingTopOptions)
                                    {
                                        <button type="button"
                                                class="section-chip ranking-chip @(IsRankingTopActive(top) ? "is-active" : string.Empty)"
                                                disabled="@IsBusy"
                                                @onclick="() => SelectRankingTopAsync(top)">
                                            Top @top
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <ApexChart @key="RankingChartKey" TItem="PlayerRankingItem" Title="@Snapshot.RequestedRankingLabel" Height="300" Options="@GetRankingChartOptions()">
                            <ApexPointSeries TItem="PlayerRankingItem"
                                             Items="@Snapshot.RequestedRanking"
                                             Name="@Snapshot.RequestedRankingLabel"
                                             SeriesType="SeriesType.Bar"
                                             XValue="item => item.PlayerName"
                                             YValue="item => (decimal?)item.Value" />
                        </ApexChart>
                    </section>
                }
            }
            else if (ActiveDashboardSection == "team-of-day")
            {
                var teamOfTheDay = Snapshot.TeamOfTheDay;
                var lineup = TeamOfTheDayLineup.ToArray();
                var candidateRows = TeamOfTheDayCandidateRows.ToArray();

                <section class="team-day-shell">
                    <div class="page-panel team-day-hero">
                        <div class="panel-head panel-head-wrap">
                            <div>
                                <p class="section-kicker">Equipe type de la journee</p>
                                <h3>@teamOfTheDay.ScopeLabel</h3>
                                <p class="page-subtitle">
                                    Meilleure joueuse par poste selon @TeamOfTheDayMetricLabel(TeamOfTheDayMetric). Les egalites sont departagees par PIE, temps de jeu, actions puis pertes.
                                </p>
                            </div>

                            <div class="team-day-mode-switch" role="tablist" aria-label="Critere equipe type">
                                <span class="team-day-filter-title">Critere principal</span>
                                <div class="team-day-chip-row">
                                    @foreach (var metric in TeamOfTheDayMetrics)
                                    {
                                        <button type="button"
                                                class="section-chip ranking-chip @(TeamOfTheDayMetric == metric ? "is-active" : string.Empty)"
                                                @onclick="() => SetTeamOfTheDayMetric(metric)"
                                                disabled="@IsBusy">
                                            @TeamOfTheDayMetricLabel(metric)
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="team-day-filter-strip">
                            <div class="team-day-filter-group">
                                <span class="team-day-filter-title">PIE minimum</span>
                                <div class="team-day-chip-row">
                                    @foreach (var threshold in TeamOfTheDayPieThresholds)
                                    {
                                        <button type="button"
                                                class="section-chip ranking-chip @(IsTeamOfTheDayPieThresholdActive(threshold) ? "is-active" : string.Empty)"
                                                @onclick="() => SetTeamOfTheDayMinimumPie(threshold)"
                                                disabled="@IsBusy">
                                            @TeamOfTheDayPieThresholdLabel(threshold)
                                        </button>
                                    }
                                </div>
                            </div>

                            <div class="team-day-filter-group">
                                <span class="team-day-filter-title">Total actions minimum</span>
                                <div class="team-day-chip-row">
                                    @foreach (var threshold in TeamOfTheDayActionThresholds)
                                    {
                                        <button type="button"
                                                class="section-chip ranking-chip @(IsTeamOfTheDayActionThresholdActive(threshold) ? "is-active" : string.Empty)"
                                                @onclick="() => SetTeamOfTheDayMinimumActions(threshold)"
                                                disabled="@IsBusy">
                                            @TeamOfTheDayActionThresholdLabel(threshold)
                                        </button>
                                    }
                                </div>
                            </div>

                            <button type="button" class="ghost-button filter-ghost" @onclick="ResetTeamOfTheDayFilters" disabled="@IsBusy">
                                Nettoyer filtres
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(teamOfTheDay.WarningMessage))
                        {
                            <section class="warning-banner team-day-warning">
                                <strong>Information</strong>
                                <span>@teamOfTheDay.WarningMessage</span>
                            </section>
                        }

                        <div class="signal-matrix team-day-metrics">
                            <div class="mini-card"><span>Postes couverts</span><strong>@lineup.Length/7</strong></div>
                            <div class="mini-card"><span>Candidates</span><strong>@teamOfTheDay.CandidateCount</strong></div>
                            <div class="mini-card"><span>Matchs journee</span><strong>@teamOfTheDay.MatchCount</strong></div>
                            <div class="mini-card"><span>Lecture</span><strong>@TeamOfTheDayMetricShortLabel(TeamOfTheDayMetric)</strong></div>
                            <div class="mini-card"><span>Filtrees</span><strong>@candidateRows.Length</strong></div>
                        </div>

                        @if (lineup.Length == 0)
                        {
                            <StateCard Kicker="Equipe type"
                                       Title="Aucune equipe type calculable"
                                       Message="Selectionnez une saison et une journee contenant des statistiques joueuses valides."
                                       Tone="empty"
                                       CssClass="empty-card-inline" />
                        }
                        else
                        {
                            <div class="team-day-stage">
                                <div class="team-day-field" aria-label="Formation equipe type">
                                    @foreach (var player in lineup)
                                    {
                                        var group = teamOfTheDay.Groups.FirstOrDefault(item => item.SlotKey == player.SlotKey);
                                        var tieCount = group?.TieCount(TeamOfTheDayMetric, TeamOfTheDayMinimumPie, TeamOfTheDayMinimumActions) ?? 0;

                                        <article @key="player.PlayerId" class="team-day-player-card @player.FormationArea">
                                            <div class="team-day-player-card__halo">@player.Initials</div>
                                            <div>
                                                <span class="team-day-position">@player.PositionLabel</span>
                                                <h4>@player.FullName</h4>
                                                <p>@player.TeamName</p>
                                            </div>

                                            <div class="team-day-score">
                                                <span>@TeamOfTheDayMetricShortLabel(TeamOfTheDayMetric)</span>
                                                <strong>@FormatTeamOfTheDayScore(player.ScoreFor(TeamOfTheDayMetric))</strong>
                                            </div>

                                            <div class="team-day-card-meta">
                                                <span>@(string.IsNullOrWhiteSpace(player.OpponentName) ? "Adversaire non renseigne" : $"vs {player.OpponentName}")</span>
                                                <span>@(string.IsNullOrWhiteSpace(player.MatchScore) ? "Score N/A" : player.MatchScore)</span>
                                            </div>

                                            <div class="team-day-card-stats">
                                                @if (player.IsGoalkeeper)
                                                {
                                                    <span>@player.StatLine.GoalkeeperStops arr.</span>
                                                    <span>@FormatRate(player.StatLine.GoalkeeperSaveRate)%</span>
                                                    <span>@player.StatLine.GoalsConceded buts pris</span>
                                                }
                                                else
                                                {
                                                    <span>@player.StatLine.Goals buts</span>
                                                    <span>@player.StatLine.Assists passes</span>
                                                    <span>@player.StatLine.DefensiveImpact def.</span>
                                                }
                                                <span>@player.StatLine.TotalActions actions</span>
                                            </div>

                                            @if (tieCount > 1)
                                            {
                                                <span class="team-day-tie">Egalite x@tieCount</span>
                                            }

                                            @if (player.MatchId.HasValue)
                                            {
                                                <a class="team-day-match-link" href="@($"/matches?matchId={player.MatchId.Value}")">Voir match</a>
                                            }
                                        </article>
                                    }
                                </div>

                                <aside class="team-day-side">
                                    <p class="section-kicker">Lecture du score</p>
                                    <h4>@TeamOfTheDayMetricLabel(TeamOfTheDayMetric)</h4>
                                    <p>@TeamOfTheDayMetricDescription</p>
                                    <div class="compact-list">
                                        @foreach (var player in lineup.OrderByDescending(item => item.ScoreFor(TeamOfTheDayMetric)).Take(4))
                                        {
                                            <div class="outcome-row">
                                                <span>@player.FullName</span>
                                                <strong>@FormatTeamOfTheDayScore(player.ScoreFor(TeamOfTheDayMetric))</strong>
                                            </div>
                                        }
                                    </div>
                                </aside>
                            </div>
                        }
                    </div>

                    @if (candidateRows.Length > 0)
                    {
                        <section class="page-panel team-day-board">
                            <div class="panel-head">
                                <div>
                                    <p class="section-kicker">Candidates par poste</p>
                                    <h3>Classement detaille et departage</h3>
                                </div>
                                <span class="panel-pill">@candidateRows.Length lignes</span>
                            </div>

                            <div class="list-stack">
                                @foreach (var group in teamOfTheDay.Groups)
                                {
                                    var best = group.GetBestCandidate(TeamOfTheDayMetric, TeamOfTheDayMinimumPie, TeamOfTheDayMinimumActions);
                                    var rows = group.Candidates
                                        .Where(candidate => candidate.MatchesFilters(TeamOfTheDayMetric, TeamOfTheDayMinimumPie, TeamOfTheDayMinimumActions))
                                        .OrderByDescending(candidate => candidate.ScoreFor(TeamOfTheDayMetric))
                                        .ThenByDescending(candidate => candidate.PieForFilter(TeamOfTheDayMetric))
                                        .ThenByDescending(candidate => candidate.PlayingTimeMinutes)
                                        .ThenByDescending(candidate => candidate.StatLine.TotalActions)
                                        .ThenBy(candidate => candidate.FullName)
                                        .ToArray();

                                    <details class="dashboard-board-drawer team-day-position-drawer" open>
                                        <summary>
                                            <div>
                                                <p class="section-kicker">@group.PositionLabel</p>
                                                <strong>@(best?.FullName ?? "Aucune candidate")</strong>
                                            </div>
                                            <span class="panel-pill">@rows.Length candidates</span>
                                        </summary>

                                        <section class="page-panel dashboard-nested-panel">
                                            <div class="table-wrap">
                                                <table class="stat-table">
                                                    <thead>
                                                        <tr>
                                                            <th>Rang</th>
                                                            <th>Joueuse</th>
                                                            <th>Equipe</th>
                                                            <th>Adversaire</th>
                                                            <th>@TeamOfTheDayMetricShortLabel(TeamOfTheDayMetric)</th>
                                                            <th>Actions</th>
                                                            <th>PIE global</th>
                                                            <th>PIE Off</th>
                                                            <th>PIE Def</th>
                                                            <th>Buts</th>
                                                            <th>Passes</th>
                                                            <th>Impact def.</th>
                                                            <th>Arrets</th>
                                                            <th>Pertes</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var row in rows.Select((candidate, index) => (candidate, index)))
                                                        {
                                                            <tr class="@(row.index == 0 ? "is-selected-row" : string.Empty)">
                                                                <td>@(row.index + 1)</td>
                                                                <td>@row.candidate.FullName</td>
                                                                <td>@row.candidate.TeamName</td>
                                                                <td>@(row.candidate.OpponentName ?? "-")</td>
                                                                <td><strong>@FormatTeamOfTheDayScore(row.candidate.ScoreFor(TeamOfTheDayMetric))</strong></td>
                                                                <td>@row.candidate.StatLine.TotalActions</td>
                                                                <td>@FormatPie(row.candidate.PieGlobal)</td>
                                                                <td>@FormatPie(row.candidate.PieOffense)</td>
                                                                <td>@FormatPie(row.candidate.PieDefense)</td>
                                                                <td>@row.candidate.StatLine.Goals</td>
                                                                <td>@row.candidate.StatLine.Assists</td>
                                                                <td>@row.candidate.StatLine.DefensiveImpact</td>
                                                                <td>@row.candidate.StatLine.GoalkeeperStops</td>
                                                                <td>@row.candidate.StatLine.Turnovers</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </section>
                                    </details>
                                }
                            </div>
                        </section>
                    }
                </section>
            }
            else if (ActiveDashboardSection == "spotlight")
            {
                <section class="page-panel">
                    <div class="panel-head panel-head-wrap">
                        <div>
                            <p class="section-kicker">Joueuse suivie</p>
                            <h3>@Snapshot.Spotlight.FullName</h3>
                            <p class="page-subtitle">
                                @Snapshot.Spotlight.TeamName - @Snapshot.Spotlight.PositionName
                                @if (Snapshot.Spotlight.Age.HasValue)
                                {
                                    <span>- @Snapshot.Spotlight.Age.Value ans</span>
                                }
                            </p>
                        </div>

                        <label class="filter-field compact-select">
                            <span>Changer de joueuse</span>
                            <select value="@Filters.SpotlightPlayerId" @onchange="OnPlayerChangedAsync">
                                @foreach (var player in Snapshot.Players)
                                {
                                    <option value="@player.Id">@player.FullName</option>
                                }
                            </select>
                        </label>
                    </div>

                    <div class="badge-row">
                        <div class="mini-card"><span>Matchs</span><strong>@Snapshot.Spotlight.MatchesPlayed</strong></div>
                        <div class="mini-card"><span>Buts</span><strong>@Snapshot.Spotlight.TotalGoals</strong></div>
                        <div class="mini-card"><span>Passes</span><strong>@Snapshot.Spotlight.Assists</strong></div>
                        <div class="mini-card"><span>@(Snapshot.Spotlight.IsGoalkeeper ? "Arrets" : "Impact def.")</span><strong>@(Snapshot.Spotlight.IsGoalkeeper ? Snapshot.Spotlight.Saves : Snapshot.Spotlight.DefensiveStops)</strong></div>
                    </div>

                    <KpiTileGrid Items="@SpotlightKpis" />

                    @if (ShowSpotlightDeepDive)
                    {
                        <div class="dual-grid">
                            <section class="page-panel dashboard-nested-panel">
                                <p class="section-kicker">Profil d'activite</p>
                                <h4>Repartition des actions</h4>
                                <ApexChart TItem="SliceValue" Title="Volume d'actions" Height="280" Options="@GetDistributionChartOptions()">
                                    <ApexPointSeries TItem="SliceValue"
                                                     Items="@Snapshot.Spotlight.Distribution"
                                                     Name="Actions"
                                                     SeriesType="SeriesType.Donut"
                                                     XValue="slice => slice.Label"
                                                     YValue="slice => (decimal?)slice.Value" />
                                </ApexChart>
                            </section>

                            <section class="page-panel dashboard-nested-panel">
                                <p class="section-kicker">Lecture rapide</p>
                                <h4>Impact dans la selection</h4>
                                <div class="compact-list">
                                    <div class="outcome-row">
                                        <span>Taux de tir ouvert</span>
                                        <strong>@FormatRate(Snapshot.Spotlight.ShootingRate)%</strong>
                                    </div>
                                    <div class="outcome-row">
                                        <span>Tirs engages</span>
                                        <strong>@Snapshot.Spotlight.ShotAttempts</strong>
                                    </div>
                                    <div class="outcome-row">
                                        <span>Conversion globale</span>
                                        <strong>@FormatRate(Snapshot.Spotlight.OverallShotSuccessRate)%</strong>
                                    </div>
                                    <div class="outcome-row">
                                        <span>Dechet tir</span>
                                        <strong>@Snapshot.Spotlight.ShotWaste</strong>
                                    </div>
                                    <div class="outcome-row">
                                        <span>Passes / pertes</span>
                                        <strong>@Snapshot.Spotlight.Assists / @Snapshot.Spotlight.Turnovers</strong>
                                    </div>
                                    <div class="outcome-row">
                                        <span>Pertes techniques</span>
                                        <strong>@Snapshot.Spotlight.TechnicalLosses</strong>
                                    </div>
                                    <div class="outcome-row">
                                        <span>Defense</span>
                                        <strong>@Snapshot.Spotlight.Defense.Interceptions int. / @Snapshot.Spotlight.Defense.Contres contres</strong>
                                    </div>
                                    @if (Snapshot.Spotlight.IsGoalkeeper)
                                    {
                                        <div class="outcome-row">
                                            <span>Stop 7m</span>
                                            <strong>@FormatRate(Snapshot.Spotlight.PenaltyStopRate)%</strong>
                                        </div>
                                    }
                                    <div class="outcome-row">
                                        <span>Sanctions</span>
                                        <strong>@Snapshot.Spotlight.Sanctions.DeuxMinutes deux min.</strong>
                                    </div>
                                </div>
                            </section>
                        </div>
                    }
                </section>

                @if (ShowSpatialSection)
                {
                    <section class="dashboard-grid">
