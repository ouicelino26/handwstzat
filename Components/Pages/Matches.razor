    private bool ShowMatchSummaryKpis => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowMatchScenarioInsights => ActiveLens == AudienceLens.Analyst;
    private bool ShowMatchTimelineKpis => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowMatchSummaryCharts => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowMatchAnalystPanels => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowTeam1TimelineSeries => MatchTeamScope is MatchTeamScopeBoth or MatchTeamScopeTeam1;
    private bool ShowTeam2TimelineSeries => MatchTeamScope is MatchTeamScopeBoth or MatchTeamScopeTeam2;
    private ZoneStat? CurrentZone => GoalZones.Concat(TriggerZones).FirstOrDefault(zone => zone.Key == ActiveZoneKey)
        ?? GoalZones.FirstOrDefault(zone => zone.Attempts > 0)
        ?? TriggerZones.FirstOrDefault(zone => zone.Attempts > 0)
        ?? GoalZones.FirstOrDefault()
        ?? TriggerZones.FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        ApplyGlobalScope();
        ScopeService.Changed += HandleGlobalScopeChanged;
        await ApplyFiltersAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await SyncSelectedMatchAsync();
    }

    private Task OnScopeSelectionChangedAsync()
    {
        PublishGlobalScope();
        return ApplyFiltersAsync();
    }

    private async Task SetActiveLens(string lens)
    {
        ActiveLens = lens;

        if (ShowMatchSummaryCharts || ShowMatchAnalystPanels)
        {
            await EnsureMatchPlayersLoadedAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyFiltersAsync()
    {
        var loadStartedAt = DateTimeOffset.UtcNow;

        try
        {
            await BusyUiHelper.EnterAsync(() => IsBusy = true, () => InvokeAsync(StateHasChanged));
            ErrorMessage = null;

            ReferenceData = await ReferenceDataService.GetReferenceDataAsync();
            await LoadFilterScopesAsync();

            var filtersAdjusted = false;

            if (CompetitionId.HasValue && AvailableCompetitions.All(item => item.CompetitionId != CompetitionId.Value))
            {
                CompetitionId = null;
                filtersAdjusted = true;
            }

            if (TeamId.HasValue && AvailableTeams.All(item => item.TeamId != TeamId.Value))
            {
                TeamId = null;
                filtersAdjusted = true;
            }

            if (filtersAdjusted)
            {
                await LoadFilterScopesAsync();
            }

            if (!string.IsNullOrWhiteSpace(Season) && !SeasonOptions.Contains(Season, StringComparer.OrdinalIgnoreCase))
            {
                Season = null;
            }

            if (!string.IsNullOrWhiteSpace(Day) && !DayOptions.Contains(Day, StringComparer.OrdinalIgnoreCase))
            {
                Day = null;
            }

            ActiveSection = "summary";
            await SyncSelectedMatchAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            await BusyUiHelper.ExitAsync(() => IsBusy = false, () => InvokeAsync(StateHasChanged), loadStartedAt);
        }
    }

    private async Task ResetAsync()
    {
        CompetitionId = null;
        TeamId = null;
        Year = null;
        Season = null;
        Day = null;
        MatchSearch = string.Empty;
        MatchPlayerSearch = string.Empty;
        MatchPlayerSort = new TableSortState("goals", SortDirection.Desc);
        MatchTeamScope = MatchTeamScopeBoth;
        ActiveSection = "summary";
        PublishGlobalScope();
        await ApplyFiltersAsync();
    }

    private async Task SelectMatchAsync(int matchId)
    {
        SelectedMatchId = matchId;
        await SyncSelectedMatchAsync();
    }

    private async Task OnMatchSearchChangedAsync(ChangeEventArgs args)
    {
        MatchSearch = args.Value?.ToString() ?? string.Empty;
        await SyncSelectedMatchAsync();
    }

    private async Task OnSeasonChangedAsync(ChangeEventArgs args)
    {
        Season = MatchFilterCatalog.NormalizeSelection(args.Value?.ToString());

        if (!string.IsNullOrWhiteSpace(Day) && !DayOptions.Contains(Day, StringComparer.OrdinalIgnoreCase))
        {
            Day = null;
        }

        PublishGlobalScope();
        await SyncSelectedMatchAsync();
    }

    private async Task OnDayChangedAsync(ChangeEventArgs args)
    {
        Day = MatchFilterCatalog.NormalizeSelection(args.Value?.ToString());
        PublishGlobalScope();
        await SyncSelectedMatchAsync();
    }

    public void Dispose()
    {
        ScopeService.Changed -= HandleGlobalScopeChanged;
    }

    private void HandleGlobalScopeChanged()
    {
        if (_publishingScope)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            ApplyGlobalScope();
            await ApplyFiltersAsync();
        });
    }

    private void ApplyGlobalScope()
    {
        CompetitionId = ScopeService.Current.CompetitionId;
        TeamId = ScopeService.Current.TeamId;
        Season = ScopeService.Current.Season;
        Day = ScopeService.Current.Day;
    }

    private void PublishGlobalScope()
    {
        _publishingScope = true;
        try
        {
            ScopeService.Update(new AnalysisScopeSnapshot(
                CompetitionId,
                AvailableCompetitions.FirstOrDefault(item => item.CompetitionId == CompetitionId)?.CompetitionName,
                TeamId,
                AvailableTeams.FirstOrDefault(item => item.TeamId == TeamId)?.TeamName,
                Season,
                Day));
        }
        finally
        {
            _publishingScope = false;
        }
    }

    private Task OnMatchPlayerSearchChanged(ChangeEventArgs args)
    {
        MatchPlayerSearch = args.Value?.ToString() ?? string.Empty;
        return InvokeAsync(StateHasChanged);
    }

    private async Task SetActiveSection(string section)
    {
        ActiveSection = section;

        await InvokeAsync(StateHasChanged);

        if (section == "players")
        {
            await EnsureMatchPlayersLoadedAsync();
        }
        else if (section == "zones")
        {
            await EnsureMatchSpatialLoadedAsync();
        }
    }

    private async Task HandleZoneSelectionAsync(string zoneKey)
    {
        if (!SelectedMatchId.HasValue || MatchSpatial is null || string.IsNullOrWhiteSpace(zoneKey))
        {
            return;
        }

        var normalizedZoneKey = zoneKey.Trim();
        var nextFocusKey = string.Equals(SpatialFocusKey, normalizedZoneKey, StringComparison.OrdinalIgnoreCase)
            ? null
            : normalizedZoneKey;

        ActiveZoneKey = normalizedZoneKey;
        await LoadSelectedSpatialAsync(nextFocusKey);
    }

    private async Task ResetSpatialFocusAsync()
    {
        if (!HasSpatialFocus)
        {
            return;
        }

        await LoadSelectedSpatialAsync(null);
    }

    private void ClearSelectedMatchDetail()
    {
        SelectedMatch = null;
        MatchSummary = null;
        MatchPlayers = [];
        MatchSpatial = null;
        SelectedMatchTimeline = [];
        ActiveZoneKey = null;
        SpatialFocusKey = null;
        IsSpatialLoading = false;
        System.Threading.Interlocked.Increment(ref SpatialLoadToken);
    }

    private long BeginSelectedMatchLoad()
    {
        SelectedMatchLoadToken++;
        return SelectedMatchLoadToken;
    }

    private async Task LoadSelectedMatchAsync(long loadToken, bool loadPlayers = false, bool replaceCurrentSelection = false)
    {
        System.Threading.Interlocked.Increment(ref SpatialLoadToken);
        IsSpatialLoading = false;

        if (!SelectedMatchId.HasValue)
        {
            IsMatchDetailLoading = false;
            ClearSelectedMatchDetail();
            return;
        }

        var matchId = SelectedMatchId.Value;
        var includePlayers = loadPlayers || ShowMatchSummaryCharts || ShowMatchAnalystPanels;
        var cache = GetMatchDetailCache(matchId);
        var needsMainData = cache.Match is null || cache.Summary is null || cache.Timeline.Count == 0;
        var needsPlayers = includePlayers && !cache.PlayersLoaded;

        if (!needsMainData)
        {
            SelectedMatch = cache.Match;
            MatchSummary = cache.Summary;
            SelectedMatchTimeline = cache.Timeline;
            MatchPlayers = cache.PlayersLoaded ? cache.Players : [];
            IsMatchDetailLoading = false;

            if (!needsPlayers)
            {
                return;
            }
        }

        if (needsMainData)
        {
            ClearSelectedMatchDetail();
            IsMatchDetailLoading = true;
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
        }

        Task<MatchListItemDto?>? matchTask = null;
        Task<MatchSummaryDto?>? summaryTask = null;
        Task<IReadOnlyList<PlayerGlobalStatsDto>>? playersTask = null;
        Task<IReadOnlyList<MatchEvent>>? eventsTask = null;

        if (cache.Match is null)
        {
            matchTask = MatchesApiClient.GetMatchAsync(matchId);
        }

        if (cache.Summary is null)
        {
            summaryTask = StatsApiClient.GetAnalyticsMatchSummaryAsync(matchId);
        }

        if (cache.Timeline.Count == 0)
        {
            eventsTask = MatchEventsApiClient.GetMatchEventsAsync(matchId);
        }

        if (includePlayers && !cache.PlayersLoaded)
        {
            playersTask = StatsApiClient.GetMatchPlayersAsync(matchId);
        }

        var pendingTasks = new List<Task>();

        if (matchTask is not null)
        {
            pendingTasks.Add(matchTask);
        }

        if (summaryTask is not null)
        {
            pendingTasks.Add(summaryTask);
        }

        if (eventsTask is not null)
        {
            pendingTasks.Add(eventsTask);
        }

        if (playersTask is not null)
        {
            pendingTasks.Add(playersTask);
        }

        if (pendingTasks.Count > 0)
        {
            await Task.WhenAll(pendingTasks);

            if (loadToken != SelectedMatchLoadToken)
            {
                return;
            }

            if (matchTask is not null)
            {
                cache.Match = matchTask.Result;
            }

            if (summaryTask is not null)
            {
                cache.Summary = summaryTask.Result;
            }

            if (eventsTask is not null)
            {
                cache.Timeline = MatchScenarioAnalyzer.BuildScoreTimeline(eventsTask.Result, cache.Match ?? SelectedMatch);
            }

            if (playersTask is not null)
            {
                cache.Players = playersTask.Result ?? [];
                cache.PlayersLoaded = true;
            }
        }

        if (loadToken != SelectedMatchLoadToken)
        {
            return;
        }

        SelectedMatch = cache.Match;
        MatchSummary = cache.Summary;
        SelectedMatchTimeline = cache.Timeline;
        MatchPlayers = cache.PlayersLoaded ? cache.Players : [];
        IsMatchDetailLoading = false;
    }

    private async Task EnsureMatchPlayersLoadedAsync()
    {
        if (!SelectedMatchId.HasValue)
        {
            return;
        }

        var cache = GetMatchDetailCache(SelectedMatchId.Value);
        if (cache.PlayersLoaded)
        {
            MatchPlayers = cache.Players;
            return;
        }

        await LoadSelectedMatchAsync(SelectedMatchLoadToken, loadPlayers: true);
    }

    private async Task EnsureMatchSpatialLoadedAsync()
    {
        if (!SelectedMatchId.HasValue)
        {
            return;
        }

        await LoadSelectedSpatialAsync(SpatialFocusKey);
    }

    private async Task LoadSelectedSpatialAsync(string? focusZoneKey = null)
    {
        if (!SelectedMatchId.HasValue || SelectedMatch is null)
        {
            MatchSpatial = null;
            ActiveZoneKey = null;
            SpatialFocusKey = null;
            IsSpatialLoading = false;
            return;
        }

        var matchId = SelectedMatchId.Value;
        var scopeKey = MatchSpatialScopeKey;
        var teamId = MatchSpatialTeamId;
        var cache = GetMatchDetailCache(matchId);
        var cacheKey = GetMatchSpatialCacheKey(scopeKey, focusZoneKey);
        var loadToken = System.Threading.Interlocked.Increment(ref SpatialLoadToken);

        if (cache.SpatialByContext.TryGetValue(cacheKey, out var cachedSpatial) && cachedSpatial is not null)
        {
            MatchSpatial = cachedSpatial;
            SpatialFocusKey = focusZoneKey;
            ActiveZoneKey = ResolveActiveZoneKey(focusZoneKey);
            IsSpatialLoading = false;
            ErrorMessage = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (cache.SpatialByContext.ContainsKey(cacheKey))
        {
            cache.SpatialByContext.Remove(cacheKey);
        }

        IsSpatialLoading = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            var spatial = await StatsApiClient.GetMatchSpatialAsync(matchId, teamId, BuildMatchSpatialQueryOptions(focusZoneKey));

            if (loadToken != SpatialLoadToken || !SelectedMatchId.HasValue || SelectedMatchId.Value != matchId || !string.Equals(scopeKey, MatchSpatialScopeKey, StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            if (spatial is not null)
            {
                cache.SpatialByContext[cacheKey] = spatial;
            }

            MatchSpatial = spatial;
            SpatialFocusKey = focusZoneKey;
            ActiveZoneKey = ResolveActiveZoneKey(focusZoneKey);
            ErrorMessage = null;
        }
        catch (Exception ex)
        {
            if (loadToken != SpatialLoadToken || !SelectedMatchId.HasValue || SelectedMatchId.Value != matchId || !string.Equals(scopeKey, MatchSpatialScopeKey, StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            MatchSpatial = null;
            ActiveZoneKey = null;
            SpatialFocusKey = null;
            ErrorMessage = ex.Message;
        }
        finally
        {
            if (loadToken == SpatialLoadToken && SelectedMatchId.HasValue && SelectedMatchId.Value == matchId && string.Equals(scopeKey, MatchSpatialScopeKey, StringComparison.OrdinalIgnoreCase))
            {
                IsSpatialLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private string GetMatchSpatialCacheKey(string scopeKey, string? focusZoneKey)
    {
        if (string.IsNullOrWhiteSpace(focusZoneKey))
        {
            return scopeKey;
        }

        return $"{scopeKey}|{focusZoneKey.Trim().ToUpperInvariant()}";
    }

    private StatsQueryOptionsDto BuildMatchSpatialQueryOptions(string? focusZoneKey)
    {
        var options = new StatsQueryOptionsDto();

        if (string.IsNullOrWhiteSpace(focusZoneKey))
        {
            return options;
        }

        if (SpatialZoneVisuals.IsTriggerZoneKey(focusZoneKey))
        {
            options.Trigger = SpatialZoneVisuals.ToBackendTriggerKey(focusZoneKey);
        }
        else
        {
            options.ShootShade = focusZoneKey.Trim();
        }

        return options;
    }

    private string? ResolveActiveZoneKey(string? preferredKey = null)
    {
        var allZoneKeys = GoalZones
            .Concat(TriggerZones)
            .Select(zone => zone.Key)
            .Where(key => !string.IsNullOrWhiteSpace(key))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!string.IsNullOrWhiteSpace(preferredKey) && allZoneKeys.Contains(preferredKey))
        {
            return preferredKey;
        }

        if (!string.IsNullOrWhiteSpace(ActiveZoneKey) && allZoneKeys.Contains(ActiveZoneKey))
        {
            return ActiveZoneKey;
        }

        return GoalZones.FirstOrDefault(zone => zone.Attempts > 0)?.Key
            ?? TriggerZones.FirstOrDefault(zone => zone.Attempts > 0)?.Key
            ?? GoalZones.FirstOrDefault()?.Key
            ?? TriggerZones.FirstOrDefault()?.Key;
    }

    private MatchDetailCacheItem GetMatchDetailCache(int matchId)
    {
        if (!MatchDetailCache.TryGetValue(matchId, out var cache))
        {
            cache = new MatchDetailCacheItem();
            MatchDetailCache[matchId] = cache;
        }

        return cache;
    }

    private async Task LoadFilterScopesAsync()
    {
        var competitionScopeTask = MatchesApiClient.GetMatchesAsync(
            teamId: TeamId,
            year: Year,
            page: 1,
            pageSize: 500);
        var teamScopeTask = MatchesApiClient.GetMatchesAsync(
            competitionId: CompetitionId,
            year: Year,
            page: 1,
            pageSize: 500);
        var contextScopeTask = MatchesApiClient.GetMatchesAsync(
            competitionId: CompetitionId,
            teamId: TeamId,
            year: Year,
            page: 1,
            pageSize: 500);

        await Task.WhenAll(competitionScopeTask, teamScopeTask, contextScopeTask);

        CompetitionOptionMatches = competitionScopeTask.Result;
        TeamOptionMatches = teamScopeTask.Result;
        ScopedMatches = contextScopeTask.Result;
        MatchList = ScopedMatches;
    }

    private static ZoneStat MapZone(ZoneStatDto zone)
    {
        return new ZoneStat(
            zone.ZoneCode,
            zone.ZoneCode,
            zone.SuccessRate,
            zone.Attempts,
            zone.SuccessCount,
            zone.Outcomes.Select(outcome => new OutcomeCount(outcome.EventName, outcome.Count)).ToList());
    }

    private static ZoneStat MapTrigger(TriggerZoneStatDto zone)
    {
        return new ZoneStat(
            SpatialZoneVisuals.ToVisualTriggerKey(zone.TriggerCode),
            SpatialZoneVisuals.ToVisualTriggerKey(zone.TriggerCode),
            zone.SuccessRate,
            zone.Attempts,
            zone.SuccessCount,
            zone.Outcomes.Select(outcome => new OutcomeCount(outcome.EventName, outcome.Count)).ToList());
    }

    private IReadOnlyList<KpiTile> BuildMatchKpis()
    {
        return MatchKpiCatalog.BuildSummaryKpis(MatchSummary, SelectedMatch, []);
    }

    private IReadOnlyList<MetricPlotPoint> BuildMatchProfileSeries()
    {
        if (MatchSummary is null)
        {
            return [];
        }

        return
        [
            new MetricPlotPoint("Buts", MatchSummary.GoalCount + MatchSummary.PenaltyGoalCount),
            new MetricPlotPoint("Passes", MatchSummary.AssistCount),
            new MetricPlotPoint("Interceptions", MatchSummary.InterceptionCount),
            new MetricPlotPoint("Arrets", MatchSummary.SaveCount),
            new MetricPlotPoint("Pertes", MatchSummary.TurnoverCount),
            new MetricPlotPoint("Sanctions", MatchSummary.SanctionCount)
        ];
    }

    private IReadOnlyList<MetricPlotPoint> BuildMatchTeamComparisonSeries(string teamName)
    {
        if (SelectedMatch is null || MatchPlayers.Count == 0 || string.IsNullOrWhiteSpace(teamName))
        {
            return [];
        }

        var teamPlayers = MatchPlayers
            .Where(player => string.Equals(player.TeamName?.Trim(), teamName.Trim(), StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (teamPlayers.Count == 0)
        {
            return [];
        }

        var goals = teamPlayers.Sum(player => player.TotalGoals);
        var passes = teamPlayers.Sum(player => player.AssistCount);
        var defense = teamPlayers.Sum(player => player.InterceptionCount + player.SaveCount);
        var turnovers = teamPlayers.Sum(player => player.TurnoverCount);
        var volume = goals + passes + defense + turnovers;

        return
        [
            new MetricPlotPoint("Buts", goals),
            new MetricPlotPoint("Passes", passes),
            new MetricPlotPoint("Defense", defense),
            new MetricPlotPoint("Pertes", turnovers),
            new MetricPlotPoint("Volume", volume)
        ];
    }

