    private IReadOnlyList<MetricPlotPoint> BuildMatchPlayerImpactSeries()
    {
        return GetScopedMatchPlayers()
            .OrderByDescending(player => HandballKpiHelper.DirectContributions(player))
            .ThenBy(player => player.FullName)
            .Take(8)
            .Select(player => new MetricPlotPoint(player.FullName, HandballKpiHelper.DirectContributions(player)))
            .ToList();
    }

    private IReadOnlyList<PlayerGlobalStatsDto> GetFilteredMatchPlayers()
    {
        IEnumerable<PlayerGlobalStatsDto> filtered = GetScopedMatchPlayers();

        if (!string.IsNullOrWhiteSpace(MatchPlayerSearch))
        {
            var query = MatchPlayerSearch.Trim();
            filtered = filtered.Where(player =>
                TextSearchHelper.Contains(player.FullName, query)
                || TextSearchHelper.Contains(player.TeamName, query)
                || TextSearchHelper.Contains(player.PositionCode, query)
                || TextSearchHelper.Contains(player.PositionName, query));
        }

        filtered = MatchPlayerSort.Column switch
        {
            "name" => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.FullName)
                : filtered.OrderBy(item => item.FullName),
            "team" => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.TeamName)
                : filtered.OrderBy(item => item.TeamName),
            "position" => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.PositionCode ?? item.PositionName)
                : filtered.OrderBy(item => item.PositionCode ?? item.PositionName),
            "assists" => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.AssistCount)
                : filtered.OrderBy(item => item.AssistCount),
            "interceptions" => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.InterceptionCount)
                : filtered.OrderBy(item => item.InterceptionCount),
            "saves" => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.SaveCount)
                : filtered.OrderBy(item => item.SaveCount),
            "turnovers" => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.TurnoverCount)
                : filtered.OrderBy(item => item.TurnoverCount),
            "shot" => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.ShotSuccessRate)
                : filtered.OrderBy(item => item.ShotSuccessRate),
            _ => MatchPlayerSort.IsDescending
                ? filtered.OrderByDescending(item => item.TotalGoals)
                : filtered.OrderBy(item => item.TotalGoals)
        };

        return filtered.ToList();
    }

    private IEnumerable<PlayerGlobalStatsDto> GetScopedMatchPlayers()
    {
        if (SelectedMatch is null || string.Equals(MatchTeamScope, MatchTeamScopeBoth, StringComparison.OrdinalIgnoreCase))
        {
            return MatchPlayers;
        }

        var teamName = string.Equals(MatchTeamScope, MatchTeamScopeTeam1, StringComparison.OrdinalIgnoreCase)
            ? SelectedMatch.Team1Name
            : SelectedMatch.Team2Name;

        if (string.IsNullOrWhiteSpace(teamName))
        {
            return MatchPlayers;
        }

        return MatchPlayers.Where(player => string.Equals(player.TeamName?.Trim(), teamName.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private string MatchTeamScopeLabel => MatchTeamScope switch
    {
        MatchTeamScopeTeam1 => SelectedMatch?.Team1Name ?? "Equipe 1",
        MatchTeamScopeTeam2 => SelectedMatch?.Team2Name ?? "Equipe 2",
        _ => "Les deux equipes"
    };

    private bool IsTeamScopeActive(string scope) => string.Equals(MatchTeamScope, scope, StringComparison.OrdinalIgnoreCase);

    private bool IsPlayerInTeamScope(string? teamName)
    {
        if (SelectedMatch is null || string.Equals(MatchTeamScope, MatchTeamScopeBoth, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        var scopedTeamName = string.Equals(MatchTeamScope, MatchTeamScopeTeam1, StringComparison.OrdinalIgnoreCase)
            ? SelectedMatch.Team1Name
            : SelectedMatch.Team2Name;

        if (string.IsNullOrWhiteSpace(scopedTeamName) || string.IsNullOrWhiteSpace(teamName))
        {
            return true;
        }

        return string.Equals(teamName.Trim(), scopedTeamName.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private async Task SetMatchTeamScopeAsync(string scope)
    {
        MatchTeamScope = scope;

        if (ShowMatchAnalystPanels)
        {
            await EnsureMatchPlayersLoadedAsync();
        }

        if (ActiveSection == "zones")
        {
            await EnsureMatchSpatialLoadedAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void SetMatchPlayerSort(string column)
    {
        MatchPlayerSort = MatchPlayerSort.Toggle(column, column is "name" or "team" or "position" ? SortDirection.Asc : SortDirection.Desc);
    }

    private RenderFragment TableHeader(string column, string label, Action<string> onSort) => builder =>
    {
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "type", "button");
        builder.AddAttribute(2, "class", $"table-sort-button {(MatchPlayerSort.IsActive(column) ? "is-active" : string.Empty)}");
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => onSort(column)));
        builder.AddAttribute(4, "aria-label", MatchPlayerSort.SortButtonLabel(column, label));
        builder.AddAttribute(5, "aria-pressed", MatchPlayerSort.IsActive(column));
        builder.AddContent(6, label);

        var glyph = MatchPlayerSort.Glyph(column);
        if (!string.IsNullOrWhiteSpace(glyph))
        {
            builder.OpenElement(7, "span");
            builder.AddAttribute(8, "class", "sort-indicator");
            builder.AddAttribute(9, "aria-hidden", "true");
            builder.AddContent(10, glyph);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private async Task SyncSelectedMatchAsync()
    {
        if (!ShowMatchDetailView || !MatchIdFromQuery.HasValue)
        {
            SelectedMatchId = null;
            IsMatchDetailLoading = false;
            IsSpatialLoading = false;
            ClearSelectedMatchDetail();
            return;
        }

        if (SelectedMatchId != MatchIdFromQuery.Value || SelectedMatch is null || MatchSummary is null)
        {
            SelectedMatchId = MatchIdFromQuery.Value;
            MatchSpatial = null;
            ActiveZoneKey = null;
            SpatialFocusKey = null;
            IsSpatialLoading = false;
            ErrorMessage = null;
            BeginSelectedMatchLoad();
            await LoadSelectedMatchAsync(SelectedMatchLoadToken, replaceCurrentSelection: true);
        }
    }

    private IReadOnlyList<MatchListItemDto> GetFilteredMatches()
    {
        var scopedMatches = MatchFilterCatalog.ApplySeasonAndDay(MatchList, Season, Day);

        if (string.IsNullOrWhiteSpace(MatchSearch))
        {
            return scopedMatches;
        }

        var query = MatchSearch.Trim();

        return scopedMatches
            .Where(match =>
                TextSearchHelper.Contains(match.Team1Name, query)
                || TextSearchHelper.Contains(match.Team2Name, query)
                || TextSearchHelper.Contains(match.CompetitionName, query)
                || TextSearchHelper.Contains(match.Season, query)
                || TextSearchHelper.Contains(match.Day, query)
                || TextSearchHelper.Contains(MatchFilterCatalog.FormatSeasonDay(match), query))
            .ToList();
    }

    private static string GetToneClass(string tone)
    {
        return tone?.ToLowerInvariant() switch
        {
            "positive" => "is-positive",
            "warning" => "is-warning",
            _ => string.Empty
        };
    }

    private static string FormatRate(double value) => value.ToString("0.#");

