@page "/matches"
@inject ReferenceDataService ReferenceDataService
@inject MatchesApiClient MatchesApiClient
@inject MatchEventsApiClient MatchEventsApiClient
@inject StatsApiClient StatsApiClient
@inject IApiAuthService AuthService
@inject AnalysisScopeService ScopeService
@implements IDisposable

<PageTitle>Games</PageTitle>

<div class="games-workspace" data-workspace="games">
    @if (!AuthService.Session.IsAuthenticated)
    {
        <AccessRequiredCard Message="Connectez-vous pour ouvrir les rencontres, les resumes et la lecture spatiale des matchs." />
    }
    else
    {
        <AudienceLensSelector Kicker="Lecture du match"
                              Title="Un même match, trois niveaux d'analyse"
                              Subtitle="Le mode choisi ajuste les indicateurs, les scénarios et la densité des panneaux de détail."
                              Value="@ActiveLens"
                              ValueChanged="SetActiveLens" />

        <section class="directory-command @(IsBusy ? "is-loading" : string.Empty)">
            <div class="panel-head panel-head-wrap">
                <div>
                    <p class="section-kicker">Game directory</p>
                    <h3>@(ShowMatchDetailView ? "Contexte de la rencontre" : "Trouver une rencontre")</h3>
                    <p class="page-subtitle">Le scope, la recherche et le retour a la liste restent memorises.</p>
                </div>

                <div class="toolbar">
                    @if (ShowMatchDetailView)
                    {
                        <a class="ghost-button filter-ghost" href="/matches">Retour aux cartes</a>
                    }
                    else
                    {
                        <button type="button" class="ghost-button filter-ghost" @onclick="ResetAsync" disabled="@IsBusy">Reinitialiser</button>
                    }
                </div>
            </div>

            @if (!ShowMatchDetailView)
            {
                <details class="filter-drawer" open>
                    <summary>
                        <div>
                            <strong>Filtres</strong>
                        </div>
                    </summary>

                    <div class="filter-drawer-body">
                        <div class="page-filters">
                            <label class="filter-field">
                                <span>Competition</span>
                                <select @bind="CompetitionId" @bind:after="OnScopeSelectionChangedAsync">
                                    <option value="">Toutes</option>
                                    @foreach (var competition in AvailableCompetitions)
                                    {
                                        <option value="@competition.CompetitionId">@competition.CompetitionName</option>
                                    }
                                </select>
                            </label>

                            <label class="filter-field">
                                <span>Equipe</span>
                                <select @bind="TeamId" @bind:after="OnScopeSelectionChangedAsync">
                                    <option value="">Toutes</option>
                                    @foreach (var team in AvailableTeams)
                                    {
                                        <option value="@team.TeamId">@team.TeamName</option>
                                    }
                                </select>
                            </label>

                            <label class="filter-field">
                                <span>Recherche match</span>
                                <input value="@MatchSearch" @oninput="OnMatchSearchChangedAsync" placeholder="Equipe, adversaire ou competition" />
                            </label>

                            <label class="filter-field">
                                <span>Saison</span>
                                <select value="@Season" @onchange="OnSeasonChangedAsync">
                                    <option value="">Toutes</option>
                                    @foreach (var season in SeasonOptions)
                                    {
                                        <option value="@season">@season</option>
                                    }
                                </select>
                            </label>

                            <label class="filter-field">
                                <span>Journee</span>
                                <select value="@Day" @onchange="OnDayChangedAsync">
                                    <option value="">Toutes</option>
                                    @foreach (var day in DayOptions)
                                    {
                                        <option value="@day">@day</option>
                                    }
                                </select>
                            </label>
                        </div>
                    </div>
                </details>
            }

        </section>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <StateCard Kicker="Erreur"
                       Title="Impossible de charger les matchs"
                       Message="@ErrorMessage"
                       Tone="error" />
        }
        else if (IsBusy && !ShowMatchDetailView && FilteredMatchList.Count == 0)
        {
            <StateCard Kicker="Chargement"
                       Title="Mise a jour des matchs"
                       Message="La selection, les filtres et les cartes se recalculent."
                       Tone="loading" />
        }
        else
        {
            <section class="workspace-grid workspace-grid-single">
                @if (IsBusy)
                {
                    <PageLoader Kicker="Chargement"
                                Title="Actualisation des matchs"
                                Message="La liste et le detail du match se recalculent." />
                }

                @if (!ShowMatchDetailView)
                {
                <article class="game-directory">
                            <div class="panel-head">
                                <div>
                                    <h3>@FilteredMatchList.Count matchs</h3>
                                </div>
                            </div>

                    @if (FilteredMatchList.Count == 0)
                    {
                        <StateCard Kicker="Aucun match"
                                   Title="Le filtre courant ne retourne aucune rencontre"
                                   Message="Essayez une autre compétition, une autre équipe ou un autre jour."
                                   Tone="empty"
                                   CssClass="empty-card-inline" />
                    }
                    else
                    {
                        <div class="match-mosaic">
                            @foreach (var match in FilteredMatchList)
                            {
                                <MatchCard @key="match.MatchId"
                                           Title="@($"{match.Team1Name ?? "Equipe A"} vs {match.Team2Name ?? "Equipe B"}")"
                                           Score="@($"{match.Team1Score ?? 0} - {match.Team2Score ?? 0}")"
                                           Meta="@(match.CompetitionName ?? "Competition")"
                                           SecondaryMeta="@MatchFilterCatalog.FormatSeasonDay(match)"
                                           DetailsHref="@($"/matches?matchId={match.MatchId}")"
                                           DetailsLabel="Voir plus" />
                            }
                        </div>
                    }
                </article>
                }

                @if (ShowMatchDetailView)
                {
                <article class="game-room">
                    @if (IsMatchDetailLoading)
                    {
                        <StateCard Kicker="Chargement"
                                   Title="Rechargement de la rencontre"
                                   Message="Le résumé, la timeline et les cartes se mettent à jour pour le match sélectionné."
                                   Tone="loading" />
                    }
                    else if (SelectedMatch is null || MatchSummary is null)
                    {
                        <StateCard Kicker="Aucun match"
                                   Title="Choisissez une rencontre pour afficher son résumé"
                                   Message="Le détail, la carte et l’effectif s’ouvrent après sélection."
                                   Tone="empty"
                                   CssClass="empty-card-inline" />
                    }
                    else
                    {
                        <header class="game-scoreboard">
                            <div class="game-scoreboard__team">
                                <span>Home</span>
                                <strong>@(SelectedMatch.Team1Name ?? "Equipe A")</strong>
                            </div>
                            <div class="game-scoreboard__score">
                                <span>@(SelectedMatch.CompetitionName ?? "Competition") · @MatchFilterCatalog.FormatSeasonDay(SelectedMatch)</span>
                                <strong>@(SelectedMatch.Team1Score ?? 0)<i>:</i>@(SelectedMatch.Team2Score ?? 0)</strong>
                            </div>
                            <div class="game-scoreboard__team game-scoreboard__team--away">
                                <span>Away</span>
                                <strong>@(SelectedMatch.Team2Name ?? "Equipe B")</strong>
                            </div>
                        </header>

                        <div class="match-scope-toolbar">
                            <div class="match-scope-copy">
                                <p class="section-kicker">Lecture équipe</p>
                                <span>Basculer la vue sur une seule équipe ou garder le match complet.</span>
                            </div>

                            <div class="match-scope-toggle" role="group" aria-label="Filtre equipe">
                                <button type="button"
                                        class="match-scope-button @(IsTeamScopeActive(MatchTeamScopeBoth) ? "is-active" : string.Empty)"
                                        @onclick="() => SetMatchTeamScopeAsync(MatchTeamScopeBoth)"
                                        disabled="@IsSpatialLoading">
                                    Les deux
                                </button>
                                <button type="button"
                                        class="match-scope-button @(IsTeamScopeActive(MatchTeamScopeTeam1) ? "is-active" : string.Empty)"
                                        @onclick="() => SetMatchTeamScopeAsync(MatchTeamScopeTeam1)"
                                        disabled="@IsSpatialLoading">
                                    @(SelectedMatch.Team1Name ?? "Equipe 1")
                                </button>
                                <button type="button"
                                        class="match-scope-button @(IsTeamScopeActive(MatchTeamScopeTeam2) ? "is-active" : string.Empty)"
                                        @onclick="() => SetMatchTeamScopeAsync(MatchTeamScopeTeam2)"
                                        disabled="@IsSpatialLoading">
                                    @(SelectedMatch.Team2Name ?? "Equipe 2")
                                </button>
                            </div>
                        </div>

                        <div class="scene-switcher" role="tablist" aria-label="Scenes du match">
                            <button type="button" class="tab-button @(ActiveSection == "summary" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("summary")'>Story</button>
                            <button type="button" class="tab-button @(ActiveSection == "zones" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("zones")'>Court</button>
                            <button type="button" class="tab-button @(ActiveSection == "players" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("players")'>Players</button>
                        </div>

                        @if (ActiveSection == "summary")
                        {
                            <div class="stats-grid">
                                <div class="mini-card"><span>Evenements</span><strong>@MatchSummary.EventCount</strong></div>
                                <div class="mini-card"><span>Buts</span><strong>@(MatchSummary.GoalCount + MatchSummary.PenaltyGoalCount)</strong></div>
                                <div class="mini-card"><span>Passes</span><strong>@MatchSummary.AssistCount</strong></div>
                                <div class="mini-card"><span>Interceptions</span><strong>@MatchSummary.InterceptionCount</strong></div>
                                <div class="mini-card"><span>Arrets</span><strong>@MatchSummary.SaveCount</strong></div>
                                <div class="mini-card"><span>Pertes</span><strong>@MatchSummary.TurnoverCount</strong></div>
                                <div class="mini-card"><span>Sanctions</span><strong>@MatchSummary.SanctionCount</strong></div>
                            </div>

                            @if (ShowMatchSummaryKpis)
                            {
                                <KpiTileGrid Items="@MatchKpis" />
                            }

                            @if (SelectedMatchTimeline.Count >= 2)
                            {
                                <section class="page-panel">
                                    <div class="panel-head panel-head-wrap">
                                        <div>
                                            <p class="section-kicker">Lecture de score</p>
                                        <h4>Évolution des deux équipes pendant le match</h4>
                                            <p class="page-subtitle">Une lecture directe du scenario, des runs et des bascules de leader.</p>
                                        </div>

                                        <span class="hero-badge">Score final @((SelectedMatch.Team1Score ?? 0) + " - " + (SelectedMatch.Team2Score ?? 0))</span>
                                    </div>

                                        <ApexChart @key="SelectedMatchLoadToken" TItem="ScoreTimelinePoint" Title="Evolution du score" Height="320" Options="@GetScoreTimelineChartOptions()">
                                            @if (ShowTeam1TimelineSeries)
                                            {
                                                <ApexPointSeries TItem="ScoreTimelinePoint"
                                                                 Items="@SelectedMatchTimeline"
                                                                 Name="@(SelectedMatch.Team1Name ?? "Equipe 1")"
                                                                 SeriesType="SeriesType.Line"
                                                                 XValue="point => point.Label"
                                                                 YValue="point => (decimal?)point.Team1Score" />
                                            }
                                            @if (ShowTeam2TimelineSeries)
                                            {
                                                <ApexPointSeries TItem="ScoreTimelinePoint"
                                                                 Items="@SelectedMatchTimeline"
                                                                 Name="@(SelectedMatch.Team2Name ?? "Equipe 2")"
                                                                 SeriesType="SeriesType.Line"
                                                                 XValue="point => point.Label"
                                                                 YValue="point => (decimal?)point.Team2Score" />
                                            }
                                        </ApexChart>

                                    @if (ShowMatchScenarioInsights)
                                    {
                                        <div class="badge-row timeline-insight-grid">
                                            @foreach (var insight in TimelineInsights)
                                            {
                                                <div class="mini-card timeline-insight-card">
                                                    <span>@insight.Label</span>
                                                    <strong>@insight.Value</strong>
                                                    <p class="tiny-note">@insight.Detail</p>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (ShowMatchTimelineKpis)
                                    {
                                        <KpiTileGrid Items="@TimelineKpis" />
                                    }

                                    @if (TimelineMoments.Count > 0)
                                    {
                                        <section class="timeline-moments">
                                            <div class="panel-head">
                                                <div>
                                                    <p class="section-kicker">Temps forts</p>
                                                    <h4>Moments qui racontent le scenario</h4>
                                                </div>
                                            </div>

                                            <div class="timeline-moment-list">
                                                @foreach (var moment in TimelineMoments)
                                                {
                                                    <article class="timeline-moment-card @GetToneClass(moment.Tone)">
                                                        <div class="timeline-moment-meta">
                                                            <span>@moment.ClockLabel</span>
                                                            <strong>@moment.ScoreLabel</strong>
                                                        </div>
                                                        <div class="timeline-moment-copy">
                                                            <h5>@moment.Title</h5>
                                                            <p>@moment.Detail</p>
                                                        </div>
                                                    </article>
                                                }
                                            </div>
                                        </section>
                                    }
                                </section>
                            }

                            @if (ShowMatchSummaryCharts)
                            {
                                <section class="page-panel matches-comparison-panel">
                                    <div class="panel-head panel-head-wrap">
                                        <div>
                                            <p class="section-kicker">Comparaison d'equipe</p>
                                            <h4>Actions majeures par camp</h4>
                                            <p class="page-subtitle">Une lecture horizontale pour comparer buts, passes, defense, pertes et sanctions des deux equipes.</p>
                                        </div>

                                        <span class="hero-badge">@FinalScoreLabel</span>
                                    </div>

                                    <div class="comparison-story">
                                        <article class="comparison-card comparison-story-card">
                                            <span>Camp 1</span>
                                            <strong>@(SelectedMatch.Team1Name ?? "Equipe 1")</strong>
                                            <p>@((int)Math.Round(MatchTeam1ComparisonSeries.Sum(point => point.Value))) points d'activite</p>
                                        </article>

                                        <article class="comparison-card comparison-story-card comparison-story-card-center">
                                            <span>Lecture commune</span>
                                            <strong>@FinalScoreLabel</strong>
                                            <p>@MatchFilterCatalog.FormatSeasonDay(SelectedMatch)</p>
                                        </article>

                                        <article class="comparison-card comparison-story-card">
                                            <span>Camp 2</span>
                                            <strong>@(SelectedMatch.Team2Name ?? "Equipe 2")</strong>
                                            <p>@((int)Math.Round(MatchTeam2ComparisonSeries.Sum(point => point.Value))) points d'activite</p>
                                        </article>
                                    </div>

                                    <ApexChart @key="SelectedMatchLoadToken" TItem="MetricPlotPoint" Title="Comparaison d'equipe" Height="340" Options="@GetMatchComparisonChartOptions()">
                                        <ApexPointSeries TItem="MetricPlotPoint"
                                                         Items="@MatchTeam1ComparisonSeries"
                                                         Name="@(SelectedMatch?.Team1Name ?? "Equipe 1")"
                                                         SeriesType="SeriesType.Bar"
                                                         XValue="point => point.Label"
                                                         YValue="point => (decimal?)point.Value" />
                                        <ApexPointSeries TItem="MetricPlotPoint"
                                                         Items="@MatchTeam2ComparisonSeries"
                                                         Name="@(SelectedMatch?.Team2Name ?? "Equipe 2")"
                                                         SeriesType="SeriesType.Bar"
                                                         XValue="point => point.Label"
                                                         YValue="point => (decimal?)point.Value" />
                                    </ApexChart>
                                </section>
                            }

                            @if (ShowMatchAnalystPanels)
                            {
                                <div class="dual-grid">
                                    <section class="page-panel">
                                        <p class="section-kicker">Profil du match</p>
                                        <h4>Volume des actions majeures</h4>
                                        <ApexChart @key="SelectedMatchLoadToken" TItem="MetricPlotPoint" Title="Profil du match" Height="300" Options="@GetMatchProfileChartOptions()">
                                            <ApexPointSeries TItem="MetricPlotPoint"
                                                             Items="@MatchProfileSeries"
                                                             Name="Volume"
                                                             SeriesType="SeriesType.Bar"
                                                             XValue="point => point.Label"
                                                             YValue="point => (decimal?)point.Value" />
                                        </ApexChart>
                                    </section>

                                    <section class="page-panel">
                                        <p class="section-kicker">Joueuses decisives</p>
                                        <h4>Actions directes sur la rencontre</h4>
                                        <ApexChart @key="SelectedMatchLoadToken" TItem="MetricPlotPoint" Title="Implication decisive" Height="300" Options="@GetMatchImpactChartOptions()">
                                            <ApexPointSeries TItem="MetricPlotPoint"
                                                             Items="@MatchPlayerImpactSeries"
                                                             Name="Buts + passes"
                                                             SeriesType="SeriesType.Bar"
                                                             XValue="point => point.Label"
                                                             YValue="point => (decimal?)point.Value" />
                                        </ApexChart>
                                    </section>
                                </div>
                            }

                            <section class="page-panel">
                                <p class="section-kicker">Top scoreuses</p>
                                <h4>Production sur le match - @MatchTeamScopeLabel</h4>
                                <div class="list-stack">
                                    @foreach (var scorer in (MatchSummary.TopScorers?.Where(scorer => IsPlayerInTeamScope(scorer.TeamName)) ?? []))
                                    {
                                        <div class="list-item">
                                            <div class="key-metric">
                                                <strong>@scorer.FullName</strong>
                                                <span>@scorer.Value buts</span>
                                            </div>
                                            <p class="tiny-note">@scorer.TeamName</p>
                                        </div>
                                    }
                                </div>
                            </section>
                        }
                        else if (ActiveSection == "zones")
                        {
                            <ErrorBoundary>
                                <ChildContent>
                                    @if (IsSpatialLoading && MatchSpatial is null)
                                    {
                                        <StateCard Kicker="Chargement"
                                                   Title="Rechargement spatial"
                                                   Message=$"La carte but et déclenchements se recalcule pour {MatchSpatialLabel}."
                                                   Tone="loading" />
                                    }
                                    else if (MatchSpatial is null)
                                    {
                                        <StateCard Kicker="Aucune carte"
                                                   Title="La lecture but et déclenchements n’a pas encore été chargée pour ce scope"
                                                   Message="Essayez un autre match ou changez le périmètre d’équipe."
                                                   Tone="empty"
                                                   CssClass="empty-card-inline" />
                                    }
                                    else
                                    {
                                        @if (string.Equals(MatchTeamScope, MatchTeamScopeBoth, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <p class="tiny-note spatial-scope-note">
                                                La lecture spatiale s'ouvre sur @MatchSpatialLabel. Utilisez les boutons d'equipe pour basculer vers l'autre camp.
                                            </p>
                                        }

                                        @if (HasSpatialFocus)
                                        {
                                            <div class="match-scope-toolbar spatial-focus-toolbar">
                                                <div class="match-scope-copy">
                                                    <p class="section-kicker">Lecture ciblee</p>
                                                    <span>Zones liees a @SpatialFocusKey</span>
                                                </div>

                                                <button type="button"
                                                        class="match-scope-button"
                                                        @onclick="ResetSpatialFocusAsync"
                                                        disabled="@IsSpatialLoading">
                                                    Voir toutes les zones
                                                </button>
                                            </div>
                                        }

                                        <div class="dual-grid">
                                            <section class="page-panel @(IsSpatialLoading ? "is-loading" : string.Empty)">
                                                <p class="section-kicker">Spatial match</p>
                                                <h4>But et declenchements</h4>
                                                <GoalKpi GoalZones="@GoalZones"
                                                         TriggerZones="@TriggerZones"
                                                         IsGoalkeeper="false"
                                                         ActiveZoneKey="@ActiveZoneKey"
                                                         OnZoneSelected="HandleZoneSelectionAsync"
                                                         HideZeroZones="@HasSpatialFocus"
                                                         IsLoading="@IsSpatialLoading" />
                                            </section>

                                            <section class="page-panel">
                                                <div class="panel-head">
                                                    <div>
                                                        <p class="section-kicker">Zone active</p>
                                                        <h4>@(CurrentZone?.Label ?? "Selectionnez une zone")</h4>
                                                    </div>
                                                    @if (IsSpatialLoading)
                                                    {
                                                        <span class="hero-badge">Chargement spatial</span>
                                                    }
                                                    else if (CurrentZone is not null)
                                                    {
                                                        <span class="hero-badge">@FormatRate(CurrentZone.Rate)%</span>
                                                    }
                                                </div>

                                                @if (CurrentZone is not null)
                                                {
                                                    <div class="badge-row">
                                                        <div class="mini-card"><span>Volume</span><strong>@CurrentZone.Attempts</strong></div>
                                                        <div class="mini-card"><span>Succes</span><strong>@CurrentZone.Successes</strong></div>
                                                        <div class="mini-card"><span>Echecs</span><strong>@CurrentZone.Failures</strong></div>
                                                    </div>

                                                    <div class="list-stack">
                                                        @foreach (var outcome in CurrentZone.Outcomes)
                                                        {
                                                            <div class="list-item">
                                                                <div class="key-metric">
                                                                    <strong>@outcome.Label</strong>
                                                                    <span>@outcome.Count</span>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </section>
                                        </div>
                                    }
                                </ChildContent>
                                <ErrorContent Context="zoneError">
                                    <StateCard Kicker="Erreur"
                                               Title="La lecture spatiale n’a pas pu se rendre"
                                               Message="Une erreur de rendu a été interceptée dans la carte des zones. Vous pouvez recharger la fiche match ou changer de camp pour réessayer."
                                               Tone="error"
                                               CssClass="empty-card-inline" />
                                </ErrorContent>
                            </ErrorBoundary>
                        }
                        else
                        {
                            <section class="page-panel">
                                <div class="panel-head">
                                    <div>
                                        <p class="section-kicker">Joueuses du match</p>
                                        <h4>@FilteredMatchPlayers.Count lignes retournees</h4>
                                    </div>
                                </div>

                                <div class="table-toolbar">
                                    <label class="filter-field table-search">
                                        <span>Filtrer le tableau</span>
                                <input value="@MatchPlayerSearch" @oninput="OnMatchPlayerSearchChanged" placeholder="Joueuse, équipe ou poste" />
                                    </label>
                                </div>

                                @{
                                    var matchPlayerRows = FilteredMatchPlayers.ToArray();
                                }

                                <div class="table-wrap">
                                    <table class="stat-table">
                                        <thead>
                                            <tr>
                                                <th>@TableHeader("name", "Joueuse", SetMatchPlayerSort)</th>
                                                <th>@TableHeader("team", "Equipe", SetMatchPlayerSort)</th>
                                                <th>@TableHeader("position", "Poste", SetMatchPlayerSort)</th>
                                                <th>@TableHeader("goals", "Buts", SetMatchPlayerSort)</th>
                                                <th>@TableHeader("assists", "Passes", SetMatchPlayerSort)</th>
                                                <th>@TableHeader("interceptions", "Interceptions", SetMatchPlayerSort)</th>
                                                <th>@TableHeader("saves", "Arrets", SetMatchPlayerSort)</th>
                                                <th>@TableHeader("turnovers", "Pertes", SetMatchPlayerSort)</th>
                                                <th>@TableHeader("shot", "Taux tir", SetMatchPlayerSort)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var player in matchPlayerRows)
                                            {
                                                <tr>
                                                    <td>@player.FullName</td>
                                                    <td>@player.TeamName</td>
                                                    <td>@(player.PositionCode ?? player.PositionName ?? "-")</td>
                                                    <td class="@TableHeatToneHelper.HeatClass(matchPlayerRows, row => (double?)row.TotalGoals, player)">@player.TotalGoals</td>
                                                    <td class="@TableHeatToneHelper.HeatClass(matchPlayerRows, row => (double?)row.AssistCount, player)">@player.AssistCount</td>
                                                    <td class="@TableHeatToneHelper.HeatClass(matchPlayerRows, row => (double?)row.InterceptionCount, player)">@player.InterceptionCount</td>
                                                    <td class="@TableHeatToneHelper.HeatClass(matchPlayerRows, row => (double?)row.SaveCount, player)">@player.SaveCount</td>
                                                    <td class="@TableHeatToneHelper.HeatClass(matchPlayerRows, row => (double?)row.TurnoverCount, player, higherIsBetter: false)">@player.TurnoverCount</td>
                                                    <td class="@TableHeatToneHelper.HeatClass(matchPlayerRows, row => (double?)row.ShotSuccessRate, player)">@FormatRate(player.ShotSuccessRate)%</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </section>
                        }
                    }
                </article>
                }
            </section>
        }
    }
</div>

@code {
    private const string MatchTeamScopeBoth = "both";
    private const string MatchTeamScopeTeam1 = "team1";
    private const string MatchTeamScopeTeam2 = "team2";

    private AnalyticsReferenceData ReferenceData { get; set; } = AnalyticsReferenceData.Empty;
    private IReadOnlyList<MatchListItemDto> MatchList { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> CompetitionOptionMatches { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> TeamOptionMatches { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> ScopedMatches { get; set; } = [];
    private IReadOnlyList<PlayerGlobalStatsDto> MatchPlayers { get; set; } = [];
    private IReadOnlyList<ScoreTimelinePoint> SelectedMatchTimeline { get; set; } = [];
    private MatchListItemDto? SelectedMatch { get; set; }
    private MatchSummaryDto? MatchSummary { get; set; }
