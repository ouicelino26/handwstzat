@page "/demo"
@layout PublicLayout
@inject NavigationManager Navigation

<PageTitle>Aperçu</PageTitle>

<div class="demo-shell">
    <section class="page-hero demo-hero">
        <div>
            <p class="section-kicker">Aperçu produit</p>
            <h2>Une démonstration claire avant l’accès live.</h2>
            <p class="page-subtitle">
                Cette page présente la logique d’interface, la lecture globale, le focus joueuse
                et les cartes spatiales sans mélanger cela avec la session utilisateur.
            </p>
        </div>

        <div class="toolbar">
            <button type="button" class="ghost-button" @onclick="GoToLogin">Connexion live</button>
            <button type="button" class="primary-button" @onclick="GoToLogin">Accéder à l’interface</button>
        </div>
    </section>

    <section class="stats-grid">
        <div class="mini-card"><span>Joueuses</span><strong>@Snapshot.Overview.PlayerCount</strong></div>
        <div class="mini-card"><span>Equipes</span><strong>@Snapshot.Overview.TeamCount</strong></div>
        <div class="mini-card"><span>Matchs</span><strong>@Snapshot.Overview.MatchCount</strong></div>
        <div class="mini-card"><span>Buts</span><strong>@Snapshot.Overview.GoalCount</strong></div>
    </section>

    <section class="dual-grid">
        <article class="page-panel">
            <div class="panel-head">
                <div>
                    <p class="section-kicker">Ce que montre la démo</p>
                    <h3>Lecture ligue et classement</h3>
                </div>
            </div>

            <div class="compact-list">
                @foreach (var item in Snapshot.TopScorers.Take(5))
                {
                    <div class="outcome-row">
                        <span>@item.PlayerName</span>
                        <strong>@item.ValueLabel</strong>
                    </div>
                }
            </div>
        </article>

        <article class="page-panel">
            <div class="panel-head">
                <div>
                <p class="section-kicker">Focus joueuse</p>
                <h3>@Snapshot.Spotlight.FullName</h3>
                <p class="page-subtitle">@Snapshot.Spotlight.TeamName - @Snapshot.Spotlight.PositionName</p>
                </div>
            </div>

            <div class="badge-row">
                <div class="mini-card"><span>Buts</span><strong>@Snapshot.Spotlight.TotalGoals</strong></div>
                <div class="mini-card"><span>Passes</span><strong>@Snapshot.Spotlight.Assists</strong></div>
                <div class="mini-card"><span>Taux tir</span><strong>@FormatRate(Snapshot.Spotlight.ShootingRate)%</strong></div>
                <div class="mini-card"><span>Matchs</span><strong>@Snapshot.Spotlight.MatchesPlayed</strong></div>
            </div>
        </article>
    </section>

    <section class="dual-grid">
        <article class="page-panel">
            <div class="panel-head">
                <div>
                    <p class="section-kicker">Carte spatiale</p>
                    <h3>But et declenchements</h3>
                </div>
            </div>

            <GoalKpi GoalZones="@Snapshot.Spotlight.GoalZones"
                     TriggerZones="@Snapshot.Spotlight.TriggerZones"
                     IsGoalkeeper="@Snapshot.Spotlight.IsGoalkeeper"
                     ActiveZoneKey="@ActiveZoneKey"
                     OnZoneSelected="HandleZoneSelectionAsync" />
        </article>

        <article class="page-panel">
            <div class="panel-head">
                <div>
                    <p class="section-kicker">Lecture de zone</p>
                    <h3>@(CurrentZone?.Label ?? "Selectionnez une zone")</h3>
                </div>
                @if (CurrentZone is not null)
                {
                    <span class="panel-pill">@FormatRate(CurrentZone.Rate)%</span>
                }
            </div>

            @if (CurrentZone is not null)
            {
                <div class="badge-row">
                    <div class="mini-card"><span>Volume</span><strong>@CurrentZone.Attempts</strong></div>
                    <div class="mini-card"><span>Succes</span><strong>@CurrentZone.Successes</strong></div>
                    <div class="mini-card"><span>Echecs</span><strong>@CurrentZone.Failures</strong></div>
                </div>

                <div class="compact-list">
                    @foreach (var outcome in CurrentZone.Outcomes)
                    {
                        <div class="outcome-row">
                            <span>@outcome.Label</span>
                            <strong>@outcome.Count</strong>
                        </div>
                    }
                </div>
            }
        </article>
    </section>
</div>

@code {
    private DashboardSnapshot Snapshot { get; } = DemoDataFactory.Create(null);

    private string? ActiveZoneKey { get; set; }

    private ZoneStat? CurrentZone => Snapshot.Spotlight.GoalZones.Concat(Snapshot.Spotlight.TriggerZones)
        .FirstOrDefault(zone => zone.Key == ActiveZoneKey)
        ?? Snapshot.Spotlight.GoalZones.FirstOrDefault(zone => zone.Attempts > 0)
        ?? Snapshot.Spotlight.TriggerZones.FirstOrDefault(zone => zone.Attempts > 0)
        ?? Snapshot.Spotlight.GoalZones.FirstOrDefault()
        ?? Snapshot.Spotlight.TriggerZones.FirstOrDefault();

    protected override void OnInitialized()
    {
        ActiveZoneKey = Snapshot.Spotlight.GoalZones.FirstOrDefault(zone => zone.Attempts > 0)?.Key
            ?? Snapshot.Spotlight.TriggerZones.FirstOrDefault(zone => zone.Attempts > 0)?.Key;
    }

    private Task HandleZoneSelectionAsync(string zoneKey)
    {
        ActiveZoneKey = zoneKey;
        return InvokeAsync(StateHasChanged);
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/");
    }

    private static string FormatRate(double value) => value.ToString("0.#");
}
