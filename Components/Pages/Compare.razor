                HandballKpiHelper.FormatPerMatchContext(player.IsGoalkeeper ? goalkeeper?.TirsSubis ?? 0 : shotAttempts, matches, player.IsGoalkeeper ? "tirs subis" : "tirs engages")),
            new KpiTile(
                player.IsGoalkeeper ? "Buts pris / match" : "Dechet tir / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(player.IsGoalkeeper ? goalkeeperConcededGoals : shotWaste, matches)),
                player.IsGoalkeeper ? "Volume de buts encaisses rapporte au temps de jeu." : "Tirs rates, tirs contres et penalties manques.",
                player.IsGoalkeeper
                    ? HandballKpiHelper.GoalkeeperConcededGoalsTone(HandballKpiHelper.PerMatch(goalkeeperConcededGoals, matches))
                    : HandballKpiHelper.FieldWasteTone(HandballKpiHelper.PerMatch(shotWaste, matches)),
                HandballKpiHelper.FormatPerMatchContext(player.IsGoalkeeper ? goalkeeperConcededGoals : shotWaste, matches, player.IsGoalkeeper ? "buts encaisses" : "dechets tir")),
            new KpiTile(
                "Pertes techniques / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(technicalLosses, matches)),
                "Mauvaises passes, pertes de balle, fautes techniques et passages en force.",
                player.IsGoalkeeper
                    ? HandballKpiHelper.KeeperWasteTone(HandballKpiHelper.PerMatch(technicalLosses, matches))
                    : HandballKpiHelper.FieldWasteTone(HandballKpiHelper.PerMatch(technicalLosses, matches)),
                HandballKpiHelper.FormatPerMatchContext(technicalLosses, matches, "pertes techniques")),
            new KpiTile(
                "Sanctions / match",
                HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(technical?.Sanctions ?? HandballKpiHelper.TotalSanctions(sanctions), matches)),
                "Charge disciplinaire individuelle.",
                HandballKpiHelper.SanctionsTone(HandballKpiHelper.PerMatch(technical?.Sanctions ?? HandballKpiHelper.TotalSanctions(sanctions), matches), player.IsGoalkeeper),
                HandballKpiHelper.FormatPerMatchContext(technical?.Sanctions ?? HandballKpiHelper.TotalSanctions(sanctions), matches, "sanctions"))
        ];
    }

    private PlayerTechnicalStatsDto? GetTechnical(int playerId) => Response?.Technical.FirstOrDefault(item => item.PlayerId == playerId);
    private PlayerOffenseStatsDto? GetOffense(int playerId) => Response?.Offense.FirstOrDefault(item => item.PlayerId == playerId);
    private PlayerDefenseStatsDto? GetDefense(int playerId) => Response?.Defense.FirstOrDefault(item => item.PlayerId == playerId);
    private PlayerPassingStatsDto? GetPassing(int playerId) => Response?.Passing.FirstOrDefault(item => item.PlayerId == playerId);
    private PlayerSanctionStatsDto? GetSanctions(int playerId) => Response?.Sanctions.FirstOrDefault(item => item.PlayerId == playerId);
    private PlayerGoalkeeperStatsDto? GetGoalkeeper(int playerId) => Response?.Goalkeeper.FirstOrDefault(item => item.PlayerId == playerId);
    private static string FormatRate(double value) => value.ToString("0.#");
    private static string FormatNullableRate(double? value) => value.HasValue ? $"{value.Value:0.#}%" : "-";

    private sealed record RadarMetrics(
        double GoalsPerMatch,
        double AssistsPerMatch,
        double DefensePerMatch,
        double EfficiencyRate,
        double SecurityRate,
        double VolumePerMatch);
}
