    private IReadOnlyList<MetricPlotPoint> GetComparisonRadarSeries(PlayerGlobalStatsDto player)
    {
        if (Response is null || Response.Players.Count == 0)
        {
            return [];
        }

        var metrics = Response.Players.Select(BuildComparisonRadarMetrics).ToList();
        var playerMetrics = BuildComparisonRadarMetrics(player);

        return
        [
            new MetricPlotPoint("Buts", NormalizeRadarValue(playerMetrics.GoalsPerMatch, metrics.Max(item => item.GoalsPerMatch))),
            new MetricPlotPoint("Passes", NormalizeRadarValue(playerMetrics.AssistsPerMatch, metrics.Max(item => item.AssistsPerMatch))),
            new MetricPlotPoint("Defense", NormalizeRadarValue(playerMetrics.DefensePerMatch, metrics.Max(item => item.DefensePerMatch))),
            new MetricPlotPoint("Efficacite", NormalizeRadarValue(playerMetrics.EfficiencyRate, metrics.Max(item => item.EfficiencyRate))),
            new MetricPlotPoint("Securite", NormalizeRadarValue(playerMetrics.SecurityRate, metrics.Max(item => item.SecurityRate))),
            new MetricPlotPoint("Volume", NormalizeRadarValue(playerMetrics.VolumePerMatch, metrics.Max(item => item.VolumePerMatch)))
        ];
    }

    private RadarMetrics BuildComparisonRadarMetrics(PlayerGlobalStatsDto player)
    {
        var offense = GetOffense(player.PlayerId);
        var defense = GetDefense(player.PlayerId);
        var passing = GetPassing(player.PlayerId);
        var sanctions = GetSanctions(player.PlayerId);
        var goalkeeper = GetGoalkeeper(player.PlayerId);
        var technical = GetTechnical(player.PlayerId);
        var matches = Math.Max(player.MatchesPlayed, 1);

        var goalsPerMatch = HandballKpiHelper.PerMatch(player.TotalGoals, matches);
        var assistsPerMatch = HandballKpiHelper.PerMatch(player.AssistCount, matches);
        var defensiveImpact = player.IsGoalkeeper
            ? technical?.GoalkeeperStops ?? HandballKpiHelper.GoalkeeperStops(goalkeeper)
            : technical?.DefensiveImpact ?? HandballKpiHelper.DefensiveImpact(defense);
        var defensePerMatch = HandballKpiHelper.PerMatch(defensiveImpact, matches);
        var efficiencyRate = player.IsGoalkeeper
            ? technical?.GoalkeeperSaveRate ?? goalkeeper?.TauxArret ?? 0
            : technical?.OverallShotSuccessRate ?? HandballKpiHelper.OverallShotSuccessRate(offense);
        var shotWaste = technical?.ShotWaste ?? HandballKpiHelper.ShotWaste(offense);
        var technicalLosses = technical?.TechnicalLosses ?? HandballKpiHelper.TechnicalLosses(passing);
        var sanctionsCount = technical?.Sanctions ?? HandballKpiHelper.TotalSanctions(sanctions);
        var lossRate = HandballKpiHelper.PerMatch(shotWaste + technicalLosses + sanctionsCount, matches);
        var securityRate = Math.Max(0, 100 - lossRate * 8);
        var volumePerMatch = HandballKpiHelper.PerMatch(HandballKpiHelper.DirectContributions(player) + defensiveImpact, matches);

        return new RadarMetrics(
            goalsPerMatch,
            assistsPerMatch,
            defensePerMatch,
            efficiencyRate,
            securityRate,
            volumePerMatch);
    }

    private static double NormalizeRadarValue(double value, double maxValue)
    {
        if (maxValue <= 0)
        {
            return 0;
        }

        return Math.Round(Math.Clamp(value / maxValue * 100d, 0d, 100d), 1);
    }

