    private IReadOnlyList<BarGaugeKpiItem> GetComparisonGaugeKpis(PlayerGlobalStatsDto player)
    {
        var offense = GetOffense(player.PlayerId);
        var defense = GetDefense(player.PlayerId);
        var passing = GetPassing(player.PlayerId);
        var sanctions = GetSanctions(player.PlayerId);
        var goalkeeper = GetGoalkeeper(player.PlayerId);
        var technical = GetTechnical(player.PlayerId);
        var primaryRate = player.IsGoalkeeper
            ? technical?.GoalkeeperSaveRate ?? goalkeeper?.TauxArret ?? 0
            : technical?.OverallShotSuccessRate ?? HandballKpiHelper.OverallShotSuccessRate(offense);
        var technicalScore = HandballKpiHelper.TechnicalBalanceScore(player, offense, defense, passing, sanctions, goalkeeper);

        return
        [
            new BarGaugeKpiItem(
                player.IsGoalkeeper ? "Taux d'arret" : "Conversion globale",
                HandballKpiHelper.FormatPercent(primaryRate),
                primaryRate,
                player.IsGoalkeeper ? "Efficacite sur les tirs subis." : "Buts rapportes a tous les tirs engages.",
                player.IsGoalkeeper
                    ? HandballKpiHelper.GoalkeeperSaveRateTone(primaryRate)
                    : HandballKpiHelper.FieldSuccessRateTone(primaryRate),
                player.IsGoalkeeper
                    ? HandballKpiHelper.FormatBase(HandballKpiHelper.GoalkeeperStops(goalkeeper), Math.Max(goalkeeper?.TirsSubis ?? 0, 1), "tirs arretes")
                    : HandballKpiHelper.FormatBase(offense?.TotalButs ?? player.TotalGoals, Math.Max(HandballKpiHelper.ShotAttempts(offense), 1), "tirs engages"),
                132),
            new BarGaugeKpiItem(
                "Indice technique",
                HandballKpiHelper.FormatPercent(technicalScore),
                technicalScore,
                "Production utile vs déchets techniques.",
                HandballKpiHelper.TechnicalBalanceTone(technicalScore, player.IsGoalkeeper),
                HandballKpiHelper.FormatBase(
                    (player.TotalGoals + player.AssistCount) + HandballKpiHelper.DefensiveImpact(defense) + HandballKpiHelper.GoalkeeperStops(goalkeeper),
                    Math.Max(
                        (player.TotalGoals + player.AssistCount) + HandballKpiHelper.DefensiveImpact(defense) + HandballKpiHelper.GoalkeeperStops(goalkeeper)
                        + HandballKpiHelper.ShotWaste(offense)
                        + HandballKpiHelper.TechnicalLosses(passing)
                        + HandballKpiHelper.TotalSanctions(sanctions)
                        + HandballKpiHelper.GoalkeeperConcededGoals(goalkeeper),
                        1),
                    "actions"),
                132)
        ];
    }

