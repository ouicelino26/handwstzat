            new MetricPlotPoint("Interceptions", player.InterceptionCount),
            new MetricPlotPoint(player.IsGoalkeeper ? "Arrets" : "Pertes", player.IsGoalkeeper ? (technical?.GoalkeeperStops ?? HandballKpiHelper.GoalkeeperStops(goalkeeper)) : technicalLosses),
            new MetricPlotPoint("Sanctions", technical?.Sanctions ?? HandballKpiHelper.TotalSanctions(sanctions)),
            new MetricPlotPoint("Impact def.", defensiveImpact)
        ];
    }

