@page "/"
@layout PublicLayout
@inject IApiAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>HandWStat Studio</PageTitle>

<div class="auth-portal">
    <section class="auth-manifesto">
        <div class="auth-manifesto__index" aria-hidden="true">HWS / 26</div>

        <div class="auth-manifesto__copy">
            <span class="auth-overline">Performance operating system</span>
            <h1 data-page-title>Voir le jeu avant qu'il ne devienne evident.</h1>
            <p>
                HandWStat transforme les rencontres, les trajectoires et les espaces en
                decisions partageables pour les staffs, analystes et joueuses.
            </p>
        </div>

        <div class="auth-signal-board" aria-label="Apercu des capacites">
            <article>
                <span>01</span>
                <strong>Read</strong>
                <small>Signaux et tendances</small>
            </article>
            <article>
                <span>02</span>
                <strong>Compare</strong>
                <small>Roles et profils</small>
            </article>
            <article>
                <span>03</span>
                <strong>Decide</strong>
                <small>Preuves et contexte</small>
            </article>
        </div>

        <button type="button" class="auth-demo-link" @onclick="OpenDemo">
            <span class="auth-demo-link__play" aria-hidden="true">▶</span>
            <span>
                <strong>Visite guidee</strong>
                <small>Explorer le produit sans session live</small>
            </span>
            <span aria-hidden="true">↗</span>
        </button>
    </section>

    <section class="auth-console" aria-labelledby="login-title">
        <div class="auth-console__status">
            <span aria-hidden="true"></span>
            API live
        </div>

        <div class="auth-console__heading">
            <span>Secure access</span>
            <h2 id="login-title">Ouvrir le studio.</h2>
            <p>Retrouvez votre scope, vos analyses et les donnees de competition.</p>
        </div>

        <div class="auth-console__form">
            <label>
                <span>Identifiant</span>
                <input @bind="UsernameInput"
                       autocomplete="username"
                       placeholder="nom.utilisateur"
                       aria-describedby="login-status" />
            </label>

            <label>
                <span>Mot de passe</span>
                <input @bind="PasswordInput"
                       type="password"
                       autocomplete="current-password"
                       placeholder="Votre mot de passe"
                       @onkeydown="HandlePasswordKeyDownAsync" />
            </label>

            <button type="button"
                    class="auth-submit"
                    @onclick="LoginAsync"
                    disabled="@IsBusy">
                <span>@(IsBusy ? "Connexion en cours" : "Entrer dans le studio")</span>
                <span aria-hidden="true">→</span>
            </button>
        </div>

        <div id="login-status" class="auth-console__feedback" aria-live="polite">
            @if (IsBusy)
            {
                <span class="auth-console__loader" aria-hidden="true"></span>
                <span>Verification de la session...</span>
            }
            else if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <span class="auth-console__feedback-dot" aria-hidden="true"></span>
                <span>@StatusMessage</span>
            }
            else
            {
                <span class="auth-console__feedback-dot" aria-hidden="true"></span>
                <span>Session chiffree, donnees synchronisees a la demande.</span>
            }
        </div>
    </section>
</div>

@code {
    private bool IsBusy { get; set; }
    private string UsernameInput { get; set; } = string.Empty;
    private string PasswordInput { get; set; } = string.Empty;
    private string? StatusMessage { get; set; }

    protected override void OnInitialized()
    {
        if (AuthService.Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/dashboard");
        }
    }

    private async Task HandlePasswordKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !IsBusy)
        {
            await LoginAsync();
        }
    }

    private async Task LoginAsync()
    {
        try
        {
            IsBusy = true;
            StatusMessage = null;

            var session = await AuthService.LoginAsync(UsernameInput, PasswordInput);
            StatusMessage = session.Message;
            PasswordInput = string.Empty;

            if (session.IsAuthenticated)
            {
                Navigation.NavigateTo("/dashboard");
            }
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void OpenDemo() => Navigation.NavigateTo("/demo");
}
