    private IReadOnlyList<PlayerGlobalStatsDto> GetFilteredRosterPlayers()
    {
        IEnumerable<PlayerGlobalStatsDto> filtered = RosterPlayers;

        if (!string.IsNullOrWhiteSpace(RosterSearch))
        {
            var query = RosterSearch.Trim();
            filtered = filtered.Where(player =>
                TextSearchHelper.Contains(player.FullName, query)
                || TextSearchHelper.Contains(player.TeamName, query)
                || TextSearchHelper.Contains(player.PositionCode, query)
                || TextSearchHelper.Contains(player.PositionName, query));
        }

        filtered = RosterSort.Column switch
        {
            "name" => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.FullName) : filtered.OrderBy(item => item.FullName),
            "position" => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.PositionCode ?? item.PositionName) : filtered.OrderBy(item => item.PositionCode ?? item.PositionName),
            "matches" => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.MatchesPlayed) : filtered.OrderBy(item => item.MatchesPlayed),
            "assists" => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.AssistCount) : filtered.OrderBy(item => item.AssistCount),
            "interceptions" => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.InterceptionCount) : filtered.OrderBy(item => item.InterceptionCount),
            "saves" => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.SaveCount) : filtered.OrderBy(item => item.SaveCount),
            "turnovers" => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.TurnoverCount) : filtered.OrderBy(item => item.TurnoverCount),
            "shot" => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.ShotSuccessRate) : filtered.OrderBy(item => item.ShotSuccessRate),
            _ => RosterSort.IsDescending ? filtered.OrderByDescending(item => item.TotalGoals) : filtered.OrderBy(item => item.TotalGoals)
        };

        return filtered.ToList();
    }

    private void SetRosterSort(string column)
    {
        RosterSort = RosterSort.Toggle(column, column is "name" or "position" ? SortDirection.Asc : SortDirection.Desc);
    }

    private RenderFragment TableHeader(string column, string label, Action<string> onSort) => builder =>
    {
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "type", "button");
        builder.AddAttribute(2, "class", $"table-sort-button {(RosterSort.IsActive(column) ? "is-active" : string.Empty)}");
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => onSort(column)));
        builder.AddAttribute(4, "aria-label", RosterSort.SortButtonLabel(column, label));
        builder.AddAttribute(5, "aria-pressed", RosterSort.IsActive(column));
        builder.AddContent(6, label);

        var glyph = RosterSort.Glyph(column);
        if (!string.IsNullOrWhiteSpace(glyph))
        {
            builder.OpenElement(7, "span");
            builder.AddAttribute(8, "class", "sort-indicator");
            builder.AddAttribute(9, "aria-hidden", "true");
            builder.AddContent(10, glyph);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static string GetToneClass(string tone)
    {
        return tone?.ToLowerInvariant() switch
        {
            "positive" => "is-positive",
            "warning" => "is-warning",
            _ => string.Empty
        };
    }

    private static string FormatRate(double value) => value.ToString("0.#");
