@page "/teams"
@inject ReferenceDataService ReferenceDataService
@inject StatsApiClient StatsApiClient
@inject MatchesApiClient MatchesApiClient
@inject MatchEventsApiClient MatchEventsApiClient
@inject IApiAuthService AuthService
@inject AnalysisScopeService ScopeService
@implements IDisposable

<PageTitle>Squads</PageTitle>

<div class="squad-workspace" data-workspace="squads">
    @if (!AuthService.Session.IsAuthenticated)
    {
        <AccessRequiredCard Message="Connectez-vous pour ouvrir les bilans d'equipe et la production des joueuses." />
    }
    else
    {
        <AudienceLensSelector Kicker="Lecture de l'équipe"
                              Title="Adaptez le bilan à votre usage"
                              Subtitle="Le mode Club privilégie le pilotage, le mode Analyste approfondit les données et le mode Joueuse simplifie la restitution."
                              Value="@ActiveLens"
                              ValueChanged="SetActiveLens" />

        <section class="directory-command @(IsBusy ? "is-loading" : string.Empty)">
            <div class="panel-head panel-head-wrap">
                <div>
                    <p class="section-kicker">Squad index</p>
                    <h3>Choisir un collectif</h3>
                </div>

                <div class="toolbar">
                    <button type="button" class="ghost-button filter-ghost" @onclick="ResetAsync" disabled="@IsBusy">Reinitialiser</button>
                </div>
            </div>

            <details class="filter-drawer" open>
                <summary>
                    <div>
                        <strong>Afficher les filtres équipe</strong>
                        <span>Équipe, compétition, saison, journée et poste effectif si besoin.</span>
                    </div>
                </summary>

                <div class="filter-drawer-body">
                    <div class="page-filters">
                        <label class="filter-field">
                            <span>Equipe</span>
                            <select @bind="TeamId" @bind:after="OnScopeSelectionChangedAsync">
                                <option value="">Selectionner</option>
                                @foreach (var team in AvailableTeams)
                                {
                                    <option value="@team.TeamId">@team.TeamName</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Competition</span>
                            <select @bind="CompetitionId" @bind:after="OnScopeSelectionChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var competition in AvailableCompetitions)
                                {
                                    <option value="@competition.CompetitionId">@competition.CompetitionName</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Saison</span>
                            <select @bind="Season" @bind:after="OnScopeSelectionChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var season in SeasonOptions)
                                {
                                    <option value="@season">@season</option>
                                }
                            </select>
                        </label>

                        <label class="filter-field">
                            <span>Journee</span>
                            <select @bind="Day" @bind:after="OnScopeSelectionChangedAsync">
                                <option value="">Toutes</option>
                                @foreach (var day in DayOptions)
                                {
                                    <option value="@day">@day</option>
                                }
                            </select>
                        </label>

                        @if (ActiveSection == "roster")
                        {
                            <label class="filter-field">
                                <span>Poste effectif</span>
                                <select @bind="PositionId" @bind:after="OnRosterScopeChangedAsync">
                                    <option value="">Tous</option>
                                    @foreach (var position in AvailablePositions)
                                    {
                                        <option value="@position.Id">@position.Name</option>
                                    }
                                </select>
                            </label>
                        }
                    </div>
                </div>
            </details>

        
        </section>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <StateCard Kicker="Erreur"
                       Title="Impossible de charger l’équipe"
                       Message="@ErrorMessage"
                       Tone="error" />
        }
        else if (IsBusy && TeamStats is null)
        {
            <StateCard Kicker="Chargement"
                       Title="Mise a jour du bilan d'equipe"
                       Message="Les KPI, joueuses et matchs se recalculent pour le contexte choisi."
                       Tone="loading" />
        }
        else if (TeamStats is null)
        {
            <StateCard Kicker="Aucune équipe"
                       Title="Choisissez une équipe pour charger son bilan"
                       Message="Les joueuses et les matchs se chargeront dans le même contexte."
                       Tone="empty" />
        }
        else
        {
            @if (IsBusy)
            {
                <PageLoader Kicker="Chargement"
                            Title="Actualisation de l'equipe"
                            Message="Les statistiques collectives et les graphes se recalculent." />
            }

            <section class="entity-stage">
                @{
                    var teamLogoUrl = SelectedTeamLogoUrl;
                }

                <header class="entity-identity entity-identity--squad">
                    <div class="team-identity-logo @(teamLogoUrl is null ? "is-placeholder" : string.Empty)">
                        @if (!string.IsNullOrWhiteSpace(teamLogoUrl))
                        {
                            <img src="@teamLogoUrl"
                                 alt="@($"Logo {TeamStats.TeamName}")"
                                 loading="lazy"
                                 onerror="this.onerror=null;this.src=this.src.includes('/2025-2026/')?this.src.replace('/2025-2026/','/2024-2025/'):this.src.replace('/2024-2025/','/2025-2026/');" />
                        }
                        else
                        {
                            <span>@(TeamStats.TeamCode ?? "HWS")</span>
                        }
                    </div>
                    <div class="entity-identity__copy">
                        <span>Squad workspace</span>
                        <h2 data-page-title>@TeamStats.TeamName</h2>
                        <p class="team-identity-meta">
                            @if (!string.IsNullOrWhiteSpace(TeamStats.TeamCode))
                            {
                                <span class="team-code-pill">@TeamStats.TeamCode</span>
                            }
                            <span>@TeamStats.MatchesPlayed matchs · @TeamPlayers.Count joueuses dans le scope</span>
                        </p>
                    </div>
                    <div class="entity-identity__score">
                        <span>Bilan</span>
                        <strong>@TeamStats.Wins / @TeamStats.Draws / @TeamStats.Losses</strong>
                    </div>
                </header>

                <div class="scene-switcher" role="tablist" aria-label="Scenes de l'equipe">
                    <button type="button" class="tab-button @(ActiveSection == "summary" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("summary")'>Pulse</button>
                    <button type="button" class="tab-button @(ActiveSection == "roster" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("roster")'>Effectif</button>
                    <button type="button" class="tab-button @(ActiveSection == "matches" ? "is-active" : string.Empty)" @onclick='() => SetActiveSection("matches")'>Games</button>
                </div>

                @if (ActiveSection == "summary")
                {
                    <div class="stats-grid">
                        <div class="mini-card"><span>Matchs</span><strong>@TeamStats.MatchesPlayed</strong></div>
                        <div class="mini-card"><span>Victoires</span><strong>@TeamStats.Wins</strong></div>
                        <div class="mini-card"><span>Nuls</span><strong>@TeamStats.Draws</strong></div>
                        <div class="mini-card"><span>Defaites</span><strong>@TeamStats.Losses</strong></div>
                        <div class="mini-card"><span>Buts pour</span><strong>@TeamStats.GoalsFor</strong></div>
                        <div class="mini-card"><span>Buts contre</span><strong>@TeamStats.GoalsAgainst</strong></div>
                        <div class="mini-card"><span>Passes</span><strong>@TeamStats.Overview.AssistCount</strong></div>
                        <div class="mini-card"><span>Interceptions</span><strong>@TeamStats.Overview.InterceptionCount</strong></div>
                    </div>

                    @if (ShowTeamSummaryKpis)
                    {
                        <KpiTileGrid Items="@TeamKpis" />
                    }

                    @if (ShowTeamSummaryCharts)
                    {
                        <div class="dual-grid">
                            <article class="page-panel">
                                <p class="section-kicker">Repartition collective</p>
                                <h4>Contribution directe par joueuse</h4>
                                <ApexChart @key="TeamId" TItem="SliceValue" Title="Contribution directe" Height="310" Options="@GetTeamContributionChartOptions()">
                                    <ApexPointSeries TItem="SliceValue"
                                                     Items="@TeamContributionDistribution"
                                                     Name="Contribution"
                                                     SeriesType="SeriesType.Donut"
                                                     XValue="slice => slice.Label"
                                                     YValue="slice => (decimal?)slice.Value" />
                                </ApexChart>
                            </article>

                            <article class="page-panel">
                                <p class="section-kicker">Lecture rapide</p>
                                <h4>Joueuses qui concentrent l'impact</h4>
                                <div class="compact-list">
                                    @foreach (var player in TeamPlayers.OrderByDescending(item => HandballKpiHelper.DirectContributions(item)).Take(5))
                                    {
                                        <div class="outcome-row">
                                            <span>@player.FullName</span>
                                            <strong>@HandballKpiHelper.DirectContributions(player)</strong>
                                        </div>
                                    }
                                </div>
                            </article>
                        </div>
                    }

                    <div class="dual-grid">
                        <article class="page-panel">
                            <p class="section-kicker">Bilan</p>
                            <h4>Production collective</h4>
                            <div class="badge-row">
                                <div class="mini-card"><span>Buts</span><strong>@(TeamStats.Overview.GoalCount + TeamStats.Overview.PenaltyGoalCount)</strong></div>
                                <div class="mini-card"><span>Arrets</span><strong>@TeamStats.Overview.SaveCount</strong></div>
                                <div class="mini-card"><span>Pertes</span><strong>@TeamStats.Overview.TurnoverCount</strong></div>
                                <div class="mini-card"><span>Sanctions</span><strong>@TeamStats.Overview.SanctionCount</strong></div>
                            </div>
                        </article>

                        <article class="page-panel">
                            <p class="section-kicker">Top internes</p>
                            <h4>Production des joueuses</h4>
                            <div class="list-stack">
                                @foreach (var player in TeamPlayers.OrderByDescending(item => item.TotalGoals).Take(5))
                                {
                                    <div class="list-item">
                                        <div class="key-metric">
                                            <strong>@player.FullName</strong>
                                            <span>@player.TotalGoals buts</span>
                                        </div>
                                        <p class="tiny-note">@player.TeamName - @FormatRate(player.ShotSuccessRate)% au tir</p>
                                    </div>
                                }
                            </div>
                        </article>
                    </div>

                    @if (ShowTeamAnalystPanels)
                    {
                        <div class="triple-grid">
                            <article class="page-panel">
                                <p class="section-kicker">Profil collectif</p>
                                <h4>Volumes moyens par match</h4>
                                <ApexChart TItem="MetricPlotPoint" Title="Profil collectif" Height="310" Options="@GetTeamProfileChartOptions()">
                                    <ApexPointSeries TItem="MetricPlotPoint"
                                                     Items="@TeamProfileSeries"
                                                     Name="@TeamStats.TeamName"
                                                     SeriesType="SeriesType.Bar"
                                                     XValue="point => point.Label"
                                                     YValue="point => (decimal?)point.Value" />
                                </ApexChart>
                            </article>

                            <article class="page-panel">
                                <p class="section-kicker">Joueuses decisives</p>
                                <h4>Actions directes dans la selection</h4>
                                <ApexChart TItem="MetricPlotPoint" Title="Implication offensive" Height="310" Options="@GetTeamImpactChartOptions()">
                                    <ApexPointSeries TItem="MetricPlotPoint"
                                                     Items="@TeamPlayerImpactSeries"
                                                     Name="Actions directes"
                                                     SeriesType="SeriesType.Bar"
                                                     XValue="point => point.Label"
                                                     YValue="point => (decimal?)point.Value" />
                                </ApexChart>
                            </article>
                        </div>
                    }
                }
                else if (ActiveSection == "roster")
                {
                    <section class="page-panel">
                        <div class="panel-head">
                            <div>
                                <p class="section-kicker">Effectif productif</p>
                                <h4>@RosterPlayers.Count joueuses dans le filtre</h4>
                            </div>
                        </div>

                        <div class="table-toolbar">
                            <label class="filter-field table-search">
                                <span>Filtrer le tableau</span>
                                <input value="@RosterSearch" @oninput="OnRosterSearchChanged" placeholder="Joueuse, poste ou equipe" />
                            </label>
                        </div>

                        @{
                            var rosterRows = FilteredRosterPlayers.ToArray();
                        }

                        <div class="table-wrap">
                            <table class="stat-table">
                                <thead>
                                    <tr>
                                        <th>@TableHeader("name", "Joueuse", SetRosterSort)</th>
                                        <th>@TableHeader("position", "Poste", SetRosterSort)</th>
                                        <th>@TableHeader("matches", "Matchs", SetRosterSort)</th>
                                        <th>@TableHeader("goals", "Buts", SetRosterSort)</th>
                                        <th>@TableHeader("assists", "Passes", SetRosterSort)</th>
                                        <th>@TableHeader("interceptions", "Interceptions", SetRosterSort)</th>
                                        <th>@TableHeader("saves", "Arrets", SetRosterSort)</th>
                                        <th>@TableHeader("turnovers", "Pertes", SetRosterSort)</th>
                                        <th>@TableHeader("shot", "Taux tir", SetRosterSort)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var player in rosterRows)
                                    {
                                        <tr>
                                            <td>@player.FullName</td>
                                            <td>@(player.PositionCode ?? player.PositionName ?? "-")</td>
                                            <td>@player.MatchesPlayed</td>
                                            <td class="@TableHeatToneHelper.HeatClass(rosterRows, row => (double?)row.TotalGoals, player)">@player.TotalGoals</td>
                                            <td class="@TableHeatToneHelper.HeatClass(rosterRows, row => (double?)row.AssistCount, player)">@player.AssistCount</td>
                                            <td class="@TableHeatToneHelper.HeatClass(rosterRows, row => (double?)row.InterceptionCount, player)">@player.InterceptionCount</td>
                                            <td class="@TableHeatToneHelper.HeatClass(rosterRows, row => (double?)row.SaveCount, player)">@player.SaveCount</td>
                                            <td class="@TableHeatToneHelper.HeatClass(rosterRows, row => (double?)row.TurnoverCount, player, higherIsBetter: false)">@player.TurnoverCount</td>
                                            <td class="@TableHeatToneHelper.HeatClass(rosterRows, row => (double?)row.ShotSuccessRate, player)">@FormatRate(player.ShotSuccessRate)%</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }
                else
                {
                    <section class="workspace-grid workspace-grid-single">
                        <article class="page-panel selection-column">
                            <div class="panel-head">
                                <div>
                                    <p class="section-kicker">Matchs</p>
                                    <h4>@TeamMatches.Count rencontres</h4>
                                    <p class="page-subtitle">Chaque carte ouvre la fiche complete du match via Voir plus.</p>
                                </div>
                            </div>

                            @if (TeamMatches.Count == 0)
                            {
                                <StateCard Kicker="Aucun match"
                                           Title="La sélection courante ne retourne aucune rencontre"
                                           Message="Essayez une autre équipe, une autre saison ou un autre jour."
                                           Tone="empty"
                                           CssClass="empty-card-inline" />
                            }
                            else
                            {
                                <div class="match-mosaic">
                                    @foreach (var match in TeamMatches)
                                    {
                                        <MatchCard @key="match.MatchId"
                                                   Title="@($"{match.Team1Name ?? "Equipe A"} vs {match.Team2Name ?? "Equipe B"}")"
                                                   Score="@($"{match.Team1Score ?? 0} - {match.Team2Score ?? 0}")"
                                                   Teams="@ReferenceData.Teams"
                                                   Season="@Season"
                                                   HomeTeamLogoUrl="@TeamLogoAssetResolver.ResolveByName(ReferenceData.Teams, match.Team1Name, Season)"
                                                   AwayTeamLogoUrl="@TeamLogoAssetResolver.ResolveByName(ReferenceData.Teams, match.Team2Name, Season)"
                                                   Meta="@(match.CompetitionName ?? "Competition")"
                                                   SecondaryMeta="@MatchFilterCatalog.FormatSeasonDay(match)"
                                                   DetailsHref="@($"/matches?matchId={match.MatchId}")"
                                                   DetailsLabel="Voir plus" />
                                    }
                                </div>
                            }
                        </article>
                    </section>
                }
            </section>
        }
    }
</div>

@code {
    private AnalyticsReferenceData ReferenceData { get; set; } = AnalyticsReferenceData.Empty;
    private TeamStatsDto? TeamStats { get; set; }
    private MatchSummaryDto? SelectedMatchSummary { get; set; }
    private IReadOnlyList<PlayerGlobalStatsDto> TeamPlayers { get; set; } = [];
    private IReadOnlyList<PlayerGlobalStatsDto> RosterPlayers { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> CompetitionOptionMatches { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> TeamOptionMatches { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> ScopedMatches { get; set; } = [];
    private IReadOnlyList<MatchListItemDto> TeamMatches { get; set; } = [];
    private IReadOnlyList<ScoreTimelinePoint> SelectedMatchTimeline { get; set; } = [];
    private bool IsBusy { get; set; }
    private bool IsSelectedMatchLoading { get; set; }
    private string? ErrorMessage { get; set; }
    private int? TeamId { get; set; }
    private int? CompetitionId { get; set; }
    private int? PositionId { get; set; }
    private int? Year { get; set; }
    private string? Season { get; set; }
    private string? Day { get; set; }
    private int? SelectedMatchId { get; set; }
    private long SelectedMatchLoadToken { get; set; }
    private string ActiveSection { get; set; } = "summary";
    private string ActiveLens { get; set; } = AudienceLens.Club;
    private string RosterSearch { get; set; } = string.Empty;
    private TableSortState RosterSort { get; set; } = new("goals", SortDirection.Desc);
    private bool _publishingScope;

    [Parameter, SupplyParameterFromQuery(Name = "teamId")]
    public int? TeamIdFromQuery { get; set; }

    private MatchListItemDto? SelectedMatch => TeamMatches.FirstOrDefault(match => match.MatchId == SelectedMatchId);
    private IReadOnlyList<string> SeasonOptions => MatchFilterCatalog.GetSeasons(ScopedMatches);
    private IReadOnlyList<string> DayOptions => MatchFilterCatalog.GetDays(ScopedMatches, Season);
    private IReadOnlyList<CompetitionDto> AvailableCompetitions => SmartFilterCatalog.GetCompetitions(
        ReferenceData,
        MatchFilterCatalog.ApplySeasonAndDay(CompetitionOptionMatches, Season, Day),
        TeamId.HasValue || !string.IsNullOrWhiteSpace(Season) || !string.IsNullOrWhiteSpace(Day));
    private IReadOnlyList<TeamDto> AvailableTeams => SmartFilterCatalog.GetTeams(
        ReferenceData,
        MatchFilterCatalog.ApplySeasonAndDay(TeamOptionMatches, Season, Day),
        CompetitionId.HasValue || !string.IsNullOrWhiteSpace(Season) || !string.IsNullOrWhiteSpace(Day));
    private string? SelectedTeamLogoUrl => TeamLogoAssetResolver.ResolveByTeam(
        TeamStats is null
            ? null
            : ReferenceData.Teams.FirstOrDefault(team => team.TeamId == TeamStats.TeamId),
        Season);
    private IReadOnlyList<LookupItemDto> AvailablePositions => SmartFilterCatalog.GetPositions(ReferenceData.Positions, RosterPlayers, PositionId.HasValue || TeamPlayers.Count > 0);
    private IReadOnlyList<ScopeSummaryItem> TeamScopeItems =>
    [
        new(
            "Equipe",
            TeamId.HasValue
                ? AvailableTeams.FirstOrDefault(item => item.TeamId == TeamId.Value)?.TeamName ?? "Selection"
                : "Selectionner"),
        new(
            "Competition",
            CompetitionId.HasValue
                ? AvailableCompetitions.FirstOrDefault(item => item.CompetitionId == CompetitionId.Value)?.CompetitionName ?? "Selection"
                : "Toutes"),
        new("Saison", string.IsNullOrWhiteSpace(Season) ? "Toutes" : Season),
        new("Journee", string.IsNullOrWhiteSpace(Day) ? "Toutes" : Day),
        new("Onglet", ActiveSection == "summary" ? "Synthese" : ActiveSection == "roster" ? "Effectif" : "Matchs")
    ];
    private IReadOnlyList<ScopeSummaryItem> SelectedTeamScopeItems => TeamStats is null
        ? []
        :
        [
            new("Equipe", TeamStats.TeamName ?? "Equipe"),
            new("Matchs", TeamStats.MatchesPlayed.ToString()),
            new("Buts pour", TeamStats.GoalsFor.ToString()),
            new("Buts contre", TeamStats.GoalsAgainst.ToString()),
            new("Effectif", TeamPlayers.Count.ToString()),
            new("Sections", ActiveSection == "summary" ? "Vue staff" : ActiveSection == "roster" ? "Vue effectif" : "Vue match")
        ];
    private bool ShowTeamSummaryKpis => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowTeamSummaryCharts => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowTeamAnalystPanels => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowTeamMatchKpis => ActiveLens is AudienceLens.Club or AudienceLens.Analyst;
    private bool ShowTeamMatchInsights => ActiveLens == AudienceLens.Analyst;
    private IReadOnlyList<KpiTile> TeamKpis => BuildTeamKpis();
    private IReadOnlyList<KpiTile> SelectedMatchKpis => MatchKpiCatalog.BuildSummaryKpis(SelectedMatchSummary, SelectedMatch, TeamPlayers);
    private IReadOnlyList<KpiTile> TimelineKpis => MatchScenarioAnalyzer.BuildTimelineKpis(SelectedMatchTimeline, SelectedMatch?.Team1Name, SelectedMatch?.Team2Name);
    private IReadOnlyList<MatchTimelineInsight> TimelineInsights => MatchScenarioAnalyzer.BuildPhaseInsights(SelectedMatchTimeline, SelectedMatch?.Team1Name, SelectedMatch?.Team2Name);
    private IReadOnlyList<MatchTimelineMoment> TimelineMoments => MatchScenarioAnalyzer.BuildKeyMoments(SelectedMatchTimeline, SelectedMatch?.Team1Name, SelectedMatch?.Team2Name);
    private IReadOnlyList<MetricPlotPoint> TeamProfileSeries => BuildTeamProfileSeries();
    private IReadOnlyList<MetricPlotPoint> TeamPlayerImpactSeries => BuildTeamPlayerImpactSeries();
    private IReadOnlyList<PlayerGlobalStatsDto> FilteredRosterPlayers => GetFilteredRosterPlayers();

    private string FinalScoreLabel => SelectedMatch is null
        ? "-"
        : $"{SelectedMatch.Team1Score ?? SelectedMatchTimeline.LastOrDefault()?.Team1Score ?? 0} - {SelectedMatch.Team2Score ?? SelectedMatchTimeline.LastOrDefault()?.Team2Score ?? 0}";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.Session.IsAuthenticated)
        {
            return;
        }

        ReferenceData = await ReferenceDataService.GetReferenceDataAsync();
        ApplyGlobalScope();
        ScopeService.Changed += HandleGlobalScopeChanged;
        TeamId = TeamIdFromQuery
            ?? ScopeService.Current.TeamId
            ?? ReferenceData.Teams.FirstOrDefault()?.TeamId;

        if (TeamId.HasValue)
        {
            await LoadTeamAsync();
        }
    }

    private async Task ResetAsync()
    {
        CompetitionId = null;
        PositionId = null;
        Year = null;
        Season = null;
        Day = null;
        RosterSearch = string.Empty;
        RosterSort = new TableSortState("goals", SortDirection.Desc);
        TeamId = ReferenceData.Teams.FirstOrDefault()?.TeamId;
        ActiveSection = "summary";
        PublishGlobalScope();
        await LoadTeamAsync();
    }

    private Task OnScopeSelectionChangedAsync()
    {
        PublishGlobalScope();
        return LoadTeamAsync();
    }

    private Task SetActiveLens(string lens)
    {
        ActiveLens = lens;
        return InvokeAsync(StateHasChanged);
    }

    private Task OnRosterScopeChangedAsync()
    {
        return LoadTeamAsync();
    }

    public void Dispose()
    {
        ScopeService.Changed -= HandleGlobalScopeChanged;
    }

    private void HandleGlobalScopeChanged()
    {
        if (_publishingScope)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            ApplyGlobalScope();
            await LoadTeamAsync();
        });
    }

    private void ApplyGlobalScope()
    {
        CompetitionId = ScopeService.Current.CompetitionId;
        TeamId = ScopeService.Current.TeamId ?? TeamId;
        Season = ScopeService.Current.Season;
        Day = ScopeService.Current.Day;
    }

    private void PublishGlobalScope()
    {
        _publishingScope = true;
        try
        {
            ScopeService.Update(new AnalysisScopeSnapshot(
                CompetitionId,
                AvailableCompetitions.FirstOrDefault(item => item.CompetitionId == CompetitionId)?.CompetitionName,
                TeamId,
                AvailableTeams.FirstOrDefault(item => item.TeamId == TeamId)?.TeamName,
                Season,
                Day));
        }
        finally
        {
            _publishingScope = false;
        }
    }

    private Task OnRosterSearchChanged(ChangeEventArgs args)
    {
        RosterSearch = args.Value?.ToString() ?? string.Empty;
        return InvokeAsync(StateHasChanged);
    }

    private Task SetActiveSection(string section)
    {
        ActiveSection = section;
        return InvokeAsync(StateHasChanged);
    }

    private async Task LoadTeamAsync(bool manageBusyState = true)
    {
        if (!TeamId.HasValue)
        {
            TeamStats = null;
            TeamPlayers = [];
            RosterPlayers = [];
            TeamMatches = [];
            SelectedMatchId = null;
            SelectedMatchSummary = null;
            SelectedMatchTimeline = [];
            return;
        }

        var loadStartedAt = DateTimeOffset.UtcNow;

        try
        {
            if (manageBusyState)
            {
                await BusyUiHelper.EnterAsync(() => IsBusy = true, () => InvokeAsync(StateHasChanged));
            }
            ErrorMessage = null;

            var summaryOptions = new StatsQueryOptionsDto
            {
                CompetitionId = CompetitionId,
                Year = Year,
                Season = Season,
                Day = Day
            };

            var rosterOptions = new StatsQueryOptionsDto
            {
                CompetitionId = CompetitionId,
                PositionId = PositionId,
                Year = Year,
                Season = Season,
                Day = Day
            };

            var teamTask = StatsApiClient.GetTeamStatsAsync(TeamId.Value, summaryOptions);
            var playersTask = StatsApiClient.GetTeamPlayersAsync(TeamId.Value, summaryOptions);
            var rosterTask = StatsApiClient.GetTeamPlayersAsync(TeamId.Value, rosterOptions);
            var competitionScopeTask = MatchesApiClient.GetMatchesAsync(
                teamId: TeamId,
                year: Year,
                page: 1,
                pageSize: 500);
            var teamScopeTask = MatchesApiClient.GetMatchesAsync(
                competitionId: CompetitionId,
                year: Year,
                page: 1,
                pageSize: 500);
            var matchesTask = MatchesApiClient.GetMatchesAsync(
                competitionId: CompetitionId,
                teamId: TeamId,
                year: Year,
                page: 1,
                pageSize: 500);

            await Task.WhenAll(teamTask, playersTask, rosterTask, competitionScopeTask, teamScopeTask, matchesTask);

            TeamStats = teamTask.Result;
            TeamPlayers = playersTask.Result;
            RosterPlayers = rosterTask.Result;
            CompetitionOptionMatches = competitionScopeTask.Result;
            TeamOptionMatches = teamScopeTask.Result;
            ScopedMatches = matchesTask.Result.OrderByDescending(match => match.Date).ToList();

            var filtersAdjusted = false;

            if (CompetitionId.HasValue && AvailableCompetitions.All(item => item.CompetitionId != CompetitionId.Value))
            {
                CompetitionId = null;
                filtersAdjusted = true;
            }

            if (TeamId.HasValue && AvailableTeams.All(item => item.TeamId != TeamId.Value))
            {
                TeamId = null;
                filtersAdjusted = true;
            }

            if (filtersAdjusted)
            {
                await LoadTeamAsync(manageBusyState: false);
                return;
            }

            if (!string.IsNullOrWhiteSpace(Season) && !SeasonOptions.Contains(Season, StringComparer.OrdinalIgnoreCase))
            {
                Season = null;
            }

            if (!string.IsNullOrWhiteSpace(Day) && !DayOptions.Contains(Day, StringComparer.OrdinalIgnoreCase))
            {
                Day = null;
            }

            TeamMatches = MatchFilterCatalog.ApplySeasonAndDay(ScopedMatches, Season, Day)
                .OrderByDescending(match => match.Date)
                .ToList();
            SelectedMatchId = null;
            SelectedMatchSummary = null;
            SelectedMatchTimeline = [];
            IsSelectedMatchLoading = false;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            if (manageBusyState)
            {
                await BusyUiHelper.ExitAsync(() => IsBusy = false, () => InvokeAsync(StateHasChanged), loadStartedAt);
            }
        }
    }

    private long BeginSelectedMatchLoad()
    {
        SelectedMatchLoadToken++;
        return SelectedMatchLoadToken;
    }

    private async Task LoadSelectedMatchTimelineAsync(long loadToken)
    {
        if (!SelectedMatchId.HasValue)
        {
            SelectedMatchSummary = null;
            SelectedMatchTimeline = [];
            IsSelectedMatchLoading = false;
            return;
        }

        IsSelectedMatchLoading = true;
        SelectedMatchSummary = null;
        SelectedMatchTimeline = [];
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            var summaryTask = StatsApiClient.GetAnalyticsMatchSummaryAsync(SelectedMatchId.Value);
            var eventsTask = MatchEventsApiClient.GetMatchEventsAsync(SelectedMatchId.Value);

            await Task.WhenAll(summaryTask, eventsTask);

            if (loadToken != SelectedMatchLoadToken)
            {
                return;
            }

            SelectedMatchSummary = summaryTask.Result;
            SelectedMatchTimeline = MatchScenarioAnalyzer.BuildScoreTimeline(eventsTask.Result, SelectedMatch);
            ErrorMessage = null;
        }
        catch (Exception ex)
        {
            if (loadToken != SelectedMatchLoadToken)
            {
                return;
            }

            SelectedMatchSummary = null;
            SelectedMatchTimeline = [];
            ErrorMessage = ex.Message;
        }
        finally
        {
            if (loadToken == SelectedMatchLoadToken)
            {
                IsSelectedMatchLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private IReadOnlyList<KpiTile> BuildTeamKpis()
    {
        if (TeamStats is null)
        {
            return [];
        }

        var matches = TeamStats.MatchesPlayed;
        var points = (TeamStats.Wins * 2) + TeamStats.Draws;
        var goalDiff = TeamStats.GoalsFor - TeamStats.GoalsAgainst;
        var technical = TeamStats.Technical;

        return
        [
            new KpiTile("Points / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(points, matches)), "Repere resultat sur le cycle filtre.", "positive", HandballKpiHelper.FormatPerMatchContext(points, matches, "points")),
            new KpiTile("Taux de victoire", HandballKpiHelper.FormatPercent(HandballKpiHelper.Share(TeamStats.Wins, matches)), "Capacite a transformer les matchs en resultats.", HandballKpiHelper.HigherIsBetterTone(HandballKpiHelper.Share(TeamStats.Wins, matches)), $"{TeamStats.Wins} victoires sur {matches} matchs"),
            new KpiTile("Diff. buts / match", HandballKpiHelper.FormatSigned(HandballKpiHelper.PerMatch(goalDiff, matches)), "Mesure la maitrise collective score apres score.", goalDiff >= 0 ? "positive" : "warning", $"{HandballKpiHelper.FormatSigned(goalDiff)} sur l'ensemble du cycle"),
            new KpiTile("Buts marques / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(TeamStats.GoalsFor, matches)), "Volume offensif moyen.", "positive", HandballKpiHelper.FormatPerMatchContext(TeamStats.GoalsFor, matches, "buts")),
            new KpiTile("Buts encaisses / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(TeamStats.GoalsAgainst, matches)), "Solidite defensive du collectif.", HandballKpiHelper.GoalkeeperConcededGoalsTone(HandballKpiHelper.PerMatch(TeamStats.GoalsAgainst, matches)), HandballKpiHelper.FormatPerMatchContext(TeamStats.GoalsAgainst, matches, "buts encaisses")),
            new KpiTile("Ballons valorises", HandballKpiHelper.FormatPercent(HandballKpiHelper.SuccessVsWasteShare(TeamStats.Overview.AssistCount, TeamStats.Overview.TurnoverCount)), "Part des actions de balle qui se terminent positivement.", HandballKpiHelper.BallRetentionTone(HandballKpiHelper.SuccessVsWasteShare(TeamStats.Overview.AssistCount, TeamStats.Overview.TurnoverCount), false), $"{TeamStats.Overview.AssistCount} passes pour {TeamStats.Overview.TurnoverCount} pertes"),
            new KpiTile("Tirs engages / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(technical.ShotAttempts, matches)), "Volume total de tirs, penalties et contres engages.", "neutral", HandballKpiHelper.FormatPerMatchContext(technical.ShotAttempts, matches, "tirs engages")),
            new KpiTile("Dechet tir / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(technical.ShotWaste, matches)), "Tirs rates, penalties rates et tirs contrés.", "warning", HandballKpiHelper.FormatPerMatchContext(technical.ShotWaste, matches, "dechets")),
            new KpiTile("Pertes / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(TeamStats.Overview.TurnoverCount, matches)), "Charge de dechet technique a surveiller.", "warning", HandballKpiHelper.FormatPerMatchContext(TeamStats.Overview.TurnoverCount, matches, "pertes")),
            new KpiTile("Arrets / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(TeamStats.Overview.SaveCount, matches)), "Contribution gardienne au rendement global.", HandballKpiHelper.GoalkeeperStopsPerMatchTone(HandballKpiHelper.PerMatch(TeamStats.Overview.SaveCount, matches)), HandballKpiHelper.FormatPerMatchContext(TeamStats.Overview.SaveCount, matches, "arrets")),
            new KpiTile("Pertes techniques / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(technical.TechnicalLosses, matches)), "Mauvaises passes, pertes de balle, fautes techniques et passages en force.", "warning", HandballKpiHelper.FormatPerMatchContext(technical.TechnicalLosses, matches, "pertes techniques")),
            new KpiTile("Stop 7m %", HandballKpiHelper.FormatPercent(technical.GoalkeeperPenaltyStopRate), "Efficacite gardienne sur les penalties.", HandballKpiHelper.GoalkeeperPenaltyStopRateTone(technical.GoalkeeperPenaltyStopRate), HandballKpiHelper.FormatBase(technical.GoalkeeperPenaltyStops, Math.Max(technical.GoalkeeperPenaltyStops + technical.GoalkeeperPenaltyConcededGoals, 1), "penalties arretes")),
            new KpiTile("Conversion globale", HandballKpiHelper.FormatPercent(technical.OverallShotSuccessRate), "Buts rapportes a tous les tirs engages.", HandballKpiHelper.FieldSuccessRateTone(technical.OverallShotSuccessRate), HandballKpiHelper.FormatBase(TeamStats.GoalsFor, Math.Max(technical.ShotAttempts, 1), "tirs engages")),
            new KpiTile("Sanctions / match", HandballKpiHelper.FormatNumber(HandballKpiHelper.PerMatch(technical.Sanctions, matches)), "Niveau de discipline collective.", HandballKpiHelper.LowerIsBetterTone(HandballKpiHelper.PerMatch(technical.Sanctions, matches)), HandballKpiHelper.FormatPerMatchContext(technical.Sanctions, matches, "sanctions"))
        ];
    }

