    private IReadOnlyList<MetricPlotPoint> BuildTeamPlayerImpactSeries()
    {
        return TeamPlayers
            .OrderByDescending(player => HandballKpiHelper.DirectContributions(player))
            .ThenBy(player => player.FullName)
            .Take(6)
            .Select(player => new MetricPlotPoint(player.FullName, HandballKpiHelper.DirectContributions(player)))
            .ToList();
    }

    private IReadOnlyList<SliceValue> TeamContributionDistribution => BuildTeamContributionDistribution();

    private IReadOnlyList<SliceValue> BuildTeamContributionDistribution()
    {
        if (TeamPlayers.Count == 0)
        {
            return [];
        }

        var rankedPlayers = TeamPlayers
            .OrderByDescending(player => HandballKpiHelper.DirectContributions(player))
            .ThenBy(player => player.FullName)
            .ToList();

        var topPlayers = rankedPlayers.Take(5).ToList();
        var totalContribution = rankedPlayers.Sum(player => HandballKpiHelper.DirectContributions(player));
        var topContribution = topPlayers.Sum(player => HandballKpiHelper.DirectContributions(player));

        var slices = topPlayers
            .Select(player => new SliceValue(player.FullName, Math.Max(HandballKpiHelper.DirectContributions(player), 0)))
            .ToList();

        var remainder = Math.Max(totalContribution - topContribution, 0);
        if (remainder > 0)
        {
            slices.Add(new SliceValue("Autres", remainder));
        }

        return slices;
    }

