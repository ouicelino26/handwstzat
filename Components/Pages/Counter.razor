@page "/counter"

<PageTitle>Diagnostic interaction</PageTitle>

<section class="diagnostic-scene">
    <span>Internal diagnostic</span>
    <h2 data-page-title>Interaction counter</h2>
    <p>Cette route technique reste disponible pour verifier le cycle de rendu Blazor.</p>
    <button type="button" @onclick="IncrementCount">
        <span>Signal emis</span>
        <strong>@CurrentCount</strong>
    </button>
</section>

@code {
    private int CurrentCount { get; set; }
    private void IncrementCount() => CurrentCount++;
}
