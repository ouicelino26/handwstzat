<aside class="entity-index @(IsPlayerListOpen ? "is-open" : "is-collapsed")"
       aria-label="@Kicker">
    <header class="entity-index__head">
        <div>
            <span>@Kicker</span>
            <strong>@Players.Count.ToString("00")</strong>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <small>@Subtitle</small>
            }
        </div>
        <button type="button"
                @onclick="TogglePlayerListAsync"
                aria-expanded="@IsPlayerListOpen"
                aria-controls="@_contentId"
                aria-label="@(IsPlayerListOpen ? "Reduire l'index" : "Ouvrir l'index")">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="@TogglePath"></path></svg>
        </button>
    </header>

    <div id="@_contentId"
         class="entity-index__body @(Scrollable ? "is-scrollable" : string.Empty)"
         aria-hidden="@(!IsPlayerListOpen)">
        @if (Players.Count == 0)
        {
            <StateCard Kicker="@EmptyKicker"
                       Title="@EmptyTitle"
                       Message="@EmptyMessage"
                       Tone="empty" />
        }
        else
        {
            @foreach (var player in Players)
            {
                var photoUrl = ResolvePlayerPhotoUrl(player.PlayerPhoto, player.PlayerId, player.FullName, player.TeamName);

                <button type="button"
                        class="entity-index__item @(SelectedPlayerId == player.PlayerId ? "is-selected" : string.Empty)"
                        aria-pressed="@(SelectedPlayerId == player.PlayerId)"
                        @onclick="() => SelectPlayerAsync(player.PlayerId)">
                    <span class="entity-index__avatar @(photoUrl is null ? "is-placeholder" : string.Empty)">
                        @if (!string.IsNullOrWhiteSpace(photoUrl))
                        {
                            <img src="@photoUrl" alt="@($"Portrait de {player.FullName}")" loading="lazy" />
                        }
                        else
                        {
                            @GetInitials(player.FullName)
                        }
                    </span>
                    <span class="entity-index__identity">
                        <strong>@player.FullName</strong>
                        <small>@(player.TeamName ?? "Equipe inconnue")</small>
                    </span>
                    <span class="entity-index__role">@(player.PositionCode ?? player.PositionName ?? "—")</span>
                    <span class="entity-index__arrow" aria-hidden="true">→</span>
                </button>
            }
        }
    </div>
</aside>

@code {
    [Parameter] public string Kicker { get; set; } = "Athlete index";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public IReadOnlyList<PlayerListItemDto> Players { get; set; } = [];
    [Parameter] public int? SelectedPlayerId { get; set; }
    [Parameter] public bool Scrollable { get; set; }
    [Parameter] public bool IsPlayerListOpen { get; set; } = true;
    [Parameter] public EventCallback<bool> IsPlayerListOpenChanged { get; set; }
    [Parameter] public string EmptyKicker { get; set; } = "Aucune joueuse";
    [Parameter] public string EmptyTitle { get; set; } = "Le scope ne retourne aucune joueuse";
    [Parameter] public string EmptyMessage { get; set; } = "Elargissez le filtre ou changez de poste.";
    [Parameter] public EventCallback<int> OnSelectedPlayerChanged { get; set; }

    private readonly string _contentId = $"entity-index-{Guid.NewGuid():N}";
    private string TogglePath => IsPlayerListOpen ? "m15 5-7 7 7 7" : "m9 5 7 7-7 7";

    private async Task SelectPlayerAsync(int playerId)
    {
        if (OnSelectedPlayerChanged.HasDelegate)
        {
            await OnSelectedPlayerChanged.InvokeAsync(playerId);
        }
    }

    private async Task TogglePlayerListAsync()
    {
        if (IsPlayerListOpenChanged.HasDelegate)
        {
            await IsPlayerListOpenChanged.InvokeAsync(!IsPlayerListOpen);
            return;
        }

        IsPlayerListOpen = !IsPlayerListOpen;
    }

    private static string GetInitials(string? fullName)
    {
        var parts = (fullName ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private static string? ResolvePlayerPhotoUrl(string? photo, int playerId, string? fullName, string? teamName)
    {
        return PlayerPhotoAssetResolver.Resolve(photo, playerId, fullName, teamName);
    }
}
