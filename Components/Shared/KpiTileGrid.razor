@if (Items.Count > 0)
{
    <section class="metric-tape @CssClass" aria-label="Indicateurs cles">
        @foreach (var entry in Items.Select((item, index) => (item, index)))
        {
            <article class="metric-tape__item @(GetToneClass(entry.item.Tone))">
                <span class="metric-tape__index">@((entry.index + 1).ToString("00"))</span>
                <div>
                    <span class="metric-tape__label">@entry.item.Label</span>
                    <strong>@entry.item.Value</strong>
                </div>
                @if (!string.IsNullOrWhiteSpace(entry.item.Context))
                {
                    <small>@entry.item.Context</small>
                }
                <p>@entry.item.Caption</p>
            </article>
        }
    </section>
}

@code {
    [Parameter] public IReadOnlyList<KpiTile> Items { get; set; } = [];
    [Parameter] public string CssClass { get; set; } = string.Empty;

    private static string GetToneClass(string tone) => tone?.ToLowerInvariant() switch
    {
        "positive" => "is-positive",
        "good" => "is-good",
        "warning" => "is-warning",
        "danger" => "is-danger",
        _ => "is-neutral"
    };
}
