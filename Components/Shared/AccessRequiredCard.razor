@inject NavigationManager Navigation

<section class="access-gate">
    <div class="access-gate__visual" aria-hidden="true">
        <span></span><span></span><span></span>
        <strong>LOCKED</strong>
    </div>
    <div class="access-gate__copy">
        <span>Secure workspace</span>
        <h2 data-page-title>@Title</h2>
        <p>@Message</p>
        <div>
            <button type="button" class="primary-button" @onclick="GoToLogin">Ouvrir une session</button>
            <button type="button" class="ghost-button" @onclick="GoToDemo">Visite guidee</button>
        </div>
    </div>
</section>

@code {
    [Parameter] public string Title { get; set; } = "Connexion requise";
    [Parameter] public string Message { get; set; } = "Connectez-vous pour ouvrir cette vue.";
    private void GoToLogin() => Navigation.NavigateTo("/");
    private void GoToDemo() => Navigation.NavigateTo("/demo");
}
