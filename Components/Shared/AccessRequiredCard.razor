@inject NavigationManager Navigation

<StateCard Kicker="Accès requis"
           Title="@Title"
           Message="@Message"
           Tone="warning"
           CssClass="access-card"
           Actions="@Actions">
</StateCard>

@code {
    [Parameter]
    public string Title { get; set; } = "Connexion requise";

    [Parameter]
    public string Message { get; set; } = "Connectez-vous pour ouvrir cette vue.";

    private RenderFragment Actions => builder =>
    {
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "type", "button");
        builder.AddAttribute(2, "class", "primary-button");
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, GoToLogin));
        builder.AddContent(4, "Se connecter");
        builder.CloseElement();

        builder.OpenElement(5, "button");
        builder.AddAttribute(6, "type", "button");
        builder.AddAttribute(7, "class", "ghost-button filter-ghost");
        builder.AddAttribute(8, "onclick", EventCallback.Factory.Create(this, GoToDemo));
        builder.AddContent(9, "Voir la démo");
        builder.CloseElement();
    };

    private void GoToLogin()
    {
        Navigation.NavigateTo("/");
    }

    private void GoToDemo()
    {
        Navigation.NavigateTo("/demo");
    }
}
