@using HandWStat.Models.Analytics

<section class="insight-board">
    <header class="insight-board__head">
        <div>
            <span>@Kicker</span>
            <h3>@Title</h3>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p>@Subtitle</p>
            }
        </div>
        <strong>@_cards.Count.ToString("00")</strong>
    </header>

    @if (_cards.Count == 0)
    {
        <StateCard Kicker="Lecture coach"
                   Title="@EmptyTitle"
                   Message="@EmptyMessage"
                   Tone="empty" />
    }
    else
    {
        <div class="insight-board__grid">
            @foreach (var entry in _cards.Select((card, index) => (card, index)))
            {
                <article class="insight-note insight-note--@GetToneClass(entry.card.Tone)">
                    <span class="insight-note__index">@((entry.index + 1).ToString("00"))</span>
                    <div>
                        <span>@GetTypeLabel(entry.card.Type, entry.card.Label)</span>
                        <p>@entry.card.Sentence</p>
                    </div>
                    <strong>@GetToneLabel(entry.card.Tone)</strong>
                </article>
            }
        </div>
    }
</section>

@code {
    [Parameter] public string Kicker { get; set; } = "Lecture coach";
    [Parameter] public string Title { get; set; } = "Ce que le staff doit retenir";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public IReadOnlyList<CoachCardViewModel> Cards { get; set; } = [];
    [Parameter] public string EmptyTitle { get; set; } = "Choisissez une joueuse pour afficher les insights";
    [Parameter] public string EmptyMessage { get; set; } = "Les signaux condensent forces, fragilites, alertes et adequation au role.";

    private IReadOnlyList<CoachCardViewModel> _cards = [];

    protected override void OnParametersSet()
    {
        _cards = Cards ?? [];
    }

    private static string GetTypeLabel(CoachCardType type, string fallback) => type switch
    {
        CoachCardType.Strength => "Force",
        CoachCardType.Weakness => "Vigilance",
        CoachCardType.Role => "Role",
        CoachCardType.Tactical => "Tactique",
        CoachCardType.Alert => "Alerte",
        _ => fallback
    };

    private static string GetToneClass(string tone) => tone?.ToLowerInvariant() switch
    {
        "positive" => "positive",
        "good" => "good",
        "warning" => "warning",
        "danger" => "danger",
        _ => "neutral"
    };

    private static string GetToneLabel(string tone) => tone?.ToLowerInvariant() switch
    {
        "positive" => "Fort",
        "good" => "Stable",
        "warning" => "A suivre",
        "danger" => "Alerte",
        _ => "Repere"
    };
}
