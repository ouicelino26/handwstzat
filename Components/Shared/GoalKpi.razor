@using System.Globalization

<div class="kpi-shell @(IsLoading ? "is-loading" : string.Empty)" aria-busy="@(IsLoading ? "true" : "false")">
    <div class="map-toolbar">
        <div>
            <p class="map-kicker">Spatial match</p>
            <h4>Lecture rapide des zones et des déclenchements</h4>
        </div>

        <div class="map-mode-toggle" role="group" aria-label="Filtre spatial">
            <button type="button"
                    class="map-mode-button @(IsViewModeActive(ViewModeBoth) ? "is-active" : string.Empty)"
                    aria-pressed="@(IsViewModeActive(ViewModeBoth))"
                    @onclick="() => SetViewModeAsync(ViewModeBoth)">
                Les deux
            </button>
            <button type="button"
                    class="map-mode-button @(IsViewModeActive(ViewModeGoal) ? "is-active" : string.Empty)"
                    aria-pressed="@(IsViewModeActive(ViewModeGoal))"
                    @onclick="() => SetViewModeAsync(ViewModeGoal)">
                Buts
            </button>
            <button type="button"
                    class="map-mode-button @(IsViewModeActive(ViewModeTrigger) ? "is-active" : string.Empty)"
                    aria-pressed="@(IsViewModeActive(ViewModeTrigger))"
                    @onclick="() => SetViewModeAsync(ViewModeTrigger)">
                Déclenchements
            </button>
        </div>
    </div>

    @if (HideZeroZones)
    {
        <p class="tiny-note spatial-focus-note">Vue ciblee: seules les zones actives et la zone selectionnee restent visibles.</p>
    }

    @if (IsLoading)
    {
        <p class="tiny-note spatial-loading-note">Chargement des zones associees...</p>
    }

    @if (ShowGoalMap)
    {
        <section class="map-panel">
            <div class="map-head">
                <div>
                    <p class="map-kicker">But</p>
                    <h4>Precision par secteur</h4>
                </div>

                <div class="heat-legend">
                    <span>@LegendStartLabel</span>
                    <span>@LegendMiddleLabel</span>
                    <span>@LegendEndLabel</span>
                </div>
            </div>

            <div class="goal-map-wrap">
                <svg class="goal-map" viewBox="0 0 804 440" role="img" aria-label="Carte de precision du but">
                    <rect x="0" y="0" width="804" height="440" rx="24" class="goal-bg" />

                    @foreach (var zone in GoalGeometries)
                    {
                        var stat = GetGoalZone(zone.Key);
                        if (!ShouldRenderZone(zone.Key, stat))
                        {
                            continue;
                        }

                        if (zone.Shape == SvgShape.Rect)
                        {
                            <rect x="@Format(zone.X)"
                                  y="@Format(zone.Y)"
                                  width="@Format(zone.Width)"
                                  height="@Format(zone.Height)"
                                  rx="6"
                                  class="zone-shape @(IsActive(zone.Key) ? "zone-active" : string.Empty)"
                                  fill="@GetGoalFillColor(stat)"
                                  stroke="@GetStrokeColor(zone.Key)"
                                  stroke-width="@GetStrokeWidth(zone.Key)"
                                  @onclick="() => SelectZoneAsync(zone.Key)">
                                <title>@GetTooltip(zone.Key, stat)</title>
                            </rect>
                        }
                        else if (zone.Shape == SvgShape.Path)
                        {
                            <path d="@zone.Data"
                                  class="zone-shape @(IsActive(zone.Key) ? "zone-active" : string.Empty)"
                                  fill="@GetGoalFillColor(stat)"
                                  stroke="@GetStrokeColor(zone.Key)"
                                  stroke-width="@GetStrokeWidth(zone.Key)"
                                  @onclick="() => SelectZoneAsync(zone.Key)">
                                <title>@GetTooltip(zone.Key, stat)</title>
                            </path>
                        }
                        else
                        {
                            <polygon points="@zone.Data"
                                     class="zone-shape @(IsActive(zone.Key) ? "zone-active" : string.Empty)"
                                     fill="@GetGoalFillColor(stat)"
                                     stroke="@GetStrokeColor(zone.Key)"
                                     stroke-width="@GetStrokeWidth(zone.Key)"
                                     @onclick="() => SelectZoneAsync(zone.Key)">
                                <title>@GetTooltip(zone.Key, stat)</title>
                            </polygon>
                        }

                        <foreignObject x="@Format(zone.LabelX - 24)"
                                       y="@Format(zone.LabelY - 10)"
                                       width="48"
                                       height="20">
                            <div xmlns="http://www.w3.org/1999/xhtml" class="zone-label">
                                @GetLabel(stat)
                            </div>
                        </foreignObject>
                    }
                </svg>
            </div>
        </section>
    }

    @if (ShowTriggerMap)
    {
        <section class="map-panel">
            <div class="map-head">
                <div>
                    <p class="map-kicker">Terrain</p>
                    <h4>Declenchements et angles</h4>
                </div>
            </div>

            <div class="pitch-map-wrap">
                <svg class="pitch-map" viewBox="0 0 706 464" role="img" aria-label="Carte terrain des declenchements">
                    <image href="/design/pitch-map-template.svg"
                           x="0"
                           y="0"
                           width="706"
                           height="464"
                           preserveAspectRatio="none" />

                    @foreach (var zone in TriggerGeometries)
                    {
                        var stat = GetTriggerZone(zone.Key);
                        if (!ShouldRenderZone(zone.Key, stat))
                        {
                            continue;
                        }

                        <path d="@zone.Data"
                              class="zone-shape trigger-zone @(IsActive(zone.Key) ? "zone-active" : string.Empty)"
                              fill="@GetTriggerFillColor(stat)"
                              stroke="@GetStrokeColor(zone.Key)"
                              stroke-width="@GetStrokeWidth(zone.Key)"
                              @onclick="() => SelectZoneAsync(zone.Key)">
                            <title>@GetTooltip(zone.Key, stat)</title>
                        </path>

                    }
                </svg>
            </div>
        </section>
    }
</div>

