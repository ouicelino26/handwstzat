    private static readonly HeatColorStop[] HeatPalette = Enumerable.Range(0, ChartPalette.GoalHeatColors.Length)
        .Select(index => new HeatColorStop(ChartPalette.GoalHeatStops[index], ChartPalette.GoalHeatColors[index]))
        .ToArray();

    private ZoneStat GetGoalZone(string key) => GoalZones.FirstOrDefault(zone => zone.Key == key) ?? Empty(key);

    private ZoneStat GetTriggerZone(string key) => TriggerZones.FirstOrDefault(zone => zone.Key == key) ?? Empty(key);

    private static ZoneStat Empty(string key) => new(key, key, 0, 0, 0, Array.Empty<OutcomeCount>());

    private string GetLabel(ZoneStat zone)
    {
        return zone.Attempts == 0
            ? "0%"
            : zone.Rate.ToString("0.#", CultureInfo.GetCultureInfo("fr-FR")) + "%";
    }

    private bool IsActive(string key)
    {
        return string.Equals(ActiveZoneKey, key, StringComparison.OrdinalIgnoreCase);
    }

    private async Task SelectZoneAsync(string key)
    {
        if (OnZoneSelected.HasDelegate)
        {
            await OnZoneSelected.InvokeAsync(key);
        }
    }

    private bool ShowGoalMap => string.Equals(ViewMode, ViewModeBoth, StringComparison.OrdinalIgnoreCase)
        || string.Equals(ViewMode, ViewModeGoal, StringComparison.OrdinalIgnoreCase);

    private bool ShowTriggerMap => string.Equals(ViewMode, ViewModeBoth, StringComparison.OrdinalIgnoreCase)
        || string.Equals(ViewMode, ViewModeTrigger, StringComparison.OrdinalIgnoreCase);

    private bool IsViewModeActive(string mode) => string.Equals(ViewMode, mode, StringComparison.OrdinalIgnoreCase);

    private async Task SetViewModeAsync(string mode)
    {
        ViewMode = mode;

        if (ViewModeChanged.HasDelegate)
        {
            await ViewModeChanged.InvokeAsync(mode);
        }
    }

    private string GetTooltip(string key, ZoneStat stat)
    {
        return $"{key} - {stat.Rate.ToString("0.#", CultureInfo.GetCultureInfo("fr-FR"))}%\n" +
               $"Volume : {stat.Attempts}\n" +
               $"Succes : {stat.Successes}\n" +
               $"Echecs : {stat.Failures}";
    }

    private string LegendStartLabel => IsGoalkeeper
        ? $"{SpatialZoneVisuals.GoalkeeperHeatMinRate:0}%"
        : "0%";

    private string LegendMiddleLabel => IsGoalkeeper
        ? $"{((SpatialZoneVisuals.GoalkeeperHeatMinRate + SpatialZoneVisuals.GoalkeeperHeatMaxRate) / 2d):0}%"
        : "50%";

    private string LegendEndLabel => IsGoalkeeper
        ? $"{SpatialZoneVisuals.GoalkeeperHeatMaxRate:0}%+"
        : "100%";

    private string GetGoalFillColor(ZoneStat zone)
    {
        return zone.Attempts == 0
            ? NeutralGoalZoneFill
            : GetFillColor(GetPaletteRate(zone.Rate));
    }

    private double GetPaletteRate(double rawRate) => SpatialZoneVisuals.ToPaletteRate(rawRate, IsGoalkeeper);

    private static string GetFillColor(double rate)
    {
        var boundedRate = Math.Clamp(rate, 0, 100);

        for (var index = 1; index < HeatPalette.Length; index++)
        {
            var previous = HeatPalette[index - 1];
            var current = HeatPalette[index];

            if (boundedRate <= current.Stop)
            {
                var span = current.Stop - previous.Stop;
                var progress = span <= 0 ? 0 : (boundedRate - previous.Stop) / span;
                return InterpolateColor(previous.Color, current.Color, progress);
            }
        }

        return HeatPalette[^1].Color;
    }

    private string GetTriggerFillColor(ZoneStat zone)
    {
        return zone.Attempts == 0 ? "transparent" : GetFillColor(GetPaletteRate(zone.Rate));
    }

    private static string InterpolateColor(string startHex, string endHex, double progress)
    {
        var boundedProgress = Math.Clamp(progress, 0, 1);
        var (startR, startG, startB) = ParseHexColor(startHex);
        var (endR, endG, endB) = ParseHexColor(endHex);

        var red = (int)Math.Round(startR + ((endR - startR) * boundedProgress), MidpointRounding.AwayFromZero);
        var green = (int)Math.Round(startG + ((endG - startG) * boundedProgress), MidpointRounding.AwayFromZero);
        var blue = (int)Math.Round(startB + ((endB - startB) * boundedProgress), MidpointRounding.AwayFromZero);

        return $"#{red:X2}{green:X2}{blue:X2}";
    }

    private static (int Red, int Green, int Blue) ParseHexColor(string hex)
    {
        return (
            int.Parse(hex.Substring(1, 2), NumberStyles.HexNumber, CultureInfo.InvariantCulture),
            int.Parse(hex.Substring(3, 2), NumberStyles.HexNumber, CultureInfo.InvariantCulture),
            int.Parse(hex.Substring(5, 2), NumberStyles.HexNumber, CultureInfo.InvariantCulture));
    }

    private string GetStrokeColor(string key)
    {
        if (SpatialZoneVisuals.IsTriggerZoneKey(key))
        {
            return IsActive(key) ? ChartPalette.GoalStrokeActive : "transparent";
        }

        return IsActive(key) ? ChartPalette.GoalStrokeInactive : ChartPalette.TriggerStrokeInactive;
    }

    private string GetStrokeWidth(string key)
    {
        if (SpatialZoneVisuals.IsTriggerZoneKey(key))
        {
            return IsActive(key) ? "3.5" : "0";
        }

        return IsActive(key) ? "4" : "2";
    }

    private bool ShouldRenderZone(string key, ZoneStat stat)
    {
        return !HideZeroZones || stat.Attempts > 0 || IsActive(key);
    }

    private static string Format(double value)
    {
        return value.ToString("0.###", CultureInfo.InvariantCulture);
    }

    private sealed record ZoneGeometry(
        string Key,
        SvgShape Shape,
