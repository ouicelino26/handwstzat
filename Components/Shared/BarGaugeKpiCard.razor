<article class="metric-orbit @GetToneClass(Item.Tone)">
    <div class="metric-orbit__copy">
        <span>@Item.Label</span>
        <strong>@Item.Value</strong>
        @if (!string.IsNullOrWhiteSpace(Item.Context))
        {
            <small>@Item.Context</small>
        }
        <p>@Item.Caption</p>
    </div>

    <div class="metric-orbit__visual"
         role="img"
         aria-label="@GetAriaLabel()">
        <svg viewBox="0 0 120 120" aria-hidden="true">
            <circle class="metric-orbit__track" cx="60" cy="60" r="48"></circle>
            <circle class="metric-orbit__value"
                    cx="60"
                    cy="60"
                    r="48"
                    pathLength="100"
                    stroke-dasharray="@($"{GaugePercent:0.##} {100d - GaugePercent:0.##}")"></circle>
        </svg>
        <span>@($"{GaugePercent:0}")</span>
    </div>
</article>

@code {
    [Parameter]
    public BarGaugeKpiItem Item { get; set; } = new("KPI", "0%", 0, string.Empty);

    private double GaugePercent
    {
        get
        {
            if (!double.IsFinite(Item.GaugeValue) || Item.Max <= Item.Min)
            {
                return 0;
            }

            return Math.Clamp((Item.GaugeValue - Item.Min) * 100d / (Item.Max - Item.Min), 0d, 100d);
        }
    }

    private string GetAriaLabel() => $"{Item.Label} {Item.Value}. {Item.Caption}";

    private static string GetToneClass(string tone) => tone?.ToLowerInvariant() switch
    {
        "positive" => "is-positive",
        "good" => "is-good",
        "warning" => "is-warning",
        "danger" => "is-danger",
        _ => "is-neutral"
    };
}
