<div class="studio-sync" role="status" aria-live="polite" aria-busy="true">
    <div class="studio-sync__panel">
        <div class="studio-sync__meter" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
        </div>
        <div class="studio-sync__copy">
            <span>@Kicker</span>
            <strong>@Title</strong>
            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <small>@Message</small>
            }
        </div>
        <div class="studio-sync__skeleton" aria-hidden="true">
            <i></i><i></i><i></i>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Kicker { get; set; } = "Synchronisation";
    [Parameter] public string Title { get; set; } = "Preparation de la scene";
    [Parameter] public string? Message { get; set; } = "Le contexte et les donnees sont actualises.";
}
