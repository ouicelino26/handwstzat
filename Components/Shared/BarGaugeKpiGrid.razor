@if (Items.Count > 0)
{
    <section class="metric-orbit-grid @CssClass" aria-label="Indicateurs de performance">
        @foreach (var item in Items)
        {
            <BarGaugeKpiCard @key="item.Label" Item="item" />
        }
    </section>
}

@code {
    [Parameter]
    public IReadOnlyList<BarGaugeKpiItem> Items { get; set; } = [];

    [Parameter]
    public string CssClass { get; set; } = string.Empty;
}
