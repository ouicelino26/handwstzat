@if (IsOpen)
{
    <div class="drawer-overlay" @onclick="CloseAsync" aria-hidden="true"></div>
    <aside class="drawer-panel @(IsOpen ? "is-open" : string.Empty)" role="dialog" aria-modal="true" aria-label="@Title">
        <div class="drawer-header">
            <h2 class="drawer-title">@Title</h2>
            <button type="button" class="drawer-close icon-button" @onclick="CloseAsync" aria-label="Fermer">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18 6 6 18M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div class="drawer-body">
            @ChildContent
        </div>
        @if (FooterContent is not null)
        {
            <div class="drawer-footer">
                @FooterContent
            </div>
        }
    </aside>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }

    private async Task CloseAsync()
    {
        await IsOpenChanged.InvokeAsync(false);
    }
}
