<section class="evidence-table">
    <header class="evidence-table__head">
        <div>
            <span>@Kicker</span>
            <h3>@Title</h3>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p>@Subtitle</p>
            }
        </div>
        @if (_sortedRows.Count > 0)
        {
            <div>
                <span>@_sortedRows.Count axes</span>
                <strong>Impact ↓</strong>
            </div>
        }
    </header>

    @if (_sortedRows.Count == 0)
    {
        <StateCard Kicker="Evidence"
                   Title="@EmptyTitle"
                   Message="@EmptyMessage"
                   Tone="empty" />
    }
    else
    {
        <div class="table-wrap">
            <table class="stat-table position-profile-table">
                <thead>
                    <tr>
                        <th scope="col">Axe</th>
                        <th scope="col">Joueuse</th>
                        <th scope="col">Mediane</th>
                        <th scope="col">Delta</th>
                        <th scope="col">Percentile favorable</th>
                        <th scope="col">Lecture</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var axis in _sortedRows)
                    {
                        <tr class="@GetRowClass(axis)" title="@axis.TooltipDeltaTitle">
                            <td>
                                <div class="table-primary-cell">
                                    <strong>@axis.Label</strong>
                                    <span>@axis.Category</span>
                                </div>
                            </td>
                            <td><strong>@axis.PlayerDisplayValue</strong></td>
                            <td>@axis.MedianDisplayValue</td>
                            <td class="@GetDeltaCellClass(axis)" title="@GetDeltaTooltip(axis)">@axis.DeltaDisplayValue</td>
                            <td><span class="axis-badge axis-badge-@axis.StatusTone">@FormatPercentile(axis.DirectionalPercentile)</span></td>
                            <td>
                                <div class="axis-insight-cell">
                                    <strong>@axis.StatusLabel</strong>
                                    <span>@axis.Summary</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    [Parameter] public string Kicker { get; set; } = "Evidence";
    [Parameter] public string Title { get; set; } = "Lecture axe par axe";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public IReadOnlyList<PositionProfileAxisViewModel> Rows { get; set; } = [];
    [Parameter] public IReadOnlyCollection<string> HighlightedAxisKeys { get; set; } = [];
    [Parameter] public IReadOnlyCollection<string> AlertAxisKeys { get; set; } = [];
    [Parameter] public string EmptyTitle { get; set; } = "Aucune donnee detaillee";
    [Parameter] public string EmptyMessage { get; set; } = "Selectionnez une joueuse et un scope pour construire le tableau.";

    private IReadOnlyList<PositionProfileAxisViewModel> _sortedRows = [];
    private HashSet<string> _highlightedAxisKeys = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _alertAxisKeys = new(StringComparer.OrdinalIgnoreCase);

    protected override void OnParametersSet()
    {
        _sortedRows = Rows.OrderByDescending(axis => axis.Impact).ThenBy(axis => axis.Label).ToList();
        _highlightedAxisKeys = new HashSet<string>(HighlightedAxisKeys ?? [], StringComparer.OrdinalIgnoreCase);
        _alertAxisKeys = new HashSet<string>(AlertAxisKeys ?? [], StringComparer.OrdinalIgnoreCase);
    }

    private static string GetDeltaTooltip(PositionProfileAxisViewModel axis) =>
        $"Valeur joueuse moins mediane du poste. {axis.Summary}";

    private static string GetDeltaCellClass(PositionProfileAxisViewModel axis) => axis.Bucket switch
    {
        PositionProfileScatterBucket.Above => "metric-cell metric-cell-positive",
        PositionProfileScatterBucket.Level => "metric-cell metric-cell-warning",
        _ => "metric-cell metric-cell-danger"
    };

    private string GetRowClass(PositionProfileAxisViewModel axis) =>
        _alertAxisKeys.Contains(axis.Key) ? "is-alert"
        : _highlightedAxisKeys.Contains(axis.Key) ? "is-highlighted"
        : string.Empty;

    private static string FormatPercentile(double value) => $"{value:0.#}%";
}
