@if (Profile is not null)
{
    var orderedHistory = GetOrderedHistory();
    var primaryHistory = GetPrimaryHistory(orderedHistory, Profile);
    var otherHistory = GetOtherHistory(orderedHistory, primaryHistory);
    var clubCount = orderedHistory.Count;

    <section class="career-line @CssClass">
        <header class="career-line__head">
            @if (!string.IsNullOrWhiteSpace(Kicker))
            {
                <span>@Kicker</span>
            }

            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <h3>@Title</h3>
            }

            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p>@Subtitle</p>
            }
            <strong>@clubCount.ToString("00")</strong>
        </header>

        <div class="career-line__track">
            <article class="career-stop career-stop--current @(primaryHistory is not null ? "has-history" : "is-empty")">
                <span class="career-stop__marker" aria-hidden="true"></span>
                <div class="career-stop__identity">
                    <span>Club principal</span>
                    <strong>@(Profile.TeamName ?? "Equipe non renseignee")</strong>
                    <small>@GetCurrentNote(primaryHistory, orderedHistory.Count)</small>
                </div>

                @if (primaryHistory is not null)
                {
                    <div class="career-stop__metrics">
                        <div><span>Matchs</span><strong>@primaryHistory.MatchesPlayed</strong></div>
                        <div><span>Minutes</span><strong>@FormatMinutes(primaryHistory.PlayingTimeMinutes)</strong></div>
                        <div><span>Events</span><strong>@primaryHistory.EventCount</strong></div>
                    </div>
                }
            </article>

            @if (otherHistory.Count > 0)
            {
                @foreach (var item in otherHistory)
                {
                    <article class="career-stop">
                        <span class="career-stop__marker" aria-hidden="true"></span>
                        <div class="career-stop__identity">
                            <span>Historique</span>
                            <strong>@GetTeamLabel(item)</strong>
                        </div>
                        <div class="career-stop__metrics">
                            <div><span>Matchs</span><strong>@item.MatchesPlayed</strong></div>
                            <div><span>Minutes</span><strong>@FormatMinutes(item.PlayingTimeMinutes)</strong></div>
                            <div><span>Events</span><strong>@item.EventCount</strong></div>
                            </div>
                    </article>
                }
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Footnote))
        {
            <p class="career-line__note">@Footnote</p>
        }
    </section>
}

@code {
    [Parameter]
    public PlayerListItemDto? Profile { get; set; }

    [Parameter]
    public string Kicker { get; set; } = "Historique de club";

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Subtitle { get; set; } = "";

    [Parameter]
    public string Footnote { get; set; } = "";

    [Parameter]
    public string CssClass { get; set; } = string.Empty;

    private IReadOnlyList<PlayerTeamHistoryDto> GetOrderedHistory()
    {
        if (Profile is null || Profile.TeamHistory.Count == 0)
        {
            return [];
        }

        return Profile.TeamHistory
            .OrderByDescending(item => MatchesProfileTeam(item, Profile) ? 1 : 0)
            .ThenByDescending(item => item.MatchesPlayed)
            .ThenByDescending(item => item.PlayingTimeMinutes)
            .ThenBy(item => GetTeamLabel(item), StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static PlayerTeamHistoryDto? GetPrimaryHistory(IReadOnlyList<PlayerTeamHistoryDto> history, PlayerListItemDto profile)
    {
        if (history.Count == 0)
        {
            return null;
        }

        return history.FirstOrDefault(item => MatchesProfileTeam(item, profile));
    }

    private static IReadOnlyList<PlayerTeamHistoryDto> GetOtherHistory(IReadOnlyList<PlayerTeamHistoryDto> history, PlayerTeamHistoryDto? primaryHistory)
    {
        if (history.Count == 0)
        {
            return [];
        }

        if (primaryHistory is null)
        {
            return history;
        }

        return history.Where(item => !ReferenceEquals(item, primaryHistory)).ToList();
    }

    private static bool MatchesProfileTeam(PlayerTeamHistoryDto item, PlayerListItemDto profile)
    {
        if (profile.TeamId.HasValue && item.TeamId.HasValue && profile.TeamId.Value == item.TeamId.Value)
        {
            return true;
        }

        if (!string.IsNullOrWhiteSpace(profile.TeamCode) && !string.IsNullOrWhiteSpace(item.TeamCode) && string.Equals(profile.TeamCode.Trim(), item.TeamCode.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        if (!string.IsNullOrWhiteSpace(profile.TeamName) && !string.IsNullOrWhiteSpace(item.TeamName) && string.Equals(profile.TeamName.Trim(), item.TeamName.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    private static string GetTeamLabel(PlayerTeamHistoryDto item)
    {
        return item.TeamName ?? item.TeamCode ?? "Equipe non renseignee";
    }

    private static string GetCurrentNote(PlayerTeamHistoryDto? primaryHistory, int historyCount)
    {
        if (historyCount == 0)
        {
            return "Aucun historique detaille n'est disponible dans la reponse courante.";
        }

        if (primaryHistory is null)
        {
            return "Aucune entree historique ne correspond au club principal du profil; les autres clubs observes sont affiches ci-dessous.";
        }

        if (historyCount == 1)
        {
            return "Un seul club est remonte dans le perimetre courant.";
        }

        return "Le club principal du profil est detaille ci-dessus; les autres clubs observes sont affiches plus bas.";
    }

    private static string FormatMinutes(double value)
    {
        var formatted = HandballKpiHelper.FormatNumber(value);
        return $"{formatted} min";
    }
}
