@using HandWStat.Models.Analytics

@if (!string.IsNullOrWhiteSpace(Title) || Items.Count > 0 || !string.IsNullOrWhiteSpace(Message))
{
    <section class="evidence-strip @CssClass">
        <div class="evidence-strip__intro">
            @if (!string.IsNullOrWhiteSpace(Kicker))
            {
                <span>@Kicker</span>
            }
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <strong>@Title</strong>
            }
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <small>@Subtitle</small>
            }
        </div>

        @if (Items.Count > 0)
        {
            <div class="evidence-strip__facts">
                @foreach (var item in Items)
                {
                    <article>
                        <span>@item.Label</span>
                        <strong>@item.Value</strong>
                    </article>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <p>@Message</p>
        }
    </section>
}

@code {
    [Parameter] public string? Kicker { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public IReadOnlyList<ScopeSummaryItem> Items { get; set; } = [];
    [Parameter] public string CssClass { get; set; } = string.Empty;
}
