<section class="studio-state @ToneClass @CssClass"
         data-state="@Tone"
         role="@Role"
         aria-live="@AriaLive"
         aria-busy="@IsBusy">
    <div class="studio-state__signal" aria-hidden="true">
        <span>@StateSymbol</span>
    </div>

    <div class="studio-state__body">
        @if (!string.IsNullOrWhiteSpace(Kicker))
        {
            <span class="studio-state__kicker">@Kicker</span>
        }

        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <h2 data-page-title>@Title</h2>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <p>@Message</p>
        }

        @if (ChildContent is not null)
        {
            <div class="studio-state__content">
                @ChildContent
            </div>
        }

        @if (Actions is not null)
        {
            <div class="studio-state__actions">
                @Actions
            </div>
        }
    </div>

    <div class="studio-state__code" aria-hidden="true">@StateCode</div>
</section>

@code {
    [Parameter] public string? Kicker { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public string Tone { get; set; } = "neutral";
    [Parameter] public string CssClass { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    private string ToneClass => $"studio-state--{Tone?.ToLowerInvariant() ?? "neutral"}";
    private bool IsBusy => string.Equals(Tone, "loading", StringComparison.OrdinalIgnoreCase);
    private string StateSymbol => Tone?.ToLowerInvariant() switch
    {
        "loading" => "···",
        "error" => "!",
        "success" => "✓",
        "warning" => "△",
        "empty" => "○",
        _ => "•"
    };
    private string StateCode => Tone?.ToUpperInvariant() switch
    {
        "ERROR" => "ERR",
        "LOADING" => "SYNC",
        "WARNING" => "CHECK",
        "EMPTY" => "NULL",
        "SUCCESS" => "OK",
        _ => "INFO"
    };
    private string Role => Tone?.ToLowerInvariant() switch
    {
        "error" => "alert",
        "loading" or "success" => "status",
        _ => "region"
    };
    private string AriaLive => Tone?.ToLowerInvariant() switch
    {
        "error" => "assertive",
        "loading" or "success" => "polite",
        _ => "off"
    };
}
