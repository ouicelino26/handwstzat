<section class="state-card @ToneClass @CssClass"
         role="@Role"
         aria-live="@AriaLive"
         aria-busy="@IsBusy">
    <div class="state-card-mark" aria-hidden="true"></div>

    <div class="state-card-copy">
        @if (!string.IsNullOrWhiteSpace(Kicker))
        {
            <p class="section-kicker">@Kicker</p>
        }

        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <h3>@Title</h3>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <p class="page-subtitle">@Message</p>
        }
    </div>

    @if (ChildContent is not null)
    {
        <div class="state-card-content">
            @ChildContent
        </div>
    }

    @if (Actions is not null)
    {
        <div class="toolbar state-card-actions">
            @Actions
        </div>
    }
</section>

@code {
    [Parameter]
    public string? Kicker { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Message { get; set; }

    [Parameter]
    public string Tone { get; set; } = "neutral";

    [Parameter]
    public string CssClass { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    private string ToneClass => Tone?.ToLowerInvariant() switch
    {
        "loading" => "is-loading",
        "empty" => "is-empty",
        "error" => "is-error",
        "success" => "is-success",
        "warning" => "is-warning",
        _ => "is-neutral"
    };

    private bool IsBusy => string.Equals(Tone, "loading", StringComparison.OrdinalIgnoreCase);

    private string Role => Tone?.ToLowerInvariant() switch
    {
        "error" => "alert",
        "loading" => "status",
        "success" => "status",
        _ => "region"
    };

    private string AriaLive => Tone?.ToLowerInvariant() switch
    {
        "error" => "assertive",
        "loading" => "polite",
        "success" => "polite",
        _ => "off"
    };
}
