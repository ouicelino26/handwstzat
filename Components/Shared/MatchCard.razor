<article class="game-ticket @(IsSelected ? "is-selected" : string.Empty)">
    <header class="game-ticket__meta">
        @if (!string.IsNullOrWhiteSpace(Kicker))
        {
            <span>@Kicker</span>
        }

        @if (!string.IsNullOrWhiteSpace(Badge))
        {
            <strong>@Badge</strong>
        }
    </header>

    @if (!_hasTeamPair && !string.IsNullOrWhiteSpace(_headline))
    {
        <h3 class="game-ticket__title">@_headline</h3>
    }

    <div class="game-ticket__score @(_hasScorePair ? string.Empty : "is-single")">
        @if (_hasScorePair)
        {
            <div class="game-ticket__team">
                @if (_hasTeamPair)
                {
                    <div class="game-ticket__team-lockup">
                        <span class="game-ticket__crest">
                            @if (!string.IsNullOrWhiteSpace(_homeLogoUrl))
                            {
                                <img src="@_homeLogoUrl"
                                     alt="@($"Logo {_homeTeam}")"
                                     loading="lazy"
                                     onerror="@LogoFallbackScript" />
                            }
                            else
                            {
                                <span>@GetTeamInitials(_homeTeam)</span>
                            }
                        </span>
                        <span class="game-ticket__team-name">@_homeTeam</span>
                    </div>
                }
                <strong>@_homeScore</strong>
            </div>

            <i aria-hidden="true">:</i>

            <div class="game-ticket__team game-ticket__team--away">
                @if (_hasTeamPair)
                {
                    <div class="game-ticket__team-lockup game-ticket__team-lockup--away">
                        <span class="game-ticket__crest">
                            @if (!string.IsNullOrWhiteSpace(_awayLogoUrl))
                            {
                                <img src="@_awayLogoUrl"
                                     alt="@($"Logo {_awayTeam}")"
                                     loading="lazy"
                                     onerror="@LogoFallbackScript" />
                            }
                            else
                            {
                                <span>@GetTeamInitials(_awayTeam)</span>
                            }
                        </span>
                        <span class="game-ticket__team-name">@_awayTeam</span>
                    </div>
                }
                <strong>@_awayScore</strong>
            </div>
        }
        else
        {
            <strong>@Score</strong>
        }
    </div>

    @if (ChildContent is not null)
    {
        <div class="game-ticket__extra">
            @ChildContent
        </div>
    }

    <footer class="game-ticket__footer">
        <div>
            @if (!string.IsNullOrWhiteSpace(Meta))
            {
                <strong>@Meta</strong>
            }

            @if (!string.IsNullOrWhiteSpace(SecondaryMeta))
            {
                <small>@SecondaryMeta</small>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(DetailsHref) || OnCardClick.HasDelegate)
        {
            <div class="game-ticket__action">
                @if (!string.IsNullOrWhiteSpace(DetailsHref))
                {
                    <a href="@DetailsHref"><span>@DetailsLabel</span><span aria-hidden="true">→</span></a>
                }
                else
                {
                    <button type="button"
                            @onclick="HandleCardClickAsync">
                        <span>@DetailsLabel</span><span aria-hidden="true">→</span>
                    </button>
                }
            </div>
        }
    </footer>
</article>

@code {
    [Parameter]
    public string Title { get; set; } = "Match";

    [Parameter]
    public string Score { get; set; } = "-";

    [Parameter]
    public IReadOnlyList<TeamDto> Teams { get; set; } = [];

    [Parameter]
    public string? Season { get; set; }

    [Parameter]
    public string? HomeTeamLogoUrl { get; set; }

    [Parameter]
    public string? AwayTeamLogoUrl { get; set; }

    [Parameter]
    public string? Kicker { get; set; }

    [Parameter]
    public string? Meta { get; set; }

    [Parameter]
    public string? SecondaryMeta { get; set; }

    [Parameter]
    public string? Badge { get; set; }

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public string DetailsHref { get; set; } = string.Empty;

    [Parameter]
    public string DetailsLabel { get; set; } = "Voir plus";

    [Parameter]
    public EventCallback OnCardClick { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string _headline = string.Empty;

    private string? _homeTeam;

    private string? _awayTeam;

    private string? _homeScore;

    private string? _awayScore;

    private string? _homeLogoUrl;

    private string? _awayLogoUrl;

    private bool _hasTeamPair;

    private bool _hasScorePair;

    private const string LogoFallbackScript = "this.onerror=null;this.src=this.src.includes('/2025-2026/')?this.src.replace('/2025-2026/','/2024-2025/'):this.src.replace('/2024-2025/','/2025-2026/');";

    protected override void OnParametersSet()
    {
        _headline = (Title ?? string.Empty).Trim();

        if (TrySplitTeams(_headline, out var homeTeam, out var awayTeam))
        {
            _homeTeam = homeTeam;
            _awayTeam = awayTeam;
            _hasTeamPair = true;
            _homeLogoUrl = HomeTeamLogoUrl ?? TeamLogoAssetResolver.ResolveByName(Teams, homeTeam, Season);
            _awayLogoUrl = AwayTeamLogoUrl ?? TeamLogoAssetResolver.ResolveByName(Teams, awayTeam, Season);
        }
        else
        {
            _homeTeam = null;
            _awayTeam = null;
            _homeLogoUrl = null;
            _awayLogoUrl = null;
            _hasTeamPair = false;
        }

        if (TrySplitScore(Score, out var homeScore, out var awayScore))
        {
            _homeScore = homeScore;
            _awayScore = awayScore;
            _hasScorePair = true;
        }
        else
        {
            _homeScore = null;
            _awayScore = null;
            _hasScorePair = false;
        }
    }

    private Task HandleCardClickAsync()
    {
        return OnCardClick.HasDelegate ? OnCardClick.InvokeAsync() : Task.CompletedTask;
    }

    private static bool TrySplitTeams(string? value, out string? homeTeam, out string? awayTeam)
    {
        homeTeam = null;
        awayTeam = null;

        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var separatorIndex = value.IndexOf(" vs ", StringComparison.OrdinalIgnoreCase);
        if (separatorIndex < 0)
        {
            return false;
        }

        homeTeam = value[..separatorIndex].Trim();
        awayTeam = value[(separatorIndex + 4)..].Trim();

        return !string.IsNullOrWhiteSpace(homeTeam) && !string.IsNullOrWhiteSpace(awayTeam);
    }

    private static bool TrySplitScore(string? value, out string? homeScore, out string? awayScore)
    {
        homeScore = null;
        awayScore = null;

        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var parts = value.Split('-', 2, StringSplitOptions.TrimEntries);
        if (parts.Length != 2)
        {
            return false;
        }

        homeScore = parts[0];
        awayScore = parts[1];

        return !string.IsNullOrWhiteSpace(homeScore) && !string.IsNullOrWhiteSpace(awayScore);
    }

    private static string GetTeamInitials(string? teamName)
    {
        var parts = (teamName ?? "HB")
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(part => part.Length > 1)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]));

        var initials = string.Concat(parts);
        return string.IsNullOrWhiteSpace(initials) ? "HB" : initials;
    }
}
