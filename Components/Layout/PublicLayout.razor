@inherits LayoutComponentBase

<div class="studio-public-shell">
    <div class="studio-public-shell__grid" aria-hidden="true"></div>
    <header class="studio-public-shell__brand">
        <span class="studio-wordmark__symbol" aria-hidden="true">
            <svg viewBox="0 0 40 40">
                <path d="M6 28 13 12l7 16 7-16 7 16"></path>
                <path d="M5 32h30"></path>
                <circle cx="20" cy="8" r="2.5"></circle>
            </svg>
        </span>
        <span>
            <strong>HandWStat</strong>
            <small>Performance intelligence</small>
        </span>
    </header>

    <main class="studio-public-stage">
        @Body
    </main>

    <footer class="studio-public-shell__footer">
        <span>Handball analytics studio</span>
        <span>2026 edition</span>
    </footer>
</div>
