<nav class="studio-domain-nav" aria-label="Domaines principaux">
    @foreach (var item in AppNavigationCatalog.Primary)
    {
        <NavLink href="@item.Href"
                 Match="@item.Match"
                 @onclick="NotifyNavigationAsync"
                 title="@item.Label">
            <span class="studio-domain-nav__icon" aria-hidden="true">@((MarkupString)item.IconMarkup)</span>
            <span class="studio-domain-nav__copy">
                <strong>@item.Label</strong>
                <small>@item.Kicker</small>
            </span>
            <span class="studio-domain-nav__index">@item.Index</span>
        </NavLink>
    }
</nav>

@code {
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private Task NotifyNavigationAsync() => OnNavigate.InvokeAsync();
}
