<nav class="nav-rail">
    @foreach (var item in Items)
    {
        <NavLink class="nav-link" href="@item.Href" Match="@item.Match" @onclick="NotifyNavigationAsync" title="@item.Title">
            <span class="nav-icon" aria-hidden="true">@((MarkupString)item.IconMarkup)</span>

            @if (!Collapsed)
            {
                <span class="nav-copy">
                    <strong>@item.Title</strong>
                    <small>@item.Description</small>
                </span>
            }
        </NavLink>
    }
</nav>

@code {
    [Parameter]
    public bool Collapsed { get; set; }

    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private static IReadOnlyList<NavItem> Items { get; } =
    [
        new(
            "dashboard",
            "Tableau",
            "Synthese",
            NavLinkMatch.All,
            """
            <svg viewBox="0 0 24 24"><path d="M4 13h4v7H4zM10 9h4v11h-4zM16 5h4v15h-4zM4 4h16" /></svg>
            """),
        new(
            "players",
            "Joueuses",
            "Fiches",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M12 6a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM5 20a7 7 0 0 1 14 0M3 10l4 2m14-2-4 2" /></svg>
            """),
        new(
            "compare",
            "Comparaison",
            "Face a face",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M7 5h4v14H7zM13 9h4v10h-4zM4 20h16M9 5V3m6 6V3" /></svg>
            """),
        new(
            "position-profiles",
            "Profil poste",
            "Mediane /60",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M12 3l7 4v10l-7 4-7-4V7l7-4Zm0 4.2-3.8 2.2v4.4L12 16l3.8-2.2V9.4L12 7.2Zm0-4.2v4.2" /></svg>
            """),
        new(
            "teams",
            "Equipes",
            "Collectif",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M12 3l8 4v6c0 4.5-3.3 7.6-8 8-4.7-.4-8-3.5-8-8V7l8-4Z" /><path d="M8.5 12h7" /></svg>
            """),
        new(
            "matches",
            "Matchs",
            "Rencontres",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M5 5h14v14H5zM5 9h14M9 5v14" /></svg>
            """)
    ];

    private Task NotifyNavigationAsync()
    {
        return OnNavigate.InvokeAsync();
    }

    private sealed record NavItem(
        string Href,
        string Title,
        string Description,
        NavLinkMatch Match,
        string IconMarkup);
}
