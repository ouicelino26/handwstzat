@inherits LayoutComponentBase
@implements IDisposable
@inject IApiAuthService AuthService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="studio-shell @(IsDomainDrawerOpen ? "domain-drawer-open" : string.Empty) @(IsContextLensOpen ? "context-lens-open" : string.Empty)">
    <header class="studio-commandbar">
        <div class="studio-commandbar__brand">
            <button type="button"
                    class="studio-icon-button studio-domain-trigger"
                    @onclick="ToggleDomainDrawer"
                    aria-label="Ouvrir les domaines">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>

            <NavLink href="dashboard" class="studio-wordmark" aria-label="HandWStat Studio, accueil">
                <span class="studio-wordmark__symbol" aria-hidden="true">
                    <svg viewBox="0 0 40 40">
                        <path d="M6 28 13 12l7 16 7-16 7 16"></path>
                        <path d="M5 32h30"></path>
                        <circle cx="20" cy="8" r="2.5"></circle>
                    </svg>
                </span>
                <span>
                    <strong>HWS</strong>
                    <small>Studio</small>
                </span>
            </NavLink>
        </div>

        <button type="button"
                class="studio-command-search"
                @onclick="OpenCommandPalette"
                aria-label="Ouvrir la recherche universelle">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5"></circle><path d="m15.5 15.5 5 5"></path></svg>
            <span>Joueuse, equipe, match ou commande</span>
            <kbd>Ctrl K</kbd>
        </button>

        <div class="studio-commandbar__actions">
            <NavLink href="compare" class="studio-create-button">
                <span aria-hidden="true">+</span>
                <span>Nouvelle analyse</span>
            </NavLink>

            <button type="button"
                    class="studio-icon-button"
                    @onclick="ToggleThemeAsync"
                    aria-label="@ThemeToggleTitle"
                    aria-pressed="@IsDarkTheme">
                @if (IsDarkTheme)
                {
                    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2m0 16v2M2 12h2m16 0h2M5 5l1.5 1.5m11 11L19 19M19 5l-1.5 1.5m-11 11L5 19"></path></svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 15.5A8 8 0 0 1 8.5 4 8.5 8.5 0 1 0 20 15.5Z"></path></svg>
                }
            </button>

            <button type="button"
                    class="studio-account"
                    @onclick="ToggleContextLens"
                    aria-expanded="@IsContextLensOpen"
                    aria-label="Ouvrir le panneau de session">
                <span class="studio-account__status" aria-hidden="true"></span>
                <span class="studio-account__copy">
                    <strong>@AccountName</strong>
                    <small>@AccountRole</small>
                </span>
                <span class="studio-account__avatar">@AccountInitials</span>
            </button>
        </div>
    </header>

    <aside class="studio-domain-rail" aria-label="Domaines HandWStat">
        <div class="studio-domain-rail__index">
            <span>@CurrentPageIndex</span>
        </div>

        <NavMenu OnNavigate="HandleNavigationAsync" />

        <div class="studio-domain-rail__utility">
            <NavLink href="position-profiles"
                     class="studio-domain-utility"
                     title="Benchmark de poste"
                     @onclick="HandleNavigationAsync">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z"></path><path d="m8 14 2-4 2 3 2-6 2 7"></path></svg>
                <span>Benchmark</span>
            </NavLink>
        </div>
    </aside>

    <section class="studio-workbench">
        <div class="studio-scene-heading">
            <div>
                <span class="studio-scene-heading__eyebrow">@CurrentPageKicker</span>
                <h1>@CurrentPageTitle</h1>
                <p>@CurrentPageDescription</p>
            </div>

            <button type="button"
                    class="studio-context-trigger"
                    @onclick="ToggleContextLens"
                    aria-expanded="@IsContextLensOpen">
                <span>Contexte</span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 5h10M5 12h14M9 19h10"></path></svg>
            </button>
        </div>

        <GlobalScopeBar />

        <main class="studio-stage" id="studio-main">
            <div class="studio-stage__content">
                @Body
            </div>
        </main>
    </section>

    <aside class="studio-context-lens" aria-label="Contexte de travail">
        <div class="studio-context-lens__head">
            <div>
                <span>Context lens</span>
                <strong>@CurrentPageTitle</strong>
            </div>
            <button type="button"
                    class="studio-icon-button"
                    @onclick="CloseContextLens"
                    aria-label="Fermer le panneau contextuel">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18"></path></svg>
            </button>
        </div>

        <section class="studio-context-card studio-context-card--signal">
            <span class="studio-context-card__label">Mission active</span>
            <strong>@CurrentPageDescription</strong>
            <p>Le scope global reste actif pendant vos changements de domaine.</p>
        </section>

        <section class="studio-context-card">
            <span class="studio-context-card__label">Raccourcis</span>
            <div class="studio-context-actions">
                <NavLink href="compare">
                    <span>Comparer des joueuses</span>
                    <span aria-hidden="true">↗</span>
                </NavLink>
                <NavLink href="position-profiles">
                    <span>Ouvrir le benchmark</span>
                    <span aria-hidden="true">↗</span>
                </NavLink>
                <button type="button" @onclick="OpenCommandPalette">
                    <span>Recherche universelle</span>
                    <kbd>Ctrl K</kbd>
                </button>
            </div>
        </section>

        <section class="studio-context-card">
            <span class="studio-context-card__label">Session</span>
            <div class="studio-session-line">
                <span class="studio-account__avatar">@AccountInitials</span>
                <div>
                    <strong>@AccountName</strong>
                    <small>@AccountRole</small>
                </div>
            </div>

            @if (AuthService.Session.IsAuthenticated)
            {
                <button type="button" class="studio-logout-button" @onclick="Logout">
                    Fermer la session
                </button>
            }
        </section>
    </aside>

    <footer class="studio-activity-tray">
        <div class="studio-activity-tray__pulse">
            <span aria-hidden="true"></span>
            <strong>Studio live</strong>
            <small>Scope synchronise</small>
        </div>
        <div class="studio-activity-tray__current">
            <span>Domaine</span>
            <strong>@CurrentPageTitle</strong>
        </div>
        <button type="button" @onclick="OpenCommandPalette">
            Naviguer rapidement
            <span aria-hidden="true">⌘</span>
        </button>
    </footer>

    <nav class="studio-mobile-dock" aria-label="Navigation principale mobile">
        @foreach (var item in MobileNavItems)
        {
            <NavLink href="@item.Href"
                     Match="@item.Match"
                     @onclick="HandleNavigationAsync"
                     title="@item.Label">
                <span aria-hidden="true">@((MarkupString)item.IconMarkup)</span>
                <small>@item.Label</small>
            </NavLink>
        }
    </nav>

    <button type="button"
            class="studio-scrim"
            @onclick="CloseOverlays"
            aria-label="Fermer les panneaux"></button>
</div>

<CommandPalette @bind-IsOpen="IsCommandPaletteOpen" />

@code {
    private DotNetObjectReference<MainLayout>? _dotNetReference;
    private bool IsCommandPaletteOpen { get; set; }
    private bool IsDomainDrawerOpen { get; set; }
    private bool IsContextLensOpen { get; set; }
    private string Theme { get; set; } = "dark";

    private static IReadOnlyList<AppNavigationItem> MobileNavItems =>
        AppNavigationCatalog.Primary.Where(item => item.ShowOnMobile).ToList();

    private bool IsDarkTheme => string.Equals(Theme, "dark", StringComparison.OrdinalIgnoreCase);
    private string ThemeToggleTitle => IsDarkTheme ? "Passer au theme clair" : "Passer au theme sombre";
    private string AccountName => AuthService.Session.Username ?? "Session live";
    private string AccountRole => AuthService.Session.Role ?? "Consultation";
    private string AccountInitials => string.Concat(AccountName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(part => char.ToUpperInvariant(part[0])));

    private AppNavigationItem? CurrentNavigationItem
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
            var path = relativePath.Split('?', '#')[0].Trim('/');
            return AppNavigationCatalog.All
                .OrderByDescending(item => item.Href.Length)
                .FirstOrDefault(item => path.Equals(item.Href, StringComparison.OrdinalIgnoreCase)
                    || path.StartsWith($"{item.Href}/", StringComparison.OrdinalIgnoreCase));
        }
    }

    private string CurrentPageTitle => CurrentNavigationItem?.Label ?? "Studio";
    private string CurrentPageDescription => CurrentNavigationItem?.Description ?? "Intelligence de performance handball.";
    private string CurrentPageIndex => CurrentNavigationItem?.Index ?? "00";
    private string CurrentPageKicker => CurrentNavigationItem?.Kicker ?? "Performance operating system";

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        AuthService.SessionChanged += HandleSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            Theme = NormalizeTheme(await JS.InvokeAsync<string>("handwstatTheme.get"));
            _dotNetReference = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("handwstatCommands.register", _dotNetReference);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            Theme = "dark";
        }
    }

    [JSInvokable]
    public Task OpenCommandPaletteFromKeyboard()
    {
        OpenCommandPalette();
        return InvokeAsync(StateHasChanged);
    }

    private void OpenCommandPalette() => IsCommandPaletteOpen = true;
    private void ToggleDomainDrawer() => IsDomainDrawerOpen = !IsDomainDrawerOpen;
    private void ToggleContextLens() => IsContextLensOpen = !IsContextLensOpen;
    private void CloseContextLens() => IsContextLensOpen = false;

    private void CloseOverlays()
    {
        IsDomainDrawerOpen = false;
        IsContextLensOpen = false;
    }

    private Task HandleNavigationAsync()
    {
        CloseOverlays();
        return InvokeAsync(StateHasChanged);
    }

    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/");
    }

    private async Task ToggleThemeAsync()
    {
        Theme = IsDarkTheme ? "light" : "dark";
        try
        {
            await JS.InvokeVoidAsync("handwstatTheme.set", Theme);
        }
        catch
        {
            // The visual state remains valid when persistence is unavailable.
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        CloseOverlays();
        InvokeAsync(StateHasChanged);
    }

    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        AuthService.SessionChanged -= HandleSessionChanged;
        try
        {
            _ = JS.InvokeVoidAsync("handwstatCommands.unregister");
        }
        catch
        {
            // The JS runtime can already be disposed during shutdown.
        }

        _dotNetReference?.Dispose();
    }

    private static string NormalizeTheme(string? theme) =>
        string.Equals(theme, "light", StringComparison.OrdinalIgnoreCase) ? "light" : "dark";
}
