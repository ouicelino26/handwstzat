@inherits LayoutComponentBase
@implements IDisposable
@inject IApiAuthService AuthService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="app-shell @(IsSidebarCollapsed ? "is-collapsed" : string.Empty)">
    <aside class="app-sidebar">
        <div class="brand-block">
            <div class="brand-row">
                <div class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 56 56">
                        <circle cx="28" cy="28" r="26" class="brand-ball" />
                        <path d="M14 20h8v22h-8zM24 14h8v28h-8zM34 26h8v16h-8z" class="brand-bars" />
                        <path d="M16 16c6 3 18 3 24 0M14 28c10-6 18-6 28 0M16 40c6-3 18-3 24 0" class="brand-lines" />
                    </svg>
                </div>

                @if (!IsSidebarCollapsed)
                {
                    <div class="brand-copy">
                        <p class="brand-kicker">Handball analytics</p>
                        <h1>HandWStat</h1>
                        <p class="brand-text">Lecture claire des matchs, des joueuses et des equipes.</p>
                    </div>
                }
            </div>
        </div>

        <NavMenu Collapsed="IsSidebarCollapsed" OnNavigate="HandleNavigationAsync" />

        <div class="sidebar-footer">
            <button type="button"
                    class="ghost-button sidebar-action-button theme-action-button"
                    @onclick="ToggleThemeAsync"
                    aria-pressed="@IsDarkTheme"
                    title="@ThemeToggleTitle">
                <span class="sidebar-action-icon" aria-hidden="true">
                    @if (IsDarkTheme)
                    {
                        <svg viewBox="0 0 24 24">
                            <path d="M12 3a1 1 0 0 1 1 1v1.1a1 1 0 1 1-2 0V4a1 1 0 0 1 1-1Zm0 15.9a1 1 0 0 1 1 1V21a1 1 0 1 1-2 0v-1.1a1 1 0 0 1 1-1Zm8.9-6.9H21a1 1 0 1 1 0-2h-.1a1 1 0 1 1 0 2ZM4 12a1 1 0 0 1-1 1H2a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1Zm12.95-6.95a1 1 0 0 1 1.41 0l.78.78a1 1 0 1 1-1.41 1.41l-.78-.78a1 1 0 0 1 0-1.41ZM5.86 18.14a1 1 0 0 1 1.41 0l.78.78a1 1 0 1 1-1.41 1.41l-.78-.78a1 1 0 0 1 0-1.41ZM18.95 18.95a1 1 0 0 1 0 1.41l-.78.78a1 1 0 0 1-1.41-1.41l.78-.78a1 1 0 0 1 1.41 0ZM5.86 5.86a1 1 0 0 1 0 1.41l-.78.78a1 1 0 0 1-1.41-1.41l.78-.78a1 1 0 0 1 1.41 0ZM12 7.1A4.9 4.9 0 1 1 7.1 12 4.9 4.9 0 0 1 12 7.1Z" />
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24">
                            <path d="M20.6 14.9A8.9 8.9 0 0 1 9.1 3.4a1 1 0 0 0-1.2 1.2 7 7 0 0 0 10.3 8.2 1 1 0 0 1 1.4 1.4Z" />
                            <path d="M18 4v1.4M20.6 5.4 19.2 6.8M21 8h-1.4M20.6 10.6l-1.4-1.4" />
                        </svg>
                    }
                </span>
                <span class="sidebar-action-label">@ThemeToggleLabel</span>
            </button>

            @if (AuthService.Session.IsAuthenticated)
            {
                <button type="button" class="ghost-button sidebar-action-button logout-action-button" @onclick="LogoutAsync" title="Deconnexion">
                    <span class="sidebar-action-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M10 17l1.4-1.4L9.8 14H16V10H9.8l1.6-1.6L10 7l-4 4 4 4Zm9-14H11v2h8v10h-8v2h8c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2Z" />
                        </svg>
                    </span>
                    <span class="sidebar-action-label">Deconnexion</span>
                </button>
            }
        </div>
    </aside>

    <div class="app-stage">
        <button type="button"
                class="icon-button mobile-nav-toggle"
                @onclick="ToggleSidebar"
                aria-label="@SidebarToggleLabel"
                title="@SidebarToggleLabel">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                @if (IsSidebarCollapsed)
                {
                    <path d="M4 7h16M4 12h16M4 17h16" />
                }
                else
                {
                    <path d="M6 6l12 12M18 6 6 18" />
                }
            </svg>
        </button>

        <main class="app-main">
            <article class="app-content">
                @Body
            </article>
        </main>
    </div>

    <nav class="mobile-nav-rail" aria-label="Navigation principale mobile">
        @foreach (var item in MobileNavItems)
        {
            <NavLink class="mobile-nav-link" href="@item.Href" Match="@item.Match" @onclick="HandleNavigationAsync" title="@item.Title">
                <span class="mobile-nav-icon" aria-hidden="true">@((MarkupString)item.IconMarkup)</span>
                <span class="mobile-nav-label">@item.Title</span>
            </NavLink>
        }
    </nav>

    <button class="shell-overlay" @onclick="CloseSidebar" aria-label="Fermer le menu"></button>
</div>

@code {
    private static readonly IReadOnlyList<MobileNavItem> MobileNavItems =
    [
        new(
            "dashboard",
            "Tableau",
            NavLinkMatch.All,
            """
            <svg viewBox="0 0 24 24"><path d="M4 13h4v7H4zM10 9h4v11h-4zM16 5h4v15h-4zM4 4h16" /></svg>
            """),
        new(
            "players",
            "Joueuses",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M12 6a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM5 20a7 7 0 0 1 14 0M3 10l4 2m14-2-4 2" /></svg>
            """),
        new(
            "compare",
            "Comparer",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M7 5h4v14H7zM13 9h4v10h-4zM4 20h16M9 5V3m6 6V3" /></svg>
            """),
        new(
            "position-profiles",
            "Profil poste",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M12 3l7 4v10l-7 4-7-4V7l7-4Zm0 4.2-3.8 2.2v4.4L12 16l3.8-2.2V9.4L12 7.2Zm0-4.2v4.2" /></svg>
            """),
        new(
            "teams",
            "Equipes",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M12 3l8 4v6c0 4.5-3.3 7.6-8 8-4.7-.4-8-3.5-8-8V7l8-4Z" /><path d="M8.5 12h7" /></svg>
            """),
        new(
            "matches",
            "Matchs",
            NavLinkMatch.Prefix,
            """
            <svg viewBox="0 0 24 24"><path d="M5 5h14v14H5zM5 9h14M9 5v14" /></svg>
            """)
    ];

    private bool IsSidebarCollapsed { get; set; } = true;

    private string Theme { get; set; } = "light";

    private bool IsDarkTheme => string.Equals(Theme, "dark", StringComparison.OrdinalIgnoreCase);

    private string ThemeToggleLabel => IsDarkTheme ? "Mode clair" : "Mode sombre";

    private string ThemeToggleTitle => IsDarkTheme ? "Passer au mode clair" : "Passer au mode sombre";

    private string SidebarToggleLabel => IsSidebarCollapsed ? "Ouvrir le menu" : "Fermer le menu";

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        AuthService.SessionChanged += HandleSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var currentTheme = await JS.InvokeAsync<string>("handwstatTheme.get");
            if (!string.IsNullOrWhiteSpace(currentTheme))
            {
                Theme = NormalizeTheme(currentTheme);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Keep the default light theme if the JS bridge is unavailable.
        }
    }

    private void ToggleSidebar()
    {
        IsSidebarCollapsed = !IsSidebarCollapsed;
    }

    private void CloseSidebar()
    {
        IsSidebarCollapsed = true;
    }

    private Task HandleNavigationAsync()
    {
        CloseSidebar();
        return InvokeAsync(StateHasChanged);
    }

    private void LogoutAsync()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/");
    }

    private async Task ToggleThemeAsync()
    {
        Theme = IsDarkTheme ? "light" : "dark";

        try
        {
            await JS.InvokeVoidAsync("handwstatTheme.set", Theme);
        }
        catch
        {
            // If persistence fails, the UI still reflects the new theme locally.
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        CloseSidebar();
        InvokeAsync(StateHasChanged);
    }

    private void HandleSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        AuthService.SessionChanged -= HandleSessionChanged;
    }

    private static string NormalizeTheme(string? theme)
    {
        return string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase) ? "dark" : "light";
    }

    private sealed record MobileNavItem(
        string Href,
        string Title,
        NavLinkMatch Match,
        string IconMarkup);
}
